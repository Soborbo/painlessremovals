{
  "name": "painless-removals",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "images": "node scripts/optimize-images.mjs",
    "images:force": "node scripts/optimize-images.mjs --force",
    "dev": "astro dev --host",
    "start": "astro dev --host",
    "build": "astro check && astro build && node scripts/check-sitemap.mjs",
    "build:prod": "astro check && astro build && node scripts/check-sitemap.mjs && wrangler deploy --dry-run --config ./dist/server/wrangler.json",
    "preview": "astro build && wrangler dev --config ./dist/server/wrangler.json",
    "deploy": "astro check && astro build && node scripts/check-sitemap.mjs && wrangler deploy --config ./dist/server/wrangler.json",
    "astro": "astro",
    "check": "astro check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@nanostores/react": "^1.1.0",
    "@noble/hashes": "^2.2.0",
    "astro": "^7.0.0",
    "clsx": "^2.1.1",
    "lite-youtube-embed": "^0.3.4",
    "nanostores": "^1.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.14.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20260623.1",
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/google.maps": "^3.65.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "sharp": "^0.35.2",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  },
  "overrides": {
    "vite": "^8.1.0"
  }
}
