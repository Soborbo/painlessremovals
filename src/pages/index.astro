    <div class="container-wide">
      <div class="grid lg:grid-cols-[auto_1fr] gap-10 lg:gap-16 items-center">
        <!-- Jay portrait -->
        <div class="flex flex-col items-center text-center mx-auto lg:mx-0 order-last lg:order-first">
          <OptimizedPicture
            name="homepage/Jay-Newton-Painless-Removals"
            pattern="QUARTER"
            alt="Jay Newton, Director of Painless Removals"
            sizes="(min-width: 1024px) 280px, 200px"
            class="w-48 lg:w-72 aspect-[3/4] object-cover object-top rounded-xl shadow-md"
          />
