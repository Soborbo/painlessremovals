// ── Schema ─────────────────────────────────────────────────────────────────────

// LCP hero preload: mobile uses pattern="FULL" (100vw), desktop uses pattern="HALF" (50vw).
// Sizes override covers both so the browser picks the right width per breakpoint.
const heroPreload = getLcpPreload('homepage/painless-removals-team', 'FULL', {
  sizes: '(min-width:1024px) 50vw, 100vw',
});

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": ENTITY.website,
    "url": siteConfig.brand.domain,
    "name": siteConfig.brand.name,
    "description": siteConfig.seo.defaultDescription,
    "publisher": ref.business(),
    "inLanguage": "en-GB",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": `${siteConfig.brand.domain}/search?q={search_term_string}`,
      },
      "query-input": "required name=search_term_string",
    },
  },
  faqPage(faqs),
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schema={schemas}
  ogImage="/img/homepage/painless-removals-team-1200w.webp"
  preload={heroPreload}
>

  <!-- ═══════════════════════════════════════════════════════════════════════════
       SECTION 1: Hero (service-page pattern)
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="relative lg:grid lg:grid-cols-2 lg:min-h-[calc(100dvh-var(--header-h,104px))]">
    <!-- Mobile: Image at top -->
    <div class="lg:hidden w-full h-[50vh] min-h-[280px] relative overflow-hidden">
      <OptimizedPicture
        name="homepage/painless-removals-team"
        pattern="FULL"
        alt="The Painless Removals crew sitting on the back of a removal van on a Bristol residential street"
        lcp
        class="w-full h-full object-cover object-bottom"
      />
    </div>

    <!-- Left: Content area -->
    <div class="gradient-hero px-6 py-8 lg:py-10 lg:px-12 xl:px-16 flex flex-col justify-center">
      <div class="max-w-xl mx-auto text-center">
        <h1 class="text-primary-600 text-sm font-semibold uppercase tracking-wide mb-2">
          Top-Rated Home Removals Company in Bristol
        </h1>

        <h2 class="text-3xl lg:text-4xl xl:text-5xl mb-3 lg:mb-4 font-bold">
          Have a<br /><span class="text-secondary-500">Painless</span> Removal
        </h2>

        <p class="text-lg lg:text-xl text-warm-gray mb-5 lg:mb-6 leading-relaxed py-[15px]">
          Bristol removals company with nearly 50 years of experience and fantastic reviews. Get an instant quote and enjoy a removal done properly — never rushed.
        </p>

        <div class="flex flex-col gap-2 mb-5 items-center">
          <a href="/instantquote/" class="btn-cta-orange">
            GET MY QUOTE IN JUST 47 SECONDS
          </a>
          <p class="text-warm-gray text-sm">Free, no risk, no obligation</p>
        </div>

        <TrustpilotStrip />
      </div>
    </div>

    <!-- Right: Full-bleed image (desktop only) -->
    <div class="hidden lg:block relative overflow-hidden">
      <OptimizedPicture
        name="homepage/painless-removals-team"
        pattern="HALF"
        alt="The Painless Removals crew sitting on the back of a removal van on a Bristol residential street"
        lcp
        class="absolute inset-0 w-full h-full object-cover"
      />
    </div>
  </section>

  <!-- USPs - Full width bar -->
  <UspBar />


  <!-- ═══════════════════════════════════════════════════════════════════════════
       SECTION 2: Instant Online Quote (full-bleed 50/50)
       ═══════════════════════════════════════════════════════════════════════ -->
  <QuoteTeaser />


