---
/**
 * Contact Thank You Page
 *
 * Displayed after successful contact form submission.
 * Shows Jay's photo and a reassuring callback message.
 */

import OptimizedPicture from '@/components/OptimizedPicture.astro';
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config/site.config';

const pageTitle = 'Thank You – We\'ll Call You Back';
const pageDescription = 'Thank you for contacting Painless Removals. We\'ll call you back as soon as we can during our office hours.';
---

<Layout title={pageTitle} description={pageDescription} noindex={true}>

  <section class="section bg-cream">
    <div class="container-wide">
      <div class="max-w-2xl mx-auto text-center">

        <!-- Jay's photo -->
        <div class="w-40 h-40 mx-auto mb-8 rounded-full overflow-hidden shadow-lg border-4 border-white">
          <OptimizedPicture
            name="about/team/Jay-Newton"
            pattern="SIXTH"
            alt="Jay Newton, Director of Painless Removals"
            loading="eager"
            class="w-full h-full object-cover"
          />
        </div>

        <!-- Confirmation icon -->
        <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-green-100 flex items-center justify-center">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </div>

        <h1 class="text-3xl lg:text-4xl font-bold mb-4">
          Thank You – We'll Call You Back
        </h1>

        <p class="text-lg text-warm-gray leading-relaxed mb-6 max-w-lg mx-auto">
          Thanks for getting in touch. We'll give you a call back as soon as we can.
          Our hours are <strong class="text-primary-600">Monday to Friday, 9am–5pm</strong>.
        </p>

        <p class="text-warm-gray mb-8">
          If you need a faster response, call us directly:
        </p>

        <!-- Big call button -->
        <a href={`tel:${siteConfig.company.contact.phone.replace(/\s/g, '')}`}
          class="btn-cta-orange inline-flex items-center gap-3 text-xl no-underline duration-300 hover:shadow-orange-600/40 hover:text-white/90">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Call {siteConfig.company.contact.phone}
        </a>

        <!-- Return link -->
        <div class="mt-10">
          <a href="/" class="inline-flex items-center gap-1.5 text-primary-600 font-medium no-underline border-b-2 border-accent-500 pb-0.5 transition-all duration-200 hover:text-secondary-500 hover:border-secondary-500">
            Return to homepage <span class="text-sm transition-transform duration-200">→</span>
          </a>
        </div>

      </div>
    </div>
  </section>

</Layout>
