---
/**
 * INSTANT QUOTE — RESULT PAGE
 *
 * Standalone result page outside the calculator step flow.
 * Displays the final quote with full breakdown, video, and quote options.
 */

export const prerender = false;

import '@/styles/calculator.css';
import { ResultPage } from '@/components/calculator/ResultPage';
import GTMHead from '@/components/GTMHead.astro';
import GTMBody from '@/components/GTMBody.astro';

// Google Maps API key (needed if user navigates back)
import { env } from 'cloudflare:workers';
const googleMapsApiKey = env.GOOGLE_MAPS_API_KEY
  || import.meta.env.GOOGLE_MAPS_API_KEY
  || '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Your moving quote from Painless Removals" />
    <title>Your Quote | Painless Removals</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700&family=DM+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <GTMHead />
    {/* Cloudflare Turnstile — INVISIBLE widget (no user-facing challenge).
        This page fires the quote + callback conversions; without this
        script and the container below, worker-dispatch.ts waits 10 s for
        window.turnstile and silently DROPS every server-side Meta CAPI
        leg (CLAUDE.md rule 4b). */}
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>
    {googleMapsApiKey && (
      <script
        async
        defer
        src={`https://maps.googleapis.com/maps/api/js?key=${googleMapsApiKey}&libraries=places&language=en-GB&region=GB`}
      />
    )}
  </head>
  <body class="min-h-screen antialiased flex flex-col" style="background: #F0EBE3; font-family: 'DM Sans', -apple-system, sans-serif;">
    <GTMBody />
    {/* Invisible Turnstile container — worker-tracking.ts renders the widget here. */}
    <div id="cf-turnstile-invisible" style="display:none" aria-hidden="true"></div>
    <main class="flex-1">
      <ResultPage client:load />
    </main>

    <footer class="mt-auto">
      <div class="text-center text-sm py-6" style="color: #8A8578;">
        <p>&copy; {new Date().getFullYear()} Painless Removals. All rights reserved.</p>
      </div>
    </footer>

    <!-- Tracking bootstrap: resumes quote timer, installs click + scroll listeners -->
    <script>
      import '@/lib/tracking/boot';
    </script>
  </body>
</html>
