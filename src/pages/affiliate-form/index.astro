---
/**
 * Partner Referral Form
 *
 * Private page for referring partners to submit client referrals.
 * Not indexed — shared directly with affiliate partners.
 * Includes Cloudflare Turnstile, honeypot spam protection,
 * and inline success confirmation.
 */

import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config/site.config';

// Page metadata – noindex (partner-only page)
const pageTitle = 'Partner Referral Form';
const pageDescription = 'Submit a client referral to Painless Removals. For approved referring partners only.';

// Turnstile site key – set via PUBLIC_TURNSTILE_SITE_KEY env var
const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;

// Schema: WebPage
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": pageTitle,
  "description": pageDescription,
  "url": `${siteConfig.brand.domain}/affiliate-form`,
  "isPartOf": {
    "@id": `${siteConfig.brand.domain}/#business`,
  },
};
---

<Layout title={pageTitle} description={pageDescription} schema={pageSchema} noindex={true}>

  <section class="section bg-cream">
    <div class="container-narrow">

      <!-- Page heading -->
      <div class="text-center mb-10">
        <p class="text-primary-600 text-sm font-semibold uppercase tracking-wide mb-2">
          Painless Removals Partner Programme
        </p>
        <h1 class="text-3xl lg:text-4xl font-bold mb-4">
          Partner Referral Form
        </h1>
        <p class="text-warm-gray leading-relaxed max-w-xl mx-auto">
          Use this form to refer a client to Painless Removals. We'll send them a
          friendly introduction email and follow up within 2 hours during office hours.
        </p>
      </div>

      <!-- Referral form -->
      <div id="form-wrapper" class="max-w-lg mx-auto">
        <form id="affiliate-form-el" class="space-y-5" novalidate>

          <!-- Honeypot – hidden from humans, bots fill it -->
          <div style="position: absolute; left: -9999px;" aria-hidden="true">
            <label for="website">Leave this blank</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <!-- Referring Agent Name -->
          <div>
            <label for="referringAgent" class="block text-sm font-semibold text-primary-600 mb-1.5">Your Name <span class="text-secondary-500">*</span></label>
            <input type="text" id="referringAgent" name="referringAgent" required autocomplete="name"
              placeholder="e.g. Sarah Jones, ABC Estate Agents"
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" />
          </div>

          <!-- Client Name -->
          <div>
            <label for="clientName" class="block text-sm font-semibold text-primary-600 mb-1.5">Client Name <span class="text-secondary-500">*</span></label>
            <input type="text" id="clientName" name="clientName" required autocomplete="off"
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" />
          </div>

          <!-- Client Phone and Client Email row -->
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="clientPhone" class="block text-sm font-semibold text-primary-600 mb-1.5">Client Phone <span class="text-secondary-500">*</span></label>
              <input type="tel" id="clientPhone" name="clientPhone" required autocomplete="off"
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" />
            </div>
            <div>
              <label for="clientEmail" class="block text-sm font-semibold text-primary-600 mb-1.5">Client Email <span class="text-secondary-500">*</span></label>
              <input type="email" id="clientEmail" name="clientEmail" required autocomplete="off"
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" />
            </div>
          </div>

          <!-- GDPR Consent Checkbox -->
          <div class="flex items-start gap-3">
            <input type="checkbox" id="gdprConsent" name="gdprConsent" required
              class="mt-1 h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500 transition-colors" />
            <label for="gdprConsent" class="text-sm text-warm-gray leading-relaxed">
              I confirm that I have obtained the client's consent to share their contact details with Painless Removals. <span class="text-secondary-500">*</span>
            </label>
          </div>

          <!-- Cloudflare Turnstile -->
          <div>
            <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="light"></div>
          </div>

          <!-- Error message area -->
          <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm"></div>

          <!-- Submit -->
          <div>
            <button type="submit" id="submit-btn"
              class="btn-cta-orange no-underline duration-300 hover:shadow-orange-600/40 cursor-pointer w-full sm:w-auto">
              SUBMIT REFERRAL
            </button>
          </div>
        </form>
      </div>

    </div>
  </section>

  <!-- Cloudflare Turnstile script -->
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <!-- Referral form submission -->
  <script is:inline>
    (function() {
      var form = document.getElementById('affiliate-form-el');
      var errorDiv = document.getElementById('form-error');
      var submitBtn = document.getElementById('submit-btn');

      if (form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault();

          errorDiv.classList.add('hidden');
          errorDiv.textContent = '';

          var referringAgent = form.querySelector('#referringAgent').value.trim();
          var clientName = form.querySelector('#clientName').value.trim();
          var clientPhone = form.querySelector('#clientPhone').value.trim();
          var clientEmail = form.querySelector('#clientEmail').value.trim();
          var gdprConsent = form.querySelector('#gdprConsent').checked;
          var honeypot = form.querySelector('#website').value;

          // Client-side validation
          if (!referringAgent) {
            window.showToast('Please enter your name or agency so we know who made the referral.', 'error');
            form.querySelector('#referringAgent').focus();
            return;
          }
          if (!clientName) {
            window.showToast('Please enter the client\'s full name.', 'error');
            form.querySelector('#clientName').focus();
            return;
          }
          if (!clientPhone) {
            window.showToast('Please enter the client\'s phone number.', 'error');
            form.querySelector('#clientPhone').focus();
            return;
          }
          if (!clientEmail) {
            window.showToast('Please enter the client\'s email address.', 'error');
            form.querySelector('#clientEmail').focus();
            return;
          }
          if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(clientEmail)) {
            window.showToast('The client\'s email address doesn\'t look right — please double-check it.', 'error');
            form.querySelector('#clientEmail').focus();
            return;
          }

          if (!gdprConsent) {
            window.showToast('Please confirm that you have the client\'s consent to share their details before submitting.', 'warning');
            form.querySelector('#gdprConsent').focus();
            return;
          }

          var turnstileResponse = '';
          var turnstileInput = form.querySelector('[name="cf-turnstile-response"]');
          if (turnstileInput) {
            turnstileResponse = turnstileInput.value;
          }

          if (!turnstileResponse) {
            window.showToast('Please complete the security check before submitting.', 'warning');
            return;
          }

          submitBtn.disabled = true;
          submitBtn.textContent = 'SUBMITTING...';

          fetch('/api/affiliate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              referringAgent: referringAgent,
              clientName: clientName,
              clientPhone: clientPhone,
              clientEmail: clientEmail,
              gdprConsent: gdprConsent,
              honeypot: honeypot,
              turnstileToken: turnstileResponse,
            }),
          })
          .then(function(res) { return res.json(); })
          .then(function(data) {
            if (data.success) {
              // Redirect to thank-you page with client name
              var name = data.clientName || clientName;
              var params = '?name=' + encodeURIComponent(name);
              if (data.warning) params += '&warning=1';
              window.location.href = '/affiliate-form/thank-you/' + params;
            } else {
              window.showToast(data.error || 'Something went wrong submitting the referral. Please try again or call us on 0117 287 0082.', 'error');
              submitBtn.disabled = false;
              submitBtn.textContent = 'SUBMIT REFERRAL';
              if (window.turnstile) { window.turnstile.reset(); }
            }
          })
          .catch(function() {
            window.showToast('Connection error — please check your internet and try again, or call us on 0117 287 0082.', 'error');
            submitBtn.disabled = false;
            submitBtn.textContent = 'SUBMIT REFERRAL';
          });
        });
      }
    })();
  </script>

</Layout>
