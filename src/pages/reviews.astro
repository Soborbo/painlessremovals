<!-- ─── Review Meter Animation ────────────────────────────────────────────── -->
<script is:inline>
  (function() {
    var meter = document.getElementById('review-meter');
    if (!meter) return;

    var animated = false;
    var targetRating = parseFloat(meter.dataset.rating) || 4.9;
    var targetPercent = (targetRating / 5) * 100;

    function animateNumber(el, target, duration) {
      var startTime = null;
      function step(ts) {
        if (!startTime) startTime = ts;
        var progress = Math.min((ts - startTime) / duration, 1);
        var eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(eased * target);
        if (progress < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    function animateRating(el, target, duration) {
      var startTime = null;
      function step(ts) {
        if (!startTime) startTime = ts;
        var progress = Math.min((ts - startTime) / duration, 1);
        var eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = (eased * target).toFixed(1);
        if (progress < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    function runAnimation() {
      if (animated) return;
      animated = true;
      var fill = document.getElementById('meter-fill');
      if (fill) fill.style.width = targetPercent + '%';
      var ratingEl = document.getElementById('meter-value');
      if (ratingEl) animateRating(ratingEl, targetRating, 2000);
      document.querySelectorAll('#meter-stats [data-count]').forEach(function(counter) {
        animateNumber(counter, parseInt(counter.getAttribute('data-count'), 10), 1800);
      });
    }

    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) { setTimeout(runAnimation, 300); observer.disconnect(); }
        });
      }, { threshold: 0.3 });
      observer.observe(meter);
    } else {
      setTimeout(runAnimation, 500);
    }
  })();
</script>


<!-- ─── Section Nav: Scroll Spy + Smooth Scroll ───────────────────────────── -->
<script is:inline>
  (function() {
    var nav = document.querySelector('.review-section-nav');
    if (!nav) return;

    var links = nav.querySelectorAll('.reviews-nav-link');
    var sectionData = [];

    links.forEach(function(link) {
      var targetId = link.getAttribute('data-section-target');
      var section = document.getElementById(targetId);
      if (section) sectionData.push({ link: link, section: section });
    });

    if (!sectionData.length) return;

    // Smooth scroll on click — offset by nav height + top bar
    links.forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        var targetId = link.getAttribute('data-section-target');
        var target = document.getElementById(targetId);
        if (!target) return;
        var offset = nav.offsetHeight + parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--top-bar-h') || '88') + 8;
        var top = target.getBoundingClientRect().top + window.pageYOffset - offset;
        window.scrollTo({ top: top, behavior: 'smooth' });
      });
    });

    // Scroll spy
    var ticking = false;
    function updateActive() {
      var navOffset = nav.offsetHeight + parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--top-bar-h') || '88') + 16;
      var active = null;

      for (var i = sectionData.length - 1; i >= 0; i--) {
        var rect = sectionData[i].section.getBoundingClientRect();
        if (rect.top <= navOffset) {
          active = sectionData[i];
          break;
        }
      }

      links.forEach(function(l) { l.classList.remove('active'); });
      if (active) active.link.classList.add('active');
      ticking = false;
    }

    window.addEventListener('scroll', function() {
      if (!ticking) { requestAnimationFrame(updateActive); ticking = true; }
    }, { passive: true });

    updateActive();
  })();
</script>
