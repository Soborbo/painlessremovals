---
/**
 * Reviews Page — Painless Removals
 *
 * Curated, editorial reviews page with themed sections.
 * LocalBusiness + AggregateRating schema (no individual Review schema).
 */

import Layout from '@/layouts/Layout.astro';
import UspBar from '@/components/UspBar.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';
import FinalCTA from '@/components/FinalCTA.astro';
import { siteConfig } from '@/config/site.config';
import { ENTITY, ref, faqPage, breadcrumbs } from '@/utils/schema';

// ── Page Meta ──────────────────────────────────────────────────────────────────

const pageTitle = 'Reviews | Painless Removals Bristol';
const pageDescription = `Read real reviews from families, professionals, and repeat customers who moved with Painless Removals Bristol. ${siteConfig.company.rating.value} stars across ${siteConfig.company.rating.count}+ reviews on Google and Trustpilot.`;

// ── Types ─────────────────────────────────────────────────────────────────────

interface Review {
  name: string;
  platform: 'google' | 'trustpilot' | 'facebook';
  rating: number;
  html: string;
}

interface ReviewSection {
  id: string;
  heading: string;
  navLabel: string;
  intro: string;
  reviews: Review[];
  bg: string;
  accent: string;
  chipBg: string;
}

// ── Featured Quote ────────────────────────────────────────────────────────────

const featuredQuote: Review = {
  name: 'Claire G.',
  platform: 'google',
  rating: 5,
  html: 'I had been dreading this move and came into it extremely stressed, but moving with these guys was a pleasure. Despite everything, <mark>our Painless removal was as painless as moving house can possibly get</mark>. In fact I have lasting happy memories.',
};

// ── Review Sections ───────────────────────────────────────────────────────────

const sections: ReviewSection[] = [
  {
    id: 'stress-free',
    heading: 'They made the worst day\u2026 easy',
    navLabel: 'Made Easy',
