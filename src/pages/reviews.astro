    accent: '#6B4E97',
    chipBg: '#CABEE8',
    reviews: [
      {
        name: 'Jeremy Vize',
        platform: 'google',
        rating: 5,
        html: 'I\u2019m disabled as I had a stroke last year so I decided to get movers for my move and they were absolutely great. <mark>They literally did everything, packed my whole flat</mark> and were lovely guys! I just sat on the sofa and did some work while they packed away my whole flat. Really great movers, lovely people, cannot recommend enough.',
