---

<Layout
  title={pageTitle}
  description={pageDescription}
  schema={schema}
  canonical={`${siteConfig.brand.domain}/reviews`}
>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO SECTION
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="gradient-hero">
    <div class="container-wide py-8 lg:py-10">
      <div class="lg:grid lg:grid-cols-2 lg:gap-10 items-center">

        <!-- Left: Heading + CTA -->
        <div class="text-center lg:text-left mb-8 lg:mb-0">
          <h1 class="text-primary-600 text-sm font-semibold uppercase tracking-wide mb-2">
            Bristol Removals Reviews
          </h1>

          <p class="text-3xl lg:text-4xl xl:text-5xl mb-3 font-bold font-heading">
            We Are Extremely Proud of <span class="text-secondary-500">Our Reviews</span>
          </p>

          <p class="text-lg lg:text-xl text-warm-gray mb-5 leading-relaxed max-w-xl mx-auto lg:mx-0">
            We have some of the highest-rated removal reviews in Bristol &amp; Bath. Almost exclusively five-star recommendations across all major review platforms.
          </p>

          <div class="flex flex-col gap-2 items-center lg:items-start">
            <a href="/instantquote/" class="btn-cta-orange">
              GET YOUR FREE QUOTE
            </a>
            <p class="text-warm-gray text-sm">Free, no risk, no obligation</p>
          </div>
        </div>

        <!-- Right: Aggregate Rating + Platform Breakdown -->
        <div class="flex flex-col justify-center">
          <!-- Rating card -->
          <div class="bg-white rounded-2xl shadow-lg p-5 mb-3" id="review-meter" data-rating={siteConfig.company.rating.value}>
            <div class="flex items-center justify-center gap-3 mb-3">
              <span class="font-heading text-5xl font-bold text-primary-600 leading-none" id="meter-value">0.0</span>
              <div class="text-left">
                <div class="text-yellow-400 text-xl tracking-wider leading-none mb-0.5">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                <span class="text-xs font-semibold text-primary-600 uppercase tracking-wide">Aggregate Rating</span>
              </div>
            </div>

            <div class="relative h-2.5 bg-gray-100 rounded-full overflow-hidden mb-4">
              <div class="absolute inset-y-0 left-0 bg-linear-to-r from-yellow-400 via-yellow-400 to-green-500 rounded-full transition-all duration-[2000ms] ease-out" id="meter-fill" style="width: 0%"></div>
            </div>

            <div class="grid grid-cols-3 gap-3 text-center" id="meter-stats">
              <div class="bg-primary-50 rounded-lg py-2.5 px-2">
                <div class="font-heading font-bold text-primary-600 text-xl" data-count={String(siteConfig.company.rating.count)} data-suffix="">0</div>
                <div class="text-warm-gray text-xs">Total Reviews</div>
              </div>
              <div class="bg-green-50 rounded-lg py-2.5 px-2">
                <div class="font-heading font-bold text-green-600 text-xl" data-count="117" data-suffix="">0</div>
                <div class="text-warm-gray text-xs">Five-Star</div>
              </div>
              <div class="bg-yellow-50 rounded-lg py-2.5 px-2">
                <div class="font-heading font-bold text-yellow-600 text-xl" data-count="3" data-suffix="">0</div>
                <div class="text-warm-gray text-xs">Four-Star</div>
              </div>
            </div>
          </div>

          <!-- Platform breakdown -->
          <div class="grid grid-cols-2 gap-2">
            <a href={siteConfig.company.contact.googleBusiness} target="_blank" rel="noopener" class="bg-white rounded-lg px-3 py-2.5 shadow-sm border border-gray-100 no-underline flex items-center gap-2 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 group">
              <img src="/images/google-g-logo.svg" alt="Google" class="w-6 h-6 shrink-0 group-hover:scale-110 transition-transform" width="48" height="48" />
              <div>
                <div class="font-heading font-bold text-primary-600 text-sm leading-tight">98 reviews</div>
                <div class="text-yellow-500 text-[10px]">&#9733;&#9733;&#9733;&#9733;&#9733; {siteConfig.company.rating.value} avg</div>
              </div>
            </a>
            <a href="https://uk.trustpilot.com/review/painlessremovals.com" target="_blank" rel="noopener" class="bg-white rounded-lg px-3 py-2.5 shadow-sm border border-gray-100 no-underline flex items-center gap-2 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 group">
              <img src="/images/trustpilot-logo.svg" alt="Trustpilot" class="h-4 w-auto shrink-0 group-hover:scale-110 transition-transform" width="220" height="50" />
              <div>
                <div class="font-heading font-bold text-primary-600 text-sm leading-tight">33 reviews</div>
                <div class="text-yellow-500 text-[10px]">&#9733;&#9733;&#9733;&#9733;&#9733; {siteConfig.company.rating.value} avg</div>
              </div>
            </a>
            <a href="https://www.yell.com/biz/painless-removals-bristol-7066268/" target="_blank" rel="noopener" class="bg-white rounded-lg px-3 py-2.5 shadow-sm border border-gray-100 no-underline flex items-center gap-2 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 group">
              <img src="/images/yell-logo.svg" alt="Yell" class="h-4 w-auto shrink-0 group-hover:scale-110 transition-transform" width="120" height="40" />
              <div>
                <div class="font-heading font-bold text-primary-600 text-sm leading-tight">5 reviews</div>
                <div class="text-yellow-500 text-[10px]">&#9733;&#9733;&#9733;&#9733;&#9733; 5.0 avg</div>
              </div>
