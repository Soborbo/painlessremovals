---
/**
 * Send Survey Video Page
 *
 * Dedicated page for customers who are ready to upload their
 * walkthrough video. Provides WhatsApp and Dropbox upload options,
 * filming tips, and a prominent help section.
 */

import Layout from '@/layouts/Layout.astro';
import FilmingTipsGrid from '@/components/FilmingTipsGrid.astro';
import { siteConfig } from '@/config/site.config';
import { breadcrumbs } from '@/utils/schema';

const pageTitle = 'Send Us Your Survey Video | Painless Removals';
const pageDescription = 'Ready to send your home walkthrough video? Upload via WhatsApp or Dropbox and we\'ll send you an accurate removal quote within hours.';

const phone = siteConfig.company.contact.phone;
const phoneTel = phone.replace(/\s/g, '');
const whatsapp = siteConfig.company.contact.whatsapp;
const whatsappDisplay = siteConfig.company.contact.whatsappDisplay;
const whatsappLink = `https://wa.me/${whatsapp}?text=${encodeURIComponent('Hi, I\'d like to send my survey video for a removal quote.')}`;
const emailLink = `mailto:${siteConfig.company.contact.email}?subject=${encodeURIComponent('Survey video for removal quote')}&body=${encodeURIComponent('Hi,\n\nPlease find my survey video at the link below:\n\n[Paste your Dropbox/Google Drive/WeTransfer link here]\n\nThanks!')}`;

const breadcrumbSchema = breadcrumbs([
  { name: "Home", path: "/" },
  { name: "Free Home Survey", path: "/free-home-survey/" },
  { name: "Send Survey Video" },
]);
---

<Layout title={pageTitle} description={pageDescription} schema={[breadcrumbSchema]}>

  <!-- Breadcrumbs -->
  <div class="bg-white border-b border-gray-100">
    <div class="container-wide py-3">
      <nav class="text-sm text-warm-gray" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="text-primary-600 hover:text-primary-700 no-underline">Home</a></li>
          <li class="text-warm-gray/50">/</li>
          <li><a href="/free-home-survey/" class="text-primary-600 hover:text-primary-700 no-underline">Free Home Survey</a></li>
          <li class="text-warm-gray/50">/</li>
          <li class="text-warm-gray">Send Survey Video</li>
        </ol>
      </nav>
    </div>
  </div>

  <!-- ============================================
       HERO — with upload buttons above the fold
  ============================================ -->
  <section class="gradient-hero">
    <div class="container-wide py-10 md:py-16">

      <!-- Heading -->
      <div class="text-center mb-8 md:mb-10">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-3">
          Send Us Your <span class="text-secondary-500">Survey Video</span>
        </h1>
        <p class="text-lg text-warm-gray max-w-2xl mx-auto">
          Choose how you'd like to send your video. We'll review it and get back to you with an accurate quote, usually within a few hours.
        </p>
      </div>

      <!-- Two upload cards — side by side, in the hero -->
      <div class="grid md:grid-cols-2 gap-5 lg:gap-6 max-w-3xl mx-auto">

        <!-- WhatsApp -->
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer"
           class="group bg-white rounded-2xl border-2 border-green-200 hover:border-green-400 shadow-sm hover:shadow-lg transition-all duration-300 p-6 lg:p-8 text-center no-underline flex flex-col items-center">
          <div class="w-14 h-14 rounded-full bg-green-100 text-green-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <span class="text-xl font-bold text-gray-900 mb-1">Send via WhatsApp</span>
          <span class="text-warm-gray text-sm mb-4">Quickest way &mdash; up to 2 GB per video</span>
          <span class="inline-flex items-center gap-2 bg-green-500 group-hover:bg-green-600 text-white font-bold px-6 py-3 rounded-lg transition-colors duration-200 text-sm">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            OPEN WHATSAPP
          </span>
          <span class="text-xs text-warm-gray mt-2">{whatsappDisplay}</span>
        </a>

        <!-- Dropbox Upload -->
        <div class="bg-white rounded-2xl border-2 border-blue-200 shadow-sm p-6 lg:p-8 text-center flex flex-col items-center">
          <div class="w-14 h-14 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center mb-4">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z"/></svg>
          </div>
          <span class="text-xl font-bold text-gray-900 mb-1">Upload via Dropbox</span>
          <span class="text-warm-gray text-sm mb-4">No account needed &mdash; just drag &amp; drop</span>
          <a href="https://www.dropbox.com/request/c7s2YBgAkZSXw9eCATzK" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-lg transition-colors duration-200 text-sm no-underline mb-3">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z"/></svg>
            UPLOAD TO DROPBOX
          </a>
          <a href={emailLink}
             class="inline-flex items-center gap-2 text-warm-gray hover:text-primary-600 text-sm no-underline transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            or email us the link
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================
       STUCK? WE'RE HERE TO HELP
  ============================================ -->
  <section class="bg-secondary-500 py-10 md:py-14">
    <div class="container-narrow text-center">
      <div class="flex items-center justify-center gap-3 mb-3">
        <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z"/></svg>
        <h2 class="text-white text-2xl md:text-3xl font-bold">Stuck? We're Here to Help</h2>
      </div>

      <p class="text-white/90 text-lg mb-6 max-w-2xl mx-auto">
        Not sure your video is good enough? Can't upload? We can do a <strong class="text-white">live video call</strong> on WhatsApp or FaceTime instead &mdash; it only takes 10 minutes.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center items-center">
        <a href={`tel:${phoneTel}`}
           class="inline-flex items-center justify-center gap-2 bg-white text-secondary-600 hover:bg-gray-100 font-bold px-6 py-3 rounded-lg transition-colors duration-200 no-underline">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
          CALL {phone}
        </a>
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center justify-center gap-2 bg-white/20 hover:bg-white/30 text-white font-bold px-6 py-3 rounded-lg transition-colors duration-200 no-underline border-2 border-white/40">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WHATSAPP US
        </a>
      </div>

      <p class="text-white/50 text-sm mt-4">Mon&ndash;Fri 9am&ndash;5pm &middot; We usually reply within the hour</p>
    </div>
  </section>

  <!-- ============================================
       9 FILMING TIPS (shared component)
  ============================================ -->
  <FilmingTipsGrid
    subtitle="Before You Film"
    heading="9 Areas to Cover"
    description="Haven't filmed yet? Work through each area in order &mdash; open everything, show everything, narrate as you go."
    bgClass="bg-cream"
  />

  <!-- ============================================
       WHAT HAPPENS NEXT
  ============================================ -->
  <section class="section bg-white">
    <div class="container-narrow">
      <h2 class="text-center text-2xl lg:text-3xl mb-10">What Happens After You Send Your Video</h2>

      <div class="space-y-6 max-w-2xl mx-auto">
        <div class="flex items-start gap-5">
          <div class="w-10 h-10 rounded-full bg-primary-600 text-white flex items-center justify-center font-bold shrink-0">1</div>
          <div>
            <h3 class="font-bold text-primary-700 text-lg mb-1">We Watch Everything</h3>
            <p class="text-warm-gray">Your Move Manager personally reviews every clip, noting furniture, volumes, access points, and special items.</p>
          </div>
        </div>

        <div class="flex items-start gap-5">
          <div class="w-10 h-10 rounded-full bg-primary-600 text-white flex items-center justify-center font-bold shrink-0">2</div>
          <div>
            <h3 class="font-bold text-primary-700 text-lg mb-1">We Ask If Anything's Missing</h3>
            <p class="text-warm-gray">We create an itemised list of everything we&rsquo;ve seen and can share it with you to check nothing&rsquo;s been missed. If we spot a gap, we&rsquo;ll ask for clarification &mdash; missed items can mean not enough van space on the day.</p>
          </div>
        </div>

        <div class="flex items-start gap-5">
          <div class="w-10 h-10 rounded-full bg-primary-600 text-white flex items-center justify-center font-bold shrink-0">3</div>
          <div>
            <h3 class="font-bold text-primary-700 text-lg mb-1">You Get Your Quote</h3>
            <p class="text-warm-gray">We'll send you a detailed, written quote &mdash; usually within a few hours during business days. We&rsquo;ll follow up a few days later to answer any questions.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       BOTTOM CTA
  ============================================ -->
  <section class="py-16 bg-gray-900 text-white text-center">
    <div class="container-narrow">
      <h2 class="text-white text-2xl md:text-3xl mb-4">Haven't Filmed Yet?</h2>
      <p class="text-gray-300 text-lg mb-8 max-w-xl mx-auto">
        No problem. Read our step-by-step guide or book a free in-person survey instead.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="/video-self-assessment-guide/" class="btn-cta-orange no-underline">
          VIDEO FILMING GUIDE
        </a>
        <a href="/free-home-survey/" class="btn-cta-outline no-underline">
          BOOK IN-PERSON SURVEY
        </a>
      </div>
    </div>
  </section>

</Layout>
