---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Server error — Painless Removals"
  description="Something went wrong on our end. Please try again or contact us directly."
  noindex
>
  <main class="min-h-[60vh] flex items-center justify-center px-4 py-16">
    <div class="max-w-md mx-auto text-center">
      <div class="text-7xl font-bold text-primary-200 mb-6">500</div>
      <h1 class="text-3xl font-bold text-primary-700 mb-4">Server error</h1>
      <p class="text-lg text-gray-700 mb-8">
        Something went wrong on our end. Please try again, or reach us directly &mdash;
        we'll always answer the phone.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="btn btn-primary">← Back to home</a>
        <a href="tel:01172870082" class="btn btn-secondary">Call 0117 287 0082</a>
      </div>
      <p class="text-sm text-gray-500 mt-8">
        If the problem persists, email <a href="mailto:hello@painlessremovals.com" class="underline">hello@painlessremovals.com</a>.
      </p>
    </div>
  </main>
</Layout>
