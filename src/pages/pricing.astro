---
/**
 * Pricing Page
 *
 * Transparent pricing for Painless Removals Bristol.
 * Leads with costs, explains factors, pushes instant quote + free survey.
 * Primary keyword: removal costs Bristol
 */

import Layout from '@/layouts/Layout.astro';
import OptimizedPicture from '@/components/OptimizedPicture.astro';
import TrustpilotStrip from '@/components/TrustpilotStrip.astro';
import UspBar from '@/components/UspBar.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';
import FinalCTA from '@/components/FinalCTA.astro';
import OvertimeChart from '@/components/OvertimeChart.astro';
import CancellationChart from '@/components/CancellationChart.astro';
import CoverageCard from '@/components/CoverageCard.astro';
import PiggybackMap from '@/components/PiggybackMap.astro';
import PayIn3 from '@/components/PayIn3.astro';
import QuoteTeaser from '@/components/QuoteTeaser.astro';
import { siteConfig } from '@/config/site.config';
import { breadcrumbs } from '@/utils/schema';

const pageTitle = 'Removal Costs Bristol — What Your Move Will Cost';
const pageDescription = 'Transparent removal pricing from Painless Removals Bristol. See what every quote includes, payment options, price examples, and exactly what you\'re paying for. No hidden charges.';

const phone = siteConfig.company.contact.phone;
const phoneTel = phone.replace(/\s/g, '');

// 21 move example cards: 7 property sizes × 3 distances
// Images cycle through available photos
const cardImageNames = [
  'home-removals/Bristol-home-removals-service-1',    // 0
  'home-removals/Bristol-home-removals-service-2',    // 1
  'about/Painless-Removals-van-Bristol',              // 2
  'home-removals/Bristol-home-removals-service-main', // 3
  'home-removals/Bristol-home-removals-valuables',    // 4
  'packing/home-packing-service-main',                // 5
  'homepage/painless-removals-team',                  // 6
  'home-removals/Bristol-furniture-disassembly-service', // 7
  'storage/painless-removals-storage',                // 8
  'concierge/Concierge-service-Painless-Removals',    // 9
  'packing/Tamara-packing',                            // 10
  'home-removals/Bristol-removals-service-3',         // 11
  'home-removals/Bristol-home-removals-service-4',    // 12
  'home-removals/Bristol-home-removals-service-5',    // 13
  'home-removals/Bristol-home-removals-company',      // 14
  'packing/Bristol-home-packing-service',             // 15
  'packing/Bristol-packing-homes',                    // 16
  'packing/Tamara-packing2',                          // 17
  'storage/painless-removals-storage-door',           // 18
  'homepage/painless-removals-Bristol-service',       // 19
  'homepage/home-removals-painless-boxes',            // 20
];
const moveCards = [
  // === LOCAL BRISTOL ===
  { property: 'studio', distance: 'local', label: 'Studio / 1-bed', distLabel: 'Local Bristol', route: 'Bedminster → Southville',       price: '£350–£490',       men: 2,   vans: 1,   duration: 'Half day',     pushesUp: 'Upper floors, no lift, bulky items',             imgIdx: 0 },
  { property: '2bed',   distance: 'local', label: '2-bed',          distLabel: 'Local Bristol', route: 'Bishopston → Redland',          price: '£490–£750',       men: 2,   vans: 1,   duration: 'Half–full day',pushesUp: 'Packing, narrow access, 1st floor+',             imgIdx: 1 },
  { property: '3sm',    distance: 'local', label: '3-bed (small)',   distLabel: 'Local Bristol', route: 'Horfield → Henleaze',           price: '£790–£1,100',     men: 3,   vans: 2,   duration: 'Full day',     pushesUp: 'Full packing, garden furniture',                 imgIdx: 11 },
  { property: '3lg',    distance: 'local', label: '3-bed (large)',   distLabel: 'Local Bristol', route: 'Westbury → Stoke Bishop',       price: '£1,200–£1,550',   men: 4,   vans: 3,   duration: 'Full day',     pushesUp: 'Full packing, stairs, chain delays',             imgIdx: 12 },
  { property: '4bed',   distance: 'local', label: '4-bed',          distLabel: 'Local Bristol', route: 'Clifton → Redland',             price: '£1,500–£1,900',   men: 4,   vans: 3,   duration: 'Full day',     pushesUp: 'Volume, period property access, piano',          imgIdx: 13 },
  { property: '5bed',   distance: 'local', label: '5-bed',          distLabel: 'Local Bristol', route: 'Sneyd Park → Long Ashton',      price: '£1,600–£2,150',   men: 5,   vans: 3,   duration: 'Full day+',    pushesUp: 'Volume, specialist items, storage',              imgIdx: 14 },
  { property: '5plus',  distance: 'local', label: '5+ bed',         distLabel: 'Local Bristol', route: 'Leigh Woods → Abbots Leigh',    price: 'Free survey required',  men: 5,   vans: 3,   duration: 'Multi-day',    pushesUp: 'Volume, outbuildings, multi-day logistics',      imgIdx: 6 },
  // === REGIONAL ===
  { property: 'studio', distance: 'regional', label: 'Studio / 1-bed', distLabel: 'Regional', route: 'Bristol → Bath',                price: '£600–£950',       men: 2,   vans: 1,   duration: 'Full day',     pushesUp: 'Packing, stairs, fragile items',                 imgIdx: 15 },
  { property: '2bed',   distance: 'regional', label: '2-bed',          distLabel: 'Regional', route: 'Bristol → Weston-super-Mare',    price: '£690–£990',       men: 2,   vans: 1,   duration: 'Full day',     pushesUp: 'Access, packing, timing',                        imgIdx: 2 },
  { property: '3sm',    distance: 'regional', label: '3-bed (small)',   distLabel: 'Regional', route: 'Bristol → Gloucester',           price: '£1,000–£1,500',   men: 3,   vans: 2,   duration: 'Full day',     pushesUp: 'Full packing, chain coordination',               imgIdx: 16 },
  { property: '3lg',    distance: 'regional', label: '3-bed (large)',   distLabel: 'Regional', route: 'Henleaze → Bath',               price: '£1,350–£1,800',   men: 4,   vans: 3,   duration: 'Full day',     pushesUp: 'Full packing, stairs, Key Wait Waiver',          imgIdx: 4 },
  { property: '4bed',   distance: 'regional', label: '4-bed',          distLabel: 'Regional', route: 'Bristol → Cardiff',              price: '£1,400–£1,900',   men: 4,   vans: 3,   duration: 'Full day',     pushesUp: 'Volume, furniture assembly, storage',            imgIdx: 7 },
  { property: '5bed',   distance: 'regional', label: '5-bed',          distLabel: 'Regional', route: 'Bristol → Swindon',              price: '£1,750–£2,200',   men: 5,   vans: 3,   duration: 'Full day',     pushesUp: 'Volume, specialist items, 2 collections',       imgIdx: 17 },
  { property: '5plus',  distance: 'regional', label: '5+ bed',         distLabel: 'Regional', route: 'Bristol → Cheltenham',           price: 'Free survey required',  men: 5,   vans: 3,   duration: 'Multi-day',    pushesUp: 'Volume, distance, specialist items',             imgIdx: 18 },
  // === LONG DISTANCE ===
  { property: 'studio', distance: 'long', label: 'Studio / 1-bed', distLabel: 'Long Distance', route: 'Bristol → London',             price: '£750–£1,200',     men: 2,   vans: 1,   duration: 'Full day',     pushesUp: 'London parking, congestion zone, access',        imgIdx: 19 },
  { property: '2bed',   distance: 'long', label: '2-bed',          distLabel: 'Long Distance', route: 'Bristol → Birmingham',         price: '£750–£1,200',     men: 2,   vans: 1,   duration: 'Full day',     pushesUp: 'Packing, access, timing',                        imgIdx: 20 },
  { property: '3sm',    distance: 'long', label: '3-bed (small)',   distLabel: 'Long Distance', route: 'Bristol → Manchester',         price: '£1,400–£2,200',   men: 3,   vans: 2,   duration: '1.5 days',     pushesUp: 'Volume, packing, overnight',                     imgIdx: 5 },
  { property: '3lg',    distance: 'long', label: '3-bed (large)',   distLabel: 'Long Distance', route: 'Bristol → Leeds',              price: '£3,400–£4,300',   men: 4,   vans: 3,   duration: '2 days',       pushesUp: 'Full packing, chain, overnight',                 imgIdx: 3 },
  { property: '4bed',   distance: 'long', label: '4-bed',          distLabel: 'Long Distance', route: 'Bristol → Edinburgh',          price: '£3,900–£5,200',   men: 4,   vans: 3,   duration: '2–3 days',     pushesUp: 'Volume, distance, specialist items',             imgIdx: 9 },
  { property: '5bed',   distance: 'long', label: '5-bed',          distLabel: 'Long Distance', route: 'Bristol → Cornwall',           price: '£3,200–£4,900',   men: 5,   vans: 3,   duration: '2 days',       pushesUp: 'Volume, rural access, specialist items',         imgIdx: 10 },
  { property: '5plus',  distance: 'long', label: '5+ bed',         distLabel: 'Long Distance', route: 'Clifton → London',             price: 'Free survey required',  men: 5,   vans: 3,   duration: '2 days',       pushesUp: 'Volume, London parking, storage',                imgIdx: 8 },
];

// FAQ data
const faqs = [
  {
    question: "Can I get an exact price without a survey?",
    answer: 'You can get a ballpark from our <a href="/instantquote/">instant calculator</a>. For an exact, fixed quote, we need a survey — video (15 mins), in-person (30 mins), or you can send us a walkthrough video yourself. All free, no obligation.',
  },
  {
    question: "Will the price change on moving day?",
    answer: 'The quoted price is the price you pay, within our <a href="/terms-conditions/">terms</a>. The only scenario where costs can increase is if the move runs past 5pm due to circumstances outside your control (like late keys in a chain) — and the Key Wait Waiver removes even that.',
  },
  {
    question: "Can I pay in instalments?",
    answer: "Yes. 30% deposit to book (BACS), then spread the balance across up to 4 payments before moving day. We also accept PayPal Pay in 3 for the balance — split into 3 interest-free payments. Subject to PayPal's eligibility and terms.",
  },
  {
    question: "Why is your quote higher than another company's?",
    answer: 'Check what\'s included. Our quotes cover full-day allocation, all protection materials, a dedicated Move Manager, and transit insurance. Some cheaper quotes exclude packing materials, charge for protection wrapping, or book multiple jobs in one day. Ask any company quoting you: "What happens if my chain delays by 3 hours?"',
  },
  {
    question: "Is it cheaper to move on a weekday?",
    answer: "Weekdays tend to have more availability. End-of-month weekends are busiest. If your date is flexible, your Move Manager can suggest the most available slots.",
  },
  {
    question: "Do you charge for parking permits?",
    answer: "If your move requires a council parking suspension (common in Bath, central Bristol, London), we'll advise you on this during the survey. The council fee varies by area and is your responsibility, but we'll tell you exactly what's needed and help with the application.",
  },
  {
    question: "What's a piggyback removal?",
    answer: 'Because Bristol sits at the M4/M5 junction, our vans regularly travel routes like London to Cornwall or London to Cardiff. If your move falls on one of these corridors, you may benefit from a piggyback rate — our vans are already making the trip. <a href="#piggyback-pricing">Learn more about piggyback pricing</a>.',
  },
  {
    question: "What happens if I'm in a property chain and keys are late?",
    answer: 'For chain moves, we allocate the full day, so we\'re already there. Your dedicated Move Manager stays in contact with your solicitor. If the delay runs past 5pm, overtime charges can apply — but the Key Wait Waiver (a small one-off fee) removes that risk entirely. <a href="#property-chains">Read more about chain moves</a>.',
  },
  {
    question: "Is professional packing worth the extra cost?",
    answer: 'For most people, yes. A full pack for a 3-bed home starts at £580 — less than most expect. The key benefit: everything we pack is covered by our £15,000 transit insurance. Items you self-pack aren\'t covered. <a href="/home-packing-service/">See packing prices</a>.',
  },
  {
    question: "Are prices higher in summer?",
    answer: "We don't have a peak-season surcharge. However, summer months (especially July–August and end-of-month weekends) have the most demand and least availability. Booking 4–6 weeks ahead gives you the widest choice of dates.",
  },
];

// Compare table data (realistic "typical" column)
const compareItems = [
  { feature: 'Full day allocation', painless: 'Always', typical: 'Often not', painlessGood: true, typicalGood: false },
  { feature: 'Mattress protectors', painless: 'Included', typical: 'Usually included', painlessGood: true, typicalGood: true },
  { feature: 'Sofa covers', painless: 'Included', typical: 'Usually included', painlessGood: true, typicalGood: true },
  { feature: 'TV bags', painless: 'Included', typical: 'Rarely offered', painlessGood: true, typicalGood: false },
  { feature: 'Blanket wrapping', painless: 'Included', typical: 'Standard', painlessGood: true, typicalGood: true },
  { feature: 'Dedicated Move Manager', painless: 'Always', typical: 'Rarely', painlessGood: true, typicalGood: false },
  { feature: 'No mileage surprises', painless: 'Quoted upfront', typical: 'Sometimes added on the day', painlessGood: true, typicalGood: false },
  { feature: 'Transit insurance', painless: '£15k per van', typical: 'Varies', painlessGood: true, typicalGood: false },
  { feature: 'Overtime protection', painless: 'Waivable', typical: 'By the minute', painlessGood: true, typicalGood: false },
  { feature: 'Furniture reassembly', painless: 'If quoted', typical: 'Extra charge', painlessGood: true, typicalGood: false },
  { feature: 'Free survey', painless: 'Always', typical: 'Sometimes', painlessGood: true, typicalGood: false },
  { feature: 'Instalment payments', painless: 'Yes', typical: 'Rarely', painlessGood: true, typicalGood: false },
];

// Schema markup
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "House Removals Pricing",
  "description": "Transparent pricing for house removals in Bristol and UK-wide. Includes what's covered, payment options, and insurance details.",
  "provider": {
    "@type": "MovingCompany",
    "name": siteConfig.company.name,
    "@id": `${siteConfig.brand.domain}/#business`,
    "url": siteConfig.brand.domain,
  },
  "areaServed": {
    "@type": "City",
    "name": "Bristol",
  },
  "url": `${siteConfig.brand.domain}/pricing/`,
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "House Removal Pricing",
    "itemListElement": moveCards.filter(c => c.price !== 'Free survey required').map(c => ({
      "@type": "Offer",
      "name": `${c.label} Removal (${c.distLabel})`,
      "priceSpecification": {
        "@type": "PriceSpecification",
        "priceCurrency": "GBP",
        "description": `${c.price} — ${c.men} men, ${c.vans} van${c.vans !== 1 ? 's' : ''}, ${c.duration}`,
      },
    })),
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer.replace(/<[^>]*>/g, ''),
    },
  })),
};

const pageSchema = [serviceSchema, faqSchema, breadcrumbs([
  { name: "Home", path: "/" },
  { name: "Pricing" },
])];

// Cancellation chart tiers
const cancellationTiers = [
  { notice: 'More than 15 working days', pct: 0,   label: '0% — full deposit refund', color: 'green',      targetWidth: '2%'  },
  { notice: '10–15 working days',        pct: 30,  label: '30% of total quote',       color: 'gold',       targetWidth: '30%' },
  { notice: 'Less than 10 working days', pct: 60,  label: '60% of total quote',       color: 'orange',     targetWidth: '60%' },
  { notice: 'Less than 3 working days',  pct: 75,  label: '75% of total quote',       color: 'terracotta', targetWidth: '75%' },
  { notice: 'Less than 24 hours',        pct: 100, label: '100% of total quote',      color: 'red',        targetWidth: '100%'},
];

// Overtime chart slots
const overtimeSlots = [
  { time: '5:00–5:30 pm', blocks: 1 },
  { time: '5:30–6:00 pm', blocks: 2 },
  { time: '6:00–6:30 pm', blocks: 3 },
  { time: '6:30–7:00 pm', blocks: 4 },
];

// Seasonal demand data
const seasonalData = [
  { months: 'Jan–Feb', level: 'Low', pct: 25, color: 'bg-green-500' },
  { months: 'Mar–Apr', level: 'Medium', pct: 50, color: 'bg-amber-400' },
  { months: 'May–Jun', level: 'High', pct: 75, color: 'bg-orange-500' },
  { months: 'Jul–Aug', level: 'Peak', pct: 100, color: 'bg-red-500' },
  { months: 'Sep–Oct', level: 'High', pct: 75, color: 'bg-orange-500' },
  { months: 'Nov–Dec', level: 'Low–Med', pct: 35, color: 'bg-green-500' },
];
---

<Layout title={pageTitle} description={pageDescription} schema={pageSchema} ogImage="/img/pricing/removal-cost-calculator-bristol-1080w.webp" preloadImage="/img/pricing/removal-cost-calculator-bristol-640w.avif">

  <!-- ============================================
       S1: HERO
  ============================================ -->
  <section class="relative lg:grid lg:grid-cols-2 lg:min-h-[calc(100dvh-var(--header-h,104px))]">
    <!-- Mobile: Image at top -->
    <div class="lg:hidden w-full h-[50vh] min-h-[280px] relative overflow-hidden">
      <OptimizedPicture
        name="pricing/removal-cost-calculator-bristol"
        pattern="HALF"
        alt="Choose your home size to get an instant removal cost estimate in Bristol"
        loading="eager"
        fetchpriority="high"
        sizes="100vw"
        class="w-full h-full object-contain"
      />
    </div>

    <!-- Left: Content area -->
    <div class="gradient-hero px-6 py-8 lg:py-10 lg:px-12 xl:px-16 flex flex-col justify-center">
      <div class="max-w-xl mx-auto text-center">
        <p class="text-primary-600 text-sm font-semibold uppercase tracking-wide mb-2">
          Removal Costs Bristol
        </p>

        <h1 class="text-3xl lg:text-4xl xl:text-5xl mb-3 lg:mb-4 font-bold font-heading">
          How Much Does a Removal Cost in <span class="text-secondary-500">Bristol?</span>
        </h1>

        <p class="text-lg lg:text-xl text-warm-gray mb-5 lg:mb-6 leading-relaxed py-[15px]">
          A local Bristol move starts from £400 for a studio and ranges up to £3,500+ for a 5-bed home. Long-distance moves cost more — use the examples below or get your price in 47 seconds.
        </p>

        <div class="flex flex-col gap-2 mb-5 items-center">
          <a href="/instantquote/" class="btn-cta-orange">
            GET YOUR INSTANT QUOTE
          </a>
          <a href={`tel:${phoneTel}`} class="inline-flex items-center gap-2 text-primary-600 font-semibold no-underline hover:text-secondary-500 transition-colors text-lg mt-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Call {phone}
          </a>
        </div>

        <TrustpilotStrip />
      </div>
    </div>

    <!-- Right: Full-bleed image (desktop only) -->
    <div class="hidden lg:block relative overflow-hidden">
      <OptimizedPicture
        name="pricing/removal-cost-calculator-bristol"
        pattern="HALF"
        alt="Choose your home size to get an instant removal cost estimate in Bristol"
        loading="eager"
        fetchpriority="high"
        sizes="50vw"
        class="absolute inset-0 w-full h-full object-contain"
      />
    </div>
  </section>

  <UspBar hideBadge={true} />


  <!-- ============================================
       INSTANT QUOTE TEASER
  ============================================ -->
  <QuoteTeaser headingId="pricing-quote-heading" />


  <!-- ============================================
       S8: PAYMENT OPTIONS + PAYPAL PAY IN 3
  ============================================ -->
  <section class="section bg-white" id="payment-options">
    <div class="container-wide">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-center mb-4">Flexible Payment Options</h2>
        <p class="text-center text-warm-gray text-lg mb-10 max-w-2xl mx-auto">
          Moving is expensive enough. We offer multiple ways to spread the cost so you can focus on settling in.
        </p>

        <!-- PayPal Pay in 3 -->
        <PayIn3 class="mb-10" />

        <!-- Payment calculator -->
        <div class="bg-gray-50 rounded-xl p-6 md:p-8" id="payment-calculator">
          <h3 class="text-xl font-bold mb-2 text-center">What Would I Actually Pay?</h3>
          <p class="text-warm-gray text-sm text-center mb-6">
            Enter your quote amount (or use our example) to see your payment breakdown.
          </p>

          <div class="max-w-md mx-auto">
            <div class="flex gap-3 mb-6">
              <div class="relative flex-1">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-warm-gray font-semibold">£</span>
                <input
                  type="number"
                  id="quote-amount"
                  min="100"
                  max="50000"
                  step="50"
                  placeholder="1500"
                  class="w-full pl-8 pr-4 py-3 border border-gray-300 rounded-lg text-lg font-semibold focus:outline-none focus:ring-2 focus:ring-primary-600 focus:border-primary-600"
                  aria-label="Enter your quote amount"
                />
              </div>
              <button
                id="calc-payment-btn"
                class="btn-cta-orange !py-3 !px-5 whitespace-nowrap !text-sm"
              >Show my payments</button>
            </div>

            <!-- Results -->
            <div id="payment-result" class="hidden">
              <div class="space-y-3">
                <div class="flex justify-between items-center py-2 border-b border-gray-200">
                  <span class="text-warm-gray">Your quote</span>
                  <span class="font-bold text-lg" id="res-total"></span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200">
                  <span class="text-warm-gray" id="res-deposit-label">Deposit (30%)</span>
                  <span class="font-semibold" id="res-deposit"></span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-200">
                  <span class="text-warm-gray">Balance</span>
                  <span class="font-semibold" id="res-balance"></span>
                </div>
                <div class="mt-4 bg-white rounded-lg p-4 border border-gray-200">
                  <p class="text-sm font-semibold mb-3">Pay the balance via:</p>
                  <div class="space-y-2">
                    <div class="flex justify-between text-sm">
                      <span class="text-warm-gray">BACS (full balance)</span>
                      <span class="font-medium" id="res-bacs"></span>
                    </div>
                    <div class="flex justify-between text-sm">
                      <span class="text-warm-gray">4 instalments (BACS)</span>
                      <span class="font-medium" id="res-instalments"></span>
                    </div>
                    <div class="flex justify-between text-sm">
                      <span class="text-warm-gray flex items-center gap-1">
                        <svg viewBox="0 0 100 32" class="h-4 w-auto inline" aria-hidden="true"><path fill="#003087" d="M12.237 2.8L4.437 2.8C3.937 2.8 3.437 3.2 3.337 3.7L0.237 23.7C0.137 24.1 0.437 24.4 0.837 24.4L4.537 24.4C5.037 24.4 5.537 24 5.637 23.5L6.437 18.1C6.537 17.6 6.937 17.2 7.537 17.2L10.037 17.2C15.137 17.2 18.137 14.7 18.937 9.8C19.237 7.7 18.937 6 17.937 4.8C16.837 3.5 14.837 2.8 12.237 2.8Z"/><path fill="#0070E0" d="M35.437 10L31.737 10C31.437 10 31.137 10.2 31.137 10.5L30.937 11.5 30.637 11.1C29.837 9.9 28.037 9.5 26.237 9.5 22.137 9.5 18.637 12.6 17.937 17 17.537 19.2 18.037 21.3 19.337 22.7 20.437 24 22.137 24.6 24.037 24.6 27.337 24.6 29.237 22.5 29.237 22.5L29.037 23.5C28.937 23.9 29.237 24.3 29.637 24.3L33.037 24.3C33.537 24.3 34.037 23.9 34.137 23.4L36.037 10.6C36.137 10.4 35.837 10 35.437 10Z"/></svg>
                        Pay in 3
                      </span>
                      <span class="font-medium" id="res-paypal"></span>
                    </div>
                    <p class="text-xs text-warm-gray mt-2" id="res-paypal-note"></p>
                  </div>
                </div>
              </div>
            </div>

            <div id="payment-default" class="text-center text-sm text-warm-gray">
              Don't have a quote yet? <a href="/instantquote/" class="soft-cta !text-sm">Get your instant quote</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================
