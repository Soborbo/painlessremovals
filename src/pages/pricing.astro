  <!-- ============================================
       JAVASCRIPT: All interactive modules
  ============================================ -->
  <script>
    // ───────────────────────────────────────────
    // M2: Payment Calculator
    // ───────────────────────────────────────────
    (function () {
      const input = document.getElementById('quote-amount') as HTMLInputElement | null;
      const btn = document.getElementById('calc-payment-btn');
      const resultDiv = document.getElementById('payment-result');
      const defaultDiv = document.getElementById('payment-default');

      if (!input || !btn || !resultDiv || !defaultDiv) return;

      function calculate() {
        const amount = parseFloat(input!.value);

        if (!amount || amount < 100) {
          resultDiv!.classList.add('hidden');
          defaultDiv!.classList.remove('hidden');
          return;
        }

        let deposit = Math.round(amount * 0.3);
        let balance = amount - deposit;

        // PayPal Pay in 3 max is £3,000 — increase deposit if needed
        if (balance > 3000) {
          deposit = amount - 3000;
          balance = 3000;
        }

        const depositPct = Math.round((deposit / amount) * 100);
        const instalment = Math.round(balance / 4);
        const paypal = Math.round((balance / 3) * 100) / 100;

        (document.getElementById('res-total') as HTMLElement).textContent = `£${amount.toLocaleString()}`;
        (document.getElementById('res-deposit-label') as HTMLElement).textContent = `Deposit (${depositPct}%)`;
        (document.getElementById('res-deposit') as HTMLElement).textContent = `£${deposit.toLocaleString()}`;
        (document.getElementById('res-balance') as HTMLElement).textContent = `£${balance.toLocaleString()}`;
        (document.getElementById('res-bacs') as HTMLElement).textContent = `£${balance.toLocaleString()} before move day`;
        (document.getElementById('res-instalments') as HTMLElement).textContent = `4 × £${instalment.toLocaleString()}`;

        const paypalEl = document.getElementById('res-paypal') as HTMLElement;
        const paypalNote = document.getElementById('res-paypal-note') as HTMLElement;

        if (balance > 3000) {
          paypalEl.textContent = 'N/A for full balance';
          paypalNote.textContent = `Balance exceeds PayPal Pay in 3 limit (£3,000). You can use PayPal for part of the balance — ask your Move Manager.`;
        } else {
          paypalEl.textContent = `3 × £${paypal.toFixed(2)}`;
          paypalNote.textContent = 'Subject to PayPal eligibility. 0% interest.';
        }

        resultDiv!.classList.remove('hidden');
        defaultDiv!.classList.add('hidden');
      }

      btn.addEventListener('click', calculate);
      input.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter') { e.preventDefault(); calculate(); }
      });

      // Show default £1,500 example on load
      input.value = '1500';
      calculate();
    })();


    // ───────────────────────────────────────────
    // M4: Move Selector (7 sizes × 3 distances = 21 cards)
    // ───────────────────────────────────────────
    (function () {
      const cards = document.querySelectorAll<HTMLElement>('.move-card');
      const btns = document.querySelectorAll<HTMLButtonElement>('.move-filter-btn');

      if (!cards.length || !btns.length) return;

      let selectedProperty: string | null = null;
      let selectedDistance: string | null = 'local'; // Default: Local Bristol

      const grid = document.getElementById('move-cards');

      function updateCards() {
        let visible = 0;
        cards.forEach(c => {
          const match = c.getAttribute('data-match') || '';
          const [cardProp, cardDist] = match.split('-');
          const propMatch = !selectedProperty || cardProp === selectedProperty;
          const distMatch = !selectedDistance || cardDist === selectedDistance;

          if (propMatch && distMatch) {
            c.style.display = '';
            c.style.opacity = '1';
            c.style.transform = selectedProperty ? 'translateY(-4px)' : '';
            c.style.boxShadow = selectedProperty ? '0 8px 25px rgba(0,0,0,0.12)' : '';
            visible++;
          } else {
            c.style.display = 'none';
          }
        });

        // Center single card at readable width
        if (grid) {
          if (visible === 1) {
            grid.style.gridTemplateColumns = '1fr 1fr 1fr';
            cards.forEach(c => {
              if (c.style.display !== 'none') c.style.gridColumn = '2';
            });
          } else {
            grid.style.gridTemplateColumns = '';
            cards.forEach(c => { c.style.gridColumn = ''; });
          }
        }
      }

      // Apply default filter on load
      updateCards();

      btns.forEach(btn => {
        btn.addEventListener('click', () => {
          const prop = btn.getAttribute('data-property');
          const dist = btn.getAttribute('data-distance');

          if (prop) {
            // Toggle: clicking same button deselects
            if (selectedProperty === prop) {
              selectedProperty = null;
              btn.classList.remove('bg-primary-600', 'text-white', 'border-primary-600');
              btn.classList.add('border-gray-200');
            } else {
              selectedProperty = prop;
              // Reset sibling buttons
              btns.forEach(b => {
                if (b.getAttribute('data-property')) {
                  b.classList.remove('bg-primary-600', 'text-white', 'border-primary-600');
                  b.classList.add('border-gray-200');
                }
              });
              btn.classList.add('bg-primary-600', 'text-white', 'border-primary-600');
              btn.classList.remove('border-gray-200');
            }
          }

          if (dist) {
            // Distance tabs: always one active, no toggle-off
            if (selectedDistance === dist) return;
            selectedDistance = dist;
            btns.forEach(b => {
              if (b.getAttribute('data-distance')) {
                b.classList.remove('bg-primary-600', 'text-white', 'border-primary-600');
                b.classList.add('border-gray-200');
              }
            });
            btn.classList.add('bg-primary-600', 'text-white', 'border-primary-600');
            btn.classList.remove('border-gray-200');
          }

          updateCards();
        });
      });
    })();


    // ───────────────────────────────────────────
    // M5: Seasonal Chart Animation
    // ───────────────────────────────────────────
    (function () {
      const chart = document.getElementById('seasonal-chart');
      if (!chart) return;

      const bars = chart.querySelectorAll<HTMLElement>('.seasonal-bar');

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              bars.forEach((bar, i) => {
                setTimeout(() => {
                  bar.style.transition = 'width 0.8s cubic-bezier(0.4, 0, 0.2, 1)';
                  bar.style.width = bar.dataset.width + '%';
                }, i * 120);
              });
              observer.disconnect();
            }
          });
        },
        { threshold: 0.3 }
      );
      observer.observe(chart);
    })();




    // ───────────────────────────────────────────
    // M7: Question Form
    // ───────────────────────────────────────────
    (function () {
      const form = document.getElementById('pricing-question-form') as HTMLFormElement | null;
      const thanks = document.getElementById('q-thanks');

      if (!form || !thanks) return;

      form.addEventListener('submit', (e: Event) => {
        e.preventDefault();
        form.classList.add('hidden');
        thanks.classList.remove('hidden');
      });
    })();
  </script>

</Layout>
