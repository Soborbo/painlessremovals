---
/**
 * House Clearance Guide — Support Article
 *
 * Informational guide targeting "house clearance bristol" queries.
 * Covers when you need a clearance, what can/can't be cleared,
 * how it works, costs, eco-friendly disposal, and FAQs.
 * Links to /house-and-waste-clearance/ service page and /contact/.
 */

import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config/site.config';
import FAQAccordion from '@/components/FAQAccordion.astro';
import FinalCTA from '@/components/FinalCTA.astro';

// Page metadata
const pageTitle = 'House Clearance Guide — What to Expect, Costs & Tips';
const pageDescription = 'Everything you need to know about house clearance in Bristol. When you need one, what can and can\'t be cleared, how it works, typical costs, and eco-friendly disposal. Free advice from Painless Removals.';

// When you need a clearance
const clearanceReasons = [
  {
    title: 'Probate & Bereavement',
    description: 'Clearing a loved one\'s home after they\'ve passed away is one of the most emotionally demanding tasks a family faces. A professional clearance service handles the heavy lifting and logistics so you can focus on what matters. We work at your pace, with care and discretion.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>`,
  },
  {
    title: 'Downsizing',
    description: 'Moving from a larger home to a smaller one means deciding what stays and what goes. A clearance service removes the items you no longer have room for and ensures they\'re donated, recycled, or disposed of responsibly rather than ending up in a skip.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
  },
  {
    title: 'Tenant Clear-Out',
    description: 'When a tenant vacates and leaves belongings behind, landlords need the property cleared quickly and thoroughly so it can be re-let or refurbished. We handle everything from furniture removal to waste disposal, leaving the property empty and ready for the next step.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>`,
  },
  {
    title: 'Hoarding Situations',
    description: 'Properties affected by hoarding require a patient, non-judgemental approach. Our team works methodically through the property, sorting items carefully and treating the occupant with compassion throughout. We\'ve handled many of these clearances and understand the sensitivity involved.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>`,
  },
  {
    title: 'Pre-Sale Preparation',
    description: 'Selling a property that\'s still full of furniture and belongings? A clearance before viewings begin can make a significant difference to how the property shows. Empty rooms look larger, cleaner, and more appealing to buyers. Estate agents consistently recommend clearing before listing.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
];

// What can and can't be cleared
const canClear = [
  'Furniture (sofas, beds, wardrobes, tables, chairs, desks)',
  'White goods (washing machines, fridges, freezers, dishwashers)',
  'Clothing, shoes, and textiles',
  'Books, magazines, and paperwork',
  'Kitchenware, crockery, and utensils',
  'Garden furniture, tools, and sheds',
  'Carpets, rugs, and curtains',
  'Electronics (TVs, computers, small appliances)',
  'General household bric-a-brac and ornaments',
  'Mattresses, duvets, and bedding',
];

const cantClear = [
  'Asbestos or asbestos-containing materials',
  'Clinical or medical waste (needles, syringes)',
  'Explosive materials (fireworks, ammunition)',
  'Tyres (these require specialist disposal)',
  'Large quantities of soil or rubble (skip hire is more suitable)',
  'Radioactive materials',
  'Liquid chemical waste in bulk containers',
  'Vehicle batteries in large quantities',
];

// How it works steps
const howItWorksSteps = [
  {
    number: 1,
    title: 'Free Survey & Quote',
    description: 'We visit the property or arrange a video walkthrough to assess the scope of the clearance. You\'ll receive a clear, written quote with no hidden fees. For probate clearances, we can work with solicitors and executors directly.',
  },
  {
    number: 2,
    title: 'Agree a Date',
    description: 'Once you\'re happy with the quote, we agree a date that works for you. For urgent clearances, we can often attend within a few days. For probate situations, we work around your timeline &ndash; there\'s no pressure to rush.',
  },
  {
    number: 3,
    title: 'Clearance Day',
    description: 'Our team arrives on the agreed date with the right vehicles and equipment. We work systematically through the property, room by room. You\'re welcome to be present or you can hand us the keys and we\'ll get on with it.',
  },
  {
    number: 4,
    title: 'Sorting & Disposal',
    description: 'Every item is sorted into categories: items for charity donation, items for recycling, and genuine waste for responsible disposal. We don\'t just throw everything in a skip &ndash; we take the time to do it properly.',
  },
  {
    number: 5,
    title: 'Completion & Handover',
    description: 'The property is left clean, empty, and ready for its next chapter &ndash; whether that\'s going on the market, being re-let, or handed back to a landlord. We sweep through every room before we leave.',
  },
];

// FAQs
const faqs = [
  {
    question: 'How much does a house clearance in Bristol typically cost?',
    answer: 'The cost depends on the size of the property, the volume of items, and any access challenges. As a rough guide, a single room clearance in Bristol starts from around &pound;400, while a full 3-bedroom house clearance typically ranges from &pound;800 to &pound;1,500. Properties with loft and garage contents, or those requiring hazardous waste disposal, may cost more. We always provide a fixed quote after surveying the property &ndash; no surprises on the day.',
  },
  {
    question: 'How long does a house clearance take?',
    answer: 'Most standard house clearances are completed within a single day. A one-bedroom flat might take 2 to 3 hours, a 3-bedroom house typically takes 4 to 6 hours, and larger or heavily-filled properties may require a full day or occasionally two. We\'ll give you an accurate time estimate when we provide your quote.',
  },
  {
    question: 'Do you handle probate clearances?',
    answer: 'Yes, and we understand the sensitivity involved. We work with families, solicitors, and executors to clear properties as part of the probate process. Our team is experienced in handling these situations with care and discretion. If there are specific items you want to keep or have valued, we can set those aside before the clearance begins.',
  },
  {
    question: 'What happens to items that are still in good condition?',
    answer: 'We sort through everything carefully. Items in good, usable condition are donated to local charities across Bristol &ndash; we have established relationships with several organisations. Furniture, clothing, books, and household goods all find new homes wherever possible. We can provide donation receipts if needed for probate records.',
  },
  {
    question: 'Can you clear a property if I can\'t be there?',
    answer: 'Absolutely. Many of our clients &ndash; particularly those managing probate clearances from a distance &ndash; simply send us the keys. We can collect them beforehand or arrange key safe access. We photograph the property before and after the clearance so you can see exactly what was done.',
  },
  {
    question: 'Do you handle hazardous materials during a clearance?',
    answer: 'We can handle common household hazardous items including paint, cleaning chemicals, batteries, and small electrical items. These are taken to approved disposal facilities rather than landfill. For asbestos or clinical waste, you\'ll need a specialist contractor &ndash; we can recommend trusted companies in the Bristol area if needed.',
  },
  {
    question: 'Is there anything I should do before the clearance team arrives?',
    answer: 'If there are specific items you want to keep, please remove them or clearly mark them before we arrive. For probate clearances, it\'s worth going through the property first to check for important documents, jewellery, photographs, or sentimental items. Beyond that, we handle everything &ndash; you don\'t need to sort, bag, or prepare anything.',
  },
  {
    question: 'Can you combine a house clearance with a house move?',
    answer: 'Yes &ndash; this is actually quite common. If you\'re downsizing, clearing a family home, or preparing a property for sale while also moving, we can handle both the clearance and the removal as a single coordinated operation. This saves time, reduces cost, and means you only deal with one company. See our <a href="/house-and-waste-clearance/" class="text-secondary-500 underline decoration-secondary-300 underline-offset-2 hover:text-secondary-700">house clearance service page</a> for full details.',
  },
];

// Schema: Article
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "House Clearance Guide — What to Expect, Costs & Tips",
  "description": pageDescription,
  "url": `${siteConfig.brand.domain}/clearance-guide/`,
  "datePublished": "2026-02-14",
  "dateModified": "2026-02-14",
  "author": {
    "@type": "Person",
    "@id": `${siteConfig.brand.domain}/about/jay-newton/#person`,
    "name": siteConfig.company.director.name,
    "jobTitle": siteConfig.company.director.title,
  },
  "publisher": {
    "@type": "MovingCompany",
    "@id": `${siteConfig.brand.domain}/#business`,
    "name": siteConfig.company.name,
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteConfig.brand.domain}/clearance-guide/`,
  },
  "image": `${siteConfig.brand.domain}/images/og-default.png`,
};

// Schema: FAQPage
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer.replace(/<[^>]*>/g, '').replace(/&ndash;/g, '–').replace(/&mdash;/g, '—').replace(/&pound;/g, '£').replace(/&ldquo;/g, '"').replace(/&rdquo;/g, '"'),
    },
  })),
};

// Schema: BreadcrumbList
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteConfig.brand.domain,
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Moving Advice",
      "item": `${siteConfig.brand.domain}/moving-advice/`,
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Clearance Guide",
      "item": `${siteConfig.brand.domain}/clearance-guide/`,
    },
  ],
};

// Combined schema array
const pageSchema = [articleSchema, faqSchema, breadcrumbSchema];
---

<Layout title={pageTitle} description={pageDescription} schema={pageSchema}>

  <!-- ============================================
       BREADCRUMBS
  ============================================ -->
  <div class="bg-white border-b border-gray-100">
    <div class="container-wide py-3">
      <nav class="text-sm text-warm-gray" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="text-primary-600 hover:text-primary-700 no-underline">Home</a></li>
          <li class="text-warm-gray/50">/</li>
          <li><a href="/moving-advice/" class="text-primary-600 hover:text-primary-700 no-underline">Moving Advice</a></li>
          <li class="text-warm-gray/50">/</li>
          <li class="text-warm-gray">Clearance Guide</li>
        </ol>
      </nav>
    </div>
  </div>

  <!-- ============================================
       SECTION 1: HERO
  ============================================ -->
  <section class="section bg-cream">
    <div class="container-narrow text-center">
      <p class="text-primary-600 text-sm font-semibold uppercase tracking-wide mb-3">
        House Clearance Advice &middot; Bristol &amp; South West
      </p>

      <h1 class="text-3xl lg:text-4xl xl:text-5xl mb-4 font-bold">
        House Clearance Guide
      </h1>

      <p class="text-lg lg:text-xl text-warm-gray leading-relaxed max-w-3xl mx-auto mb-6">
        Whether you&rsquo;re dealing with probate, downsizing, preparing a property for sale, or simply facing a home that&rsquo;s accumulated decades of belongings, a house clearance can feel overwhelming. This guide explains everything you need to know &ndash; from what to expect and what it costs, to how items are sorted, donated, and responsibly disposed of. We&rsquo;ve been helping families across Bristol with clearances since 1978, and this is the honest advice we&rsquo;d give to a friend.
      </p>

      <div class="flex flex-wrap justify-center gap-4 text-sm text-warm-gray">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          Written by Jay Newton, Director
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          Updated February 2026
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          10 minute read
        </span>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECTION 2: WHEN YOU NEED A CLEARANCE
  ============================================ -->
  <section class="section bg-white">
    <div class="container-wide">
      <h2 class="text-center mb-4">When You Might Need a House Clearance</h2>
      <p class="text-center text-warm-gray text-lg mb-12 max-w-2xl mx-auto">
        House clearances aren&rsquo;t just for extreme situations. Here are the most common reasons people in Bristol call us for help.
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {clearanceReasons.map((reason) => (
          <div class="bg-cream rounded-lg p-6 hover:shadow-md transition-shadow duration-300">
            <div class="text-primary-600 mb-4" set:html={reason.icon} />
            <h3 class="text-lg font-bold text-primary-600 mb-2">{reason.title}</h3>
            <p class="text-warm-gray text-sm leading-relaxed">{reason.description}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 bg-primary-50 rounded-lg p-6 border-l-4 border-primary-500 max-w-3xl mx-auto">
        <p class="text-warm-gray leading-relaxed">
          <strong class="text-primary-600">A note on bereavement clearances:</strong> We understand that clearing a loved one&rsquo;s home is about far more than removing objects. Many of these belongings carry memories and meaning. Our team works with sensitivity and patience &ndash; we never rush a probate clearance, and we&rsquo;re happy to set aside items you want to keep, have valued, or pass to family members. If you need extra time, that&rsquo;s absolutely fine.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECTION 3: WHAT CAN AND CAN'T BE CLEARED
  ============================================ -->
  <section class="section bg-cream">
    <div class="container-wide">
      <h2 class="text-center mb-4">What Can and Can&rsquo;t Be Cleared</h2>
      <p class="text-center text-warm-gray text-lg mb-12 max-w-2xl mx-auto">
        A professional clearance service handles the vast majority of household items. Here&rsquo;s what we can and can&rsquo;t take.
      </p>

      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- We CAN clear -->
        <div class="bg-white rounded-lg p-6 shadow-sm border-t-4 border-green-500">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-green-100 text-green-600 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <h3 class="text-lg font-bold text-green-700">We Can Clear</h3>
          </div>
          <ul class="space-y-3">
            {canClear.map((item) => (
              <li class="flex items-start gap-2 text-warm-gray text-sm">
                <span class="text-green-500 mt-0.5 shrink-0">&#10003;</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- We CAN'T take -->
        <div class="bg-white rounded-lg p-6 shadow-sm border-t-4 border-red-500">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-red-100 text-red-600 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </div>
            <h3 class="text-lg font-bold text-red-700">We Can&rsquo;t Take</h3>
          </div>
          <ul class="space-y-3">
            {cantClear.map((item) => (
              <li class="flex items-start gap-2 text-warm-gray text-sm">
                <span class="text-red-500 mt-0.5 shrink-0">&#10007;</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <p class="text-xs text-warm-gray mt-4 pt-4 border-t border-gray-100">
            For items we can&rsquo;t handle, we can recommend specialist disposal companies in the Bristol area. Just ask.
          </p>
        </div>
      </div>

      <div class="mt-8 text-center">
        <p class="text-warm-gray text-sm">
          Unsure about a specific item? Call us on
          <a href={`tel:${siteConfig.company.contact.phone.replace(/\s/g, '')}`} class="text-secondary-500 underline decoration-secondary-300 underline-offset-2 hover:text-secondary-700">{siteConfig.company.contact.phone}</a>
          and we&rsquo;ll let you know straightaway.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECTION 4: HOW IT WORKS
  ============================================ -->
  <section class="section bg-white" id="how-it-works">
    <div class="container-wide">
      <h2 class="text-center mb-4">How a House Clearance Works</h2>
      <p class="text-center text-warm-gray text-lg mb-12 max-w-2xl mx-auto">
        From first contact to completion, here&rsquo;s what the process looks like when you book a clearance with Painless Removals.
      </p>

      <div class="max-w-3xl mx-auto space-y-6">
        {howItWorksSteps.map((step) => (
          <div class="flex items-start gap-5 group">
            <div class="w-12 h-12 bg-primary-600 text-white rounded-full flex items-center justify-center text-xl font-bold shrink-0 transition-all duration-300 group-hover:scale-110 group-hover:shadow-lg group-hover:bg-primary-700">
              {step.number}
            </div>
            <div class="pt-1">
              <h3 class="text-lg font-bold text-primary-600 mb-1 transition-colors duration-300 group-hover:text-secondary-500">{step.title}</h3>
              <p class="text-warm-gray leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/house-and-waste-clearance/" class="btn-cta-orange">
          VIEW OUR CLEARANCE SERVICE
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECTION 5: COSTS OVERVIEW
  ============================================ -->
  <section class="section bg-cream" id="costs">
    <div class="container-wide">
      <h2 class="text-center mb-4">House Clearance Costs in Bristol</h2>
      <p class="text-center text-warm-gray text-lg mb-12 max-w-2xl mx-auto">
        Pricing varies depending on the size of the property, the volume of items, and any special requirements. Here&rsquo;s a general guide to help you budget.
      </p>

      <div class="max-w-3xl mx-auto">
        <!-- Pricing table -->
        <div class="bg-white rounded-lg shadow-sm overflow-hidden">
          <table class="w-full">
            <thead>
              <tr class="bg-primary-600 text-white">
                <th class="text-left py-4 px-6 font-semibold">Property / Item</th>
                <th class="text-right py-4 px-6 font-semibold">Typical Cost</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-3 px-6 text-warm-gray">Single item collection (sofa, mattress, appliance)</td>
                <td class="py-3 px-6 text-right font-semibold text-primary-600">From &pound;40</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-3 px-6 text-warm-gray">Single room clearance</td>
                <td class="py-3 px-6 text-right font-semibold text-primary-600">From &pound;400</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-3 px-6 text-warm-gray">1&ndash;2 bedroom flat clearance</td>
                <td class="py-3 px-6 text-right font-semibold text-primary-600">&pound;500 &ndash; &pound;900</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-3 px-6 text-warm-gray">3 bedroom house clearance</td>
                <td class="py-3 px-6 text-right font-semibold text-primary-600">&pound;800 &ndash; &pound;1,500</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-3 px-6 text-warm-gray">4+ bedroom house clearance</td>
                <td class="py-3 px-6 text-right font-semibold text-primary-600">&pound;1,200 &ndash; &pound;2,500+</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-3 px-6 text-warm-gray">Garden and outbuilding clearance (add-on)</td>
                <td class="py-3 px-6 text-right font-semibold text-primary-600">From &pound;200</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="mt-6 space-y-4">
          <div class="bg-white rounded-lg p-5 shadow-sm border-l-4 border-secondary-500">
            <h3 class="font-bold text-primary-600 mb-2">What affects the price?</h3>
            <ul class="space-y-2 text-warm-gray text-sm">
              <li class="flex items-start gap-2">
                <span class="text-secondary-500 mt-0.5 shrink-0 font-bold">&bull;</span>
                <span><strong>Volume of items</strong> &ndash; A home packed floor-to-ceiling costs more than one with a few rooms of furniture</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-secondary-500 mt-0.5 shrink-0 font-bold">&bull;</span>
                <span><strong>Access difficulty</strong> &ndash; Narrow staircases, upstairs flats without lifts, or limited parking all add time</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-secondary-500 mt-0.5 shrink-0 font-bold">&bull;</span>
                <span><strong>Hazardous materials</strong> &ndash; Paint, chemicals, and electrical items require special handling</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-secondary-500 mt-0.5 shrink-0 font-bold">&bull;</span>
                <span><strong>Location</strong> &ndash; Properties in central Bristol or further afield may have travel-related costs</span>
