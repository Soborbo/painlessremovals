<!-- Office Steps Styles -->
<style>
  .office-steps__container {
    width: 100%;
  }

  /* Horizontal scroll on mobile */
  .office-steps__scroll-track {
    overflow-x: auto;
    overflow-y: visible;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 1rem;
  }
  .office-steps__scroll-track::-webkit-scrollbar {
    display: none;
  }

  /* Flex layout — single row */
  .office-steps__grid {
    display: flex;
    align-items: stretch;
    gap: 0;
    padding: 0 1rem;
  }

  /* Connector arrow */
  .office-steps__connector {
    display: flex;
    align-items: center;
    align-self: center;
    justify-content: center;
    color: #3b6587;
    opacity: 0.35;
    flex-shrink: 0;
    width: 28px;
  }
  .office-steps__connector svg {
    width: 24px;
    height: auto;
  }

  /* Card */
  .office-steps__card {
    position: relative;
    background: white;
    border-radius: 16px;
    padding: 1.5rem 1.25rem 1.25rem;
    box-shadow: 0 1px 4px rgb(0 0 0 / 0.05);
    border: 1px solid rgb(0 0 0 / 0.04);
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    width: 72vw;
    max-width: 280px;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .office-steps__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 32px rgb(0 0 0 / 0.1);
  }

  /* Icon / number badge */
  .office-steps__icon-wrap {
    position: relative;
    width: 48px;
    height: 48px;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, rgb(59 101 135 / 0.1), rgb(59 101 135 / 0.04));
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
                background 0.4s ease;
  }
  .group:hover .office-steps__icon-wrap {
    transform: scale(1.1);
    background: linear-gradient(135deg, rgb(59 101 135 / 0.18), rgb(59 101 135 / 0.08));
  }

  .office-steps__badge {
    width: 28px;
    height: 28px;
    background: #006eb7;
    color: white;
    border-radius: 50%;
    font-size: 0.85rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Typography */
  .office-steps__title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
    color: #31536e;
  }
  .office-steps__desc {
    font-size: 0.85rem;
    line-height: 1.6;
    color: #6B6B6B;
    margin: 0;
    flex: 1;
  }

  /* Desktop: all 5 cards in one row, no scroll */
  @media (min-width: 1350px) {
    .office-steps__scroll-track {
      overflow: visible;
    }
    .office-steps__grid {
      justify-content: center;
      padding: 0 2rem;
    }
    .office-steps__card {
      width: auto;
      max-width: none;
      flex: 1;
      min-width: 0;
    }
    .office-steps__connector {
      width: 36px;
    }
    .office-steps__connector svg {
      width: 28px;
    }
    .office-steps__icon-wrap {
      width: 56px;
      height: 56px;
    }
    .office-steps__badge {
      width: 32px;
      height: 32px;
      font-size: 0.95rem;
    }
    .office-steps__title {
      font-size: 1.15rem;
    }
    .office-steps__desc {
      font-size: 0.9rem;
    }
    .office-steps__card {
      padding: 1.75rem 1.5rem 1.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .office-steps__card { transition: none; }
    .office-review { transition: none; }
    .group:hover .office-review__shine { animation: none; }
  }

  /* ── Review card microinteraction ── */
  .office-review {
    overflow: hidden;
  }
  .office-review__shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 40%, rgb(255 255 255 / 0.6) 50%, transparent 60%);
    opacity: 0;
    pointer-events: none;
    border-radius: 16px;
  }
  .group:hover .office-review__shine {
    opacity: 1;
    animation: review-shine 0.8s ease-out;
  }
  @keyframes review-shine {
    from { transform: translateX(-100%); }
    to { transform: translateX(100%); }
  }
</style>

<!-- YouTube Facade Script -->
<script>
  const facade = document.getElementById('yt-facade');
  if (facade) {
    facade.addEventListener('click', () => {
      const videoId = facade.dataset.videoId;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0&hl=en&cc_lang_pref=en`;
      iframe.title = 'Painless Removals office move service';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';
      facade.innerHTML = '';
      facade.style.position = 'relative';
      facade.appendChild(iframe);
    });
  }
</script>
