          </h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            {faqs
              .filter(faq => faq.category === cat.id)
              .map((faq) => (
                <details
                  class={`group bg-white rounded-lg border border-l-4 ${cat.border} ${cat.accent} shadow-sm overflow-hidden transition-all duration-300 hover:shadow-md self-start`}
