<style>
  /* Sticky nav responsive top offset */
  @media (min-width: 768px) {
    #faq-nav {
      top: 64px !important; /* tablet: taller header, no services nav */
    }
  }
  @media (min-width: 1024px) {
    #faq-nav {
      top: calc(64px + 40px) !important; /* desktop: header + services nav */
    }
  }

  /* Smooth scroll for anchor links */
  html {
    scroll-behavior: smooth;
  }

  /* Nav pills — colourful on hover and active only */
  .faq-nav-pill:hover {
    background-color: var(--pill-bg);
    color: var(--pill-text);
    border-color: var(--pill-bg);
  }

  .faq-nav-pill.active {
    background-color: var(--pill-bg);
    color: var(--pill-text);
    border-color: var(--pill-bg);
    font-weight: 700;
  }

  /* FAQ answer animation */
  .faq-page-answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    padding-top: 0;
    padding-bottom: 0;
    border-top-width: 0;
  }
  details[open] > .faq-page-answer {
    grid-template-rows: 1fr;
    padding-top: 0;
    padding-bottom: 1.25rem;
    border-top-width: 1px;
  }
  .faq-page-answer > div {
    overflow: hidden;
    min-height: 0;
  }
  details[open] .faq-page-chevron {
    transform: rotate(180deg);
  }
</style>

<script is:inline>
  // Highlight active category in sticky nav based on scroll position
  // Auto-scroll the nav so the active pill is centered
  (function() {
    var navContainer = document.querySelector('#faq-nav .overflow-x-auto');
    var pills = document.querySelectorAll('.faq-nav-pill');
    var sections = [];
    pills.forEach(function(pill) {
      var id = pill.getAttribute('href').replace('#', '');
      var section = document.getElementById(id);
      if (section) sections.push({ id: id, el: section, pill: pill });
    });

    var lastActiveId = null;
    var ticking = false;

    function scrollPillIntoView(pill) {
      if (!navContainer || !pill) return;
      var containerRect = navContainer.getBoundingClientRect();
      var pillRect = pill.getBoundingClientRect();
      var scrollLeft = navContainer.scrollLeft;
      var targetScroll = scrollLeft + pillRect.left - containerRect.left - (containerRect.width / 2) + (pillRect.width / 2);
      navContainer.scrollTo({ left: targetScroll, behavior: 'smooth' });
    }

    function updateActive() {
      var scrollY = window.scrollY + 100;
      var active = sections[0];
      for (var i = 0; i < sections.length; i++) {
        if (sections[i].el.offsetTop <= scrollY) {
          active = sections[i];
        }
      }
      pills.forEach(function(p) { p.classList.remove('active'); });
      if (active) {
        active.pill.classList.add('active');
        if (active.id !== lastActiveId) {
          lastActiveId = active.id;
          scrollPillIntoView(active.pill);
        }
      }
      ticking = false;
    }

    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(updateActive);
        ticking = true;
      }
    }, { passive: true });

    // Ensure nav starts scrolled to the left and first pill is active on load
    if (navContainer) navContainer.scrollLeft = 0;
    setTimeout(updateActive, 50);
  })();

  // FAQ page details animation — prevent two-step open/close
  (function() {
    document.querySelectorAll('.faq-page-answer').forEach(function(wrap) {
      var det = wrap.closest('details');
      if (!det) return;
      var summary = det.querySelector('summary');
      if (!summary) return;

      summary.addEventListener('click', function(e) {
        e.preventDefault();
        if (det.hasAttribute('open')) {
          wrap.style.gridTemplateRows = '0fr';
          function onEnd() {
            wrap.removeEventListener('transitionend', onEnd);
            det.removeAttribute('open');
            wrap.style.gridTemplateRows = '';
          }
          wrap.addEventListener('transitionend', onEnd);
          setTimeout(function() { if (det.hasAttribute('open')) { det.removeAttribute('open'); wrap.style.gridTemplateRows = ''; } }, 400);
        } else {
          wrap.style.gridTemplateRows = '0fr';
          det.setAttribute('open', '');
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              wrap.style.gridTemplateRows = '1fr';
              function onOpenEnd() {
                wrap.removeEventListener('transitionend', onOpenEnd);
                wrap.style.gridTemplateRows = '';
              }
              wrap.addEventListener('transitionend', onOpenEnd);
            });
          });
        }
      });
    });
  })();
</script>
