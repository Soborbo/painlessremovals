<!-- Interactive Checklist Script -->
<script>
  const STORAGE_KEY = 'painless-checklist-v1';

  function loadState(): Record<string, boolean> {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      return raw ? JSON.parse(raw) : {};
    } catch {
      return {};
    }
  }

  function saveState(state: Record<string, boolean>) {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    } catch {
      // Storage full or unavailable — silently fail
    }
  }

  function itemKey(phase: number, item: number): string {
    return `${phase}-${item}`;
  }

  function updateProgress() {
    const phases = document.querySelectorAll('.checklist-phase');
    phases.forEach((phaseEl) => {
      const phaseIdx = phaseEl.getAttribute('data-phase');
      const checkboxes = phaseEl.querySelectorAll<HTMLInputElement>('.checklist-checkbox');
      const total = checkboxes.length;
      const checked = Array.from(checkboxes).filter(cb => cb.checked).length;

      // Update counter badge
      const badge = document.querySelector(`.phase-progress[data-phase="${phaseIdx}"]`);
      if (badge) {
        badge.textContent = `${checked}/${total}`;
        if (checked === total && total > 0) {
          badge.classList.remove('bg-gray-100', 'text-warm-gray');
          badge.classList.add('bg-green-100', 'text-green-700');
        } else {
          badge.classList.remove('bg-green-100', 'text-green-700');
          badge.classList.add('bg-gray-100', 'text-warm-gray');
        }
      }

      // Update progress bar
      const bar = document.querySelector(`.phase-bar[data-phase="${phaseIdx}"]`) as HTMLElement;
      if (bar) {
        const pct = total > 0 ? (checked / total) * 100 : 0;
        bar.style.width = `${pct}%`;
      }
    });
  }

  function applyStrikethrough(checkbox: HTMLInputElement) {
    const label = checkbox.closest('.checklist-item')?.querySelector('.checklist-label');
    if (label) {
      if (checkbox.checked) {
        label.classList.add('line-through', 'opacity-50');
      } else {
        label.classList.remove('line-through', 'opacity-50');
      }
    }
  }

  // Initialise from localStorage
  const state = loadState();
  const allCheckboxes = document.querySelectorAll<HTMLInputElement>('.checklist-checkbox');

  allCheckboxes.forEach((cb) => {
    const phase = Number(cb.getAttribute('data-phase'));
    const item = Number(cb.getAttribute('data-item'));
    const key = itemKey(phase, item);

    if (state[key]) {
      cb.checked = true;
      applyStrikethrough(cb);
    }

    cb.addEventListener('change', () => {
      const currentState = loadState();
      if (cb.checked) {
        currentState[key] = true;
      } else {
        delete currentState[key];
      }
      saveState(currentState);
      applyStrikethrough(cb);
      updateProgress();
    });
  });

  updateProgress();

  // Reset All button
  document.getElementById('reset-checklist')?.addEventListener('click', () => {
    if (confirm('Reset all checked items? This cannot be undone.')) {
      localStorage.removeItem(STORAGE_KEY);
      allCheckboxes.forEach((cb) => {
        cb.checked = false;
        applyStrikethrough(cb);
      });
      updateProgress();
    }
  });

  // Print button
  document.getElementById('print-checklist')?.addEventListener('click', () => {
    // Open all details before printing
    const allDetails = document.querySelectorAll<HTMLDetailsElement>('.checklist-phase');
    const originalStates = Array.from(allDetails).map(d => d.open);
    allDetails.forEach(d => d.open = true);

    window.print();

    // Restore original states after print dialog closes
    setTimeout(() => {
      allDetails.forEach((d, i) => d.open = originalStates[i]);
    }, 500);
  });
</script>

<!-- Print Styles -->
<style is:global>
  @media print {
    /* Show all phases expanded */
    .checklist-phase { display: block !important; }
    .checklist-phase[open] > div { display: block !important; }

    /* Hide non-essential elements */
    header,
    .gradient-hero,
    footer,
    nav[aria-label="Breadcrumb"],
    #reset-checklist,
    #print-checklist,
    .phase-bar { display: none !important; }

    /* Clean checkbox styling for print */
    .checklist-checkbox {
      -webkit-appearance: auto;
      appearance: auto;
      width: 14px !important;
      height: 14px !important;
    }

    /* Remove strikethrough for print — show full text */
    .checklist-label {
      text-decoration: none !important;
      opacity: 1 !important;
    }
  }
</style>

