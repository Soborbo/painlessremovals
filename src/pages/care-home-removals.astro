        <span>Speak to us today</span>
        <span class="kf-banner-cta-num">{PHONE_DISPLAY}</span>
      </a>
    </section>

  </main>

  <!-- Cloudflare Turnstile -->
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <!-- Form submission -->
  <script is:inline>
    (function () {
      var form = document.getElementById('kf-form');
      if (!form) return;

      var PHONE = (form.dataset.phone || '0117 287 0082');
      var errorEl = document.getElementById('kf-form-error');
      var submitBtn = document.getElementById('kf-submit');
      var successEl = document.getElementById('kf-form-success');

      function showError(msg) {
        errorEl.textContent = msg;
        errorEl.hidden = false;
        if (window.showToast) window.showToast(msg, 'error');
      }

      function clearError() {
        errorEl.hidden = true;
        errorEl.textContent = '';
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        clearError();

        var contactName = form.querySelector('#kf-name').value.trim();
        var orgName = form.querySelector('#kf-org').value.trim();
        var contactPhone = form.querySelector('#kf-phone').value.trim();
        var contactEmail = form.querySelector('#kf-email').value.trim();
        var messageVal = form.querySelector('#kf-message').value.trim();
        var gdprConsent = form.querySelector('#kf-consent').checked;
        var honeypot = form.querySelector('#kf-website').value;

        if (!contactName) { showError('Please enter your name.'); return; }
        if (!orgName) { showError('Please tell us the name of your home or organisation.'); return; }
        if (!contactPhone) { showError('Please enter a phone number we can reach you on.'); return; }
        if (!contactEmail) { showError('Please enter your email address.'); return; }
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(contactEmail)) { showError('That email address doesn\'t look right — please double-check it.'); return; }
        if (!gdprConsent) { showError('Please tick the consent box so we know you\'re happy for us to be in touch.'); return; }

        var turnstileToken = '';
        var tsInput = form.querySelector('[name="cf-turnstile-response"]');
        if (tsInput) turnstileToken = tsInput.value;
        if (!turnstileToken) { showError('Please complete the security check before submitting.'); return; }

        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending…';

        // Compose a single message body for the contact endpoint, since the
        // generic /api/contact/ doesn't take a separate "organisation" field.
        var combinedMessage = 'Care home walkthrough request.\nOrganisation: ' + orgName +
          (messageVal ? ('\n\n' + messageVal) : '');

        fetch('/api/contact/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: contactName,
            phone: contactPhone,
            email: contactEmail,
            message: combinedMessage,
            honeypot: honeypot,
            turnstileToken: turnstileToken,
            source: 'care-home-removals',
          }),
        })
          .then(function (res) {
            return res.json().catch(function () { throw new Error('Server returned ' + res.status); });
          })
          .then(function (data) {
            if (data && data.success) {
              var eventId = (window.crypto && window.crypto.randomUUID)
                ? window.crypto.randomUUID()
                : ('id-' + Date.now() + '-' + Math.random().toString(36).slice(2));
              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push({
                event: 'form_submission',
                event_id: eventId,
                form_name: 'care_home_walkthrough',
                form_source: 'care-home-removals',
              });

              form.hidden = true;
              successEl.hidden = false;
              successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
            } else {
              showError((data && data.error) || ('Something went wrong. Please try again or call us on ' + PHONE + '.'));
              submitBtn.disabled = false;
              submitBtn.textContent = 'Book my walk-through';
              if (window.turnstile) window.turnstile.reset();
            }
          })
          .catch(function () {
            showError('Connection error — please check your internet and try again, or call us on ' + PHONE + '.');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Book my walk-through';
          });
      });
    })();
  </script>

</Layout>

