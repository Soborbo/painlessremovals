    </section>

    <!-- ============================================================
         FINAL BANNER
    ============================================================ -->
    <section class="kf-banner">
      <div class="kf-banner-diamond" aria-hidden="true"></div>
      <h3 class="kf-banner-h3">Painless for the resident. <em>Painless for the home.</em></h3>
