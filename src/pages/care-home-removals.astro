---
/**
 * Care Home & Supported Living Removals — sector landing page.
 *
 * Sendable to managers and operators of assisted living, care homes,
 * nursing homes, housing-association supported-living schemes.
 *
 * Visual template mirrors the agent-referral / Knight Frank design
 * language (kf-* class system) — premium petrol-blue + gold serif
 * aesthetic, tier cards, callback form. Content for the care sector:
 * "we know when bingo is", free walkthrough, our-own-storage operator
 * benefit, admin tail support. Deliberately avoids any claim of
 * specialist clinical training (dementia / autism / mental health) —
 * we say "experience working in care environments" and "calm,
 * respectful, structured approach" only.
 */

import Layout from '@/layouts/Layout.astro';
import OptimizedPicture from '@/components/OptimizedPicture.astro';
import { siteConfig } from '@/config/site.config';
import { service, faqPage, breadcrumbs, areas } from '@/utils/schema';

const pageTitle = 'Care Home & Supported Living Removals Bristol | Painless Removals';
const pageDescription = 'A removals service for Bristol’s care homes, nursing homes, and housing-association schemes. Free site walkthrough, hand-picked crews, our own storage, and a single point of contact who answers the phone.';

const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const PHONE_DISPLAY = siteConfig.company.contact.phone;
const PHONE_TEL = PHONE_DISPLAY.replace(/\s/g, '');

// Hero / og:image — JPG fallback for broadest social-platform compatibility (FB/LinkedIn/X all parse JPG cleanly).
const heroImagePath = '/img/later-life/Bristol-care-home-community-2560w.jpg';
const heroImageUrl = `${siteConfig.brand.domain}${heroImagePath}`;
const heroImageCaption = 'Older residents in the dining room of a Bristol care home — Painless Removals helps clients move into and between care homes, nursing homes, and supported-living schemes.';

const faqs = [
  {
    question: 'How quickly can you start working with our home?',
    answer: 'For a single resident, often within a few days of the walkthrough. For larger pieces of work — a wing decant, a refurbishment, or a scheme-wide programme — we recommend a few weeks of lead time. The walkthrough itself is free and we can usually do it within the week.',
  },
  {
    question: 'Do your crews have DBS checks?',
    answer: 'Yes. Anyone we send into a regulated environment has been vetted and briefed on the home, the resident and the day before they arrive.',
  },
  {
    question: 'How do you handle moves for residents who need a calmer pace?',
    answer: 'With more time, more preparation, a smaller, quieter crew. We take our cue from the family or care team — written timelines in advance, a smaller working space, the people who know the resident driving the pace.',
  },
  {
    question: 'Can you take items into storage?',
    answer: 'Yes. We run our own storage — not self-storage. The family does not have to find a unit and you get the room back faster.',
  },
];

const heroImageSchema = {
  "@context": "https://schema.org",
  "@type": "ImageObject",
  "@id": `${siteConfig.brand.domain}/care-home-removals/#hero-image`,
  "url": heroImageUrl,
  "contentUrl": heroImageUrl,
  "width": 5168,
  "height": 3420,
  "encodingFormat": "image/jpeg",
  "name": "Painless Removals — Care Home & Supported Living Removals in Bristol",
  "caption": heroImageCaption,
  "description": heroImageCaption,
  "representativeOfPage": true,
};

const pageSchema = [
  service({
    name: 'Care Home & Supported Living Removals Bristol',
    description: pageDescription,
    serviceType: 'Care Home Removals',
    url: '/care-home-removals/',
    areaServed: areas.bristol,
    image: heroImagePath,
  }),
  heroImageSchema,
  faqPage(faqs),
  breadcrumbs([
    { name: 'Home', path: '/' },
    { name: 'Care Home & Supported Living Removals' },
  ]),
];
---

<Layout title={pageTitle} description={pageDescription} schema={pageSchema} ogImage={heroImagePath}>

  <main class="kf">

    <!-- ============================================================
         HERO
    ============================================================ -->
    <section class="kf-hero">
      <div class="kf-hero-image" aria-hidden="true">
        <OptimizedPicture
          name="later-life/Bristol-care-home-community"
          pattern="HALF"
          alt={heroImageCaption}
          loading="eager"
          fetchpriority="high"
          class="kf-hero-image-img"
        />
      </div>
      <div class="kf-hero-inner">
        <div class="kf-hero-copy">
          <div class="kf-eyebrow">For Care Homes &amp; Supported Living</div>
          <h1 class="kf-h1">
            We know<br />
            <em>When bingo is</em><span class="kf-period">.</span>
          </h1>
          <div class="kf-hero-kicker">Bristol-Based &middot; Free Walkthrough &middot; Hand-Picked Crews</div>
          <p class="kf-hero-lead">
            Before the removal, we walk the building so we know what to
            expect: where the lift is, when programmes run, when we&rsquo;d
            disturb least.
            <em>That&rsquo;s what makes our moves genuinely painless for everyone.</em>
          </p>

          <div class="kf-hero-cta">
            <a href="#callback" class="kf-btn kf-btn-orange">Book a free walk-through</a>
            <a href={`tel:${PHONE_TEL}`} class="kf-btn-text">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              Or call {PHONE_DISPLAY}
            </a>
          </div>

          <div class="kf-hero-stats">
            <div class="kf-stat">
              <span class="kf-stat-num">1978</span>
              <span class="kf-stat-label">Established</span>
            </div>
            <div class="kf-stat-divider"></div>
            <div class="kf-stat">
              <span class="kf-stat-num">2,000+</span>
              <span class="kf-stat-label">Moves led by Jay personally</span>
            </div>
            <div class="kf-stat-divider"></div>
            <div class="kf-stat">
              <span class="kf-stat-num">{siteConfig.company.rating.value}{'★'}</span>
              <span class="kf-stat-label">{siteConfig.company.rating.count} Google reviews</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         TRUST STRIP
    ============================================================ -->
    <section class="kf-trust">
      <div class="kf-trust-inner">
        <div class="kf-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <div>
            <div class="kf-trust-title">DBS-Checked Crews</div>
            <div class="kf-trust-text">Vetted, uniformed, briefed before they arrive</div>
          </div>
        </div>
        <div class="kf-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 2 3 5v6c0 5 3.8 9.4 9 11 5.2-1.6 9-6 9-11V5l-9-3z"/><path d="m9 12 2 2 4-4"/></svg>
          <div>
            <div class="kf-trust-title">Fully Insured</div>
            <div class="kf-trust-text">{'£'}15k per van &middot; Move Assured accredited</div>
          </div>
        </div>
        <div class="kf-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M8 10h8M8 14h6"/><path d="m15 17 2 2 4-4"/></svg>
          <div>
            <div class="kf-trust-title">One Phone, Always Answered</div>
            <div class="kf-trust-text">A single named contact, start to finish</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         INTRODUCTION — Jay portrait + the framing piece
    ============================================================ -->
    <section class="kf-section kf-intro">
      <div class="kf-wide kf-intro-grid">
        <figure class="kf-intro-portrait">
          <OptimizedPicture
            name="about/team/Jay"
            pattern="HALF"
            alt="Jay Newton, Director, Painless Removals"
            loading="lazy"
            class="kf-intro-portrait-img"
          />
          <figcaption>
            <strong>Jay Newton</strong>
            <span>Director &middot; Painless Removals</span>
          </figcaption>
        </figure>

        <div class="kf-intro-copy">
          <div class="kf-eyebrow">The free walkthrough</div>
          <h2 class="kf-h2">
            We learn the <em>rhythm of the home</em>.
          </h2>
          <p class="kf-intro-p">
            On a free walkthrough we walk the building with your team. Yes, we look at lift access,
            corridor widths and floor surfaces &mdash; the basics. But we also learn the rhythm of
            the home: when meals are served, when the activity room is busy, when residents tend to
            nap, where the route from the lift to the room passes the lounge, and at what time of
            day that lounge is full.
          </p>
          <p class="kf-intro-p">
            That&rsquo;s how a move stops being a disturbance. The point isn&rsquo;t just to get
            furniture from A to B without a scratch &mdash; it&rsquo;s to do it without unsettling
            the people who live in the building. <em>That&rsquo;s a different brief, and it&rsquo;s
            the one we work to.</em>
          </p>
        </div>
      </div>
    </section>

    <!-- ============================================================
         THREE TIERS
    ============================================================ -->
    <section class="kf-section kf-tiers-section">
      <div class="kf-wide">
        <div class="kf-section-head">
          <div>
            <div class="kf-eyebrow">Three Levels of Service</div>
            <h2 class="kf-h2">The right level of care<br />for <em>every care home move.</em></h2>
          </div>
          <div class="kf-section-head-note">
            Every package includes a dedicated Move Manager, a fixed quote on survey,
            and full protection of the property at both ends.
          </div>
        </div>

        <div class="kf-tiers">

          <!-- Tier 1: Painless Removal -->
          <article class="kf-tier">
            <div class="kf-tier-image">
              <OptimizedPicture
                name="home-removals/Bristol-home-removals-service-2"
                pattern="THIRD"
                alt="Painless Removals crew loading a home removals van in Bristol"
                loading="lazy"
                class="kf-tier-image-img"
              />
            </div>
            <div class="kf-tier-body">
              <div class="kf-tier-label">Level One</div>
              <h3 class="kf-tier-h3">Painless <em>Removal</em></h3>
              <p class="kf-tier-lead">
                The resident&rsquo;s belongings are packed by family or staff. We handle everything from the room onward, properly, carefully, on time.
              </p>
              <ul class="kf-tier-list">
                <li>Dedicated Move Manager &amp; trusted in-house crew</li>
                <li>Loading, transport &amp; unloading by our own team</li>
                <li>Furniture disassembly &amp; reassembly included</li>
                <li>Sofa covers, mattress protectors, picture &amp; TV bags as standard</li>
                <li>{'£'}15,000 Goods-in-Transit cover per van</li>
              </ul>
              <div class="kf-tier-foot">
                <strong>Ideal for</strong>
                A move where the family or care team is comfortable packing personal items and just needs an experienced, uniformed crew on the day.
              </div>
            </div>
          </article>

          <!-- Tier 2: Painless Packing (featured) -->
          <article class="kf-tier kf-tier-featured">
            <div class="kf-tier-ribbon">Most Requested</div>
            <div class="kf-tier-image">
              <OptimizedPicture
                name="packing/home-packing-service"
                pattern="THIRD"
                alt="Painless Removals professional packing service for a care home move"
                loading="lazy"
                class="kf-tier-image-img"
              />
            </div>
            <div class="kf-tier-body">
              <div class="kf-tier-label">Level Two</div>
              <h3 class="kf-tier-h3">Painless <em>Packing</em></h3>
              <p class="kf-tier-lead">
                We pack, we move, we unpack. The resident arrives to a familiar, ordered room, not a stack of boxes for someone else to deal with.
              </p>
              <ul class="kf-tier-list">
                <li>Everything in Painless Removal</li>
                <li>Full professional packing: fragile, wardrobe, kitchen, personal items</li>
                <li>Specialist handling for photos, frames, ornaments &amp; keepsakes</li>
                <li>Unpack &amp; placement at the new address</li>
                <li>Packed items covered under transit insurance</li>
              </ul>
              <div class="kf-tier-foot">
                <strong>Ideal for</strong>
                Family at distance, busy care teams, or when the resident needs a gentler, slower transition without the stress of packing.
              </div>
            </div>
          </article>

          <!-- Tier 3: Painless Concierge -->
          <article class="kf-tier">
            <div class="kf-tier-image">
              <OptimizedPicture
                name="concierge/Concierge-service-Painless-Removals"
                pattern="THIRD"
                alt="Painless Removals concierge service coordinating a care home move"
                loading="lazy"
                class="kf-tier-image-img"
              />
            </div>
            <div class="kf-tier-body">
              <div class="kf-tier-label">Level Three</div>
              <h3 class="kf-tier-h3">Painless <em>Concierge</em></h3>
              <p class="kf-tier-lead">
                Our full white-glove service with a concierge built in. The family or care team only has to walk the resident through the door.
              </p>
              <ul class="kf-tier-list">
                <li>Everything in Painless Packing</li>
                <li>Concierge: address changes, post redirection &amp; supplier handover</li>
                <li>Utilities, broadband and deliveries coordinated for the new address</li>
                <li>Storage in our own warehouse for items that don&rsquo;t fit yet</li>
                <li>Single named contact across family, care team and any third parties</li>
              </ul>
              <div class="kf-tier-foot">
                <strong>Ideal for</strong>
                Families coordinating from another part of the country, complex personal effects, or moves where the admin tail would otherwise fall on the home.
              </div>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- ============================================================
         BAND — calm, respectful, structured approach
    ============================================================ -->
    <section class="kf-specialist">
      <div class="kf-specialist-inner">
        <div>
          <div class="kf-band-label">For the resident, not just the room</div>
          <h3 class="kf-specialist-h3">A <em>calm, respectful, structured</em> approach.</h3>
        </div>
        <div>
          <p class="kf-specialist-p">
            Moving is one of the most stressful things a person can go through &mdash; for an older resident, that stress is amplified. We&rsquo;ve worked in care environments for years, so we&rsquo;ve learned to take our cue from the people who know the resident best. Written timelines agreed in advance, a smaller, quieter crew, leaving the familiar room intact until the last possible moment, setting the new space up first so it already feels lived-in when the resident arrives.
          </p>
        </div>
      </div>
    </section>

    <!-- ============================================================
         WHY (testimonials) + HOW (steps)
    ============================================================ -->
    <section class="kf-bottom-grid">

      <div class="kf-why">
        <h2 class="kf-h2">What they <em>say</em><br />about working with us.</h2>
        <div class="kf-gold-hair"></div>

        <blockquote class="kf-quote">
          <p>"I'm disabled as I had a stroke last year so I decided to get movers for my move and they were absolutely great. <mark>They literally did everything, packed my whole flat</mark> and were lovely guys! I just sat on the sofa and did some work while they packed away my whole flat. Really great movers, lovely people, cannot recommend enough."</p>
          <footer class="kf-quote-foot">
            <span class="kf-quote-photo kf-quote-photo-mono" aria-hidden="true">★</span>
            <cite>Jeremy Vize &middot; Google review</cite>
          </footer>
        </blockquote>

        <blockquote class="kf-quote">
          <p>"We went for the full packing and removal package when we moved. <mark>The whole process was painless</mark> from start to finish and the team was exceptionally friendly, efficient, and helpful from start to finish. Would strongly recommend their service to anyone."</p>
          <footer class="kf-quote-foot">
            <img src="/images/reviews/caspian-johnson.avif" alt="Caspian Johnson" class="kf-quote-photo" width="36" height="36" loading="lazy" />
            <cite>Caspian Johnson &middot; Trustpilot review</cite>
          </footer>
        </blockquote>

        <blockquote class="kf-quote">
          <p>"Painless Removals have been brilliant, couldn't recommend them more. They helped us move in Bristol and then helped us organise a cross-country move. Both were done on a tight timeline and at a good price. The guys who moved us were <mark>very kind and efficient</mark> &mdash; Thanks again!"</p>
          <footer class="kf-quote-foot">
            <img src="/images/reviews/laura-carnegie-brown.avif" alt="Laura Carnegie-Brown" class="kf-quote-photo" width="36" height="36" loading="lazy" />
            <cite>Laura Carnegie-Brown &middot; Google review</cite>
          </footer>
        </blockquote>

        <div class="kf-reviews-badge">
          <div class="kf-stars">{'★★★★★'}</div>
          <div>
            <div class="kf-score">{siteConfig.company.rating.value} / 5</div>
            <div class="kf-score-meta">{siteConfig.company.rating.count} verified Google reviews</div>
          </div>
        </div>
      </div>

      <div class="kf-how">
        <div class="kf-how-head">
          <h2 class="kf-h2">How we make it <em>painless</em><br />for everyone.</h2>
          <div class="kf-gold-hair"></div>
        </div>

        <div class="kf-steps">
          <div class="kf-step">
            <div class="kf-step-num">1</div>
            <div class="kf-step-title">Walk-Through</div>
            <p>We visit the care home or facility, and we visit the resident at their current address too. Free, no pressure. We meet your team, learn the building and the day.</p>
          </div>
          <div class="kf-step">
            <div class="kf-step-num">2</div>
            <div class="kf-step-title">Plan Together</div>
            <p>We walk through the timing, the route, and the layout at the other end with the resident or family. Briefed crew before they arrive.</p>
          </div>
          <div class="kf-step">
            <div class="kf-step-num">3</div>
            <div class="kf-step-title">The Move</div>
            <p>Calm, quiet, careful. Floors and door frames protected. The resident is never rushed.</p>
          </div>
          <div class="kf-step">
            <div class="kf-step-num">4</div>
            <div class="kf-step-title">Finish Properly</div>
            <p>We don&rsquo;t leave until everything is where it should be. Admin tail handled where needed: post, utilities, address changes, storage collected, the room ready to hand back.</p>
          </div>
        </div>

        <div class="kf-jay">
          <div class="kf-jay-avatar">
            <OptimizedPicture
              name="about/team/Jay-Newton"
              pattern="ICON"
              alt="Jay Newton, Director, Painless Removals"
              loading="lazy"
              class="kf-jay-avatar-img"
            />
          </div>
          <div class="kf-jay-body">
            <div class="kf-jay-mark">"</div>
            <p>You&rsquo;re letting people into someone&rsquo;s home. That&rsquo;s a bigger trust than carrying a sofa. That&rsquo;s what we hire for &mdash; the lifting, we can teach.</p>
            <cite>Jay Newton &mdash; Director, Painless Removals</cite>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         OPERATOR BENEFITS BAND — storage + admin
    ============================================================ -->
    <section class="kf-section kf-benefits-section">
      <div class="kf-wide">
        <div class="kf-section-head kf-section-head--center">
          <div>
            <div class="kf-eyebrow kf-eyebrow-center-style">For the home, as well as the resident</div>
            <h2 class="kf-h2 kf-h2-center">We take the risk and stress <em>off your desk.</em></h2>
          </div>
        </div>

        <div class="kf-benefits-grid">
          <article class="kf-benefit">
            <div class="kf-benefit-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3" y="7" width="18" height="13" rx="1"/><path d="M3 11h18"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            </div>
            <h3 class="kf-benefit-h3">Our Own Storage &mdash; Not Self-Storage</h3>
            <p>The family doesn&rsquo;t need to find a unit, sign a contract or arrange a haul. We collect, transport and store &mdash; one team, one chain of custody. Your room comes back into circulation as soon as the resident has moved, not when the family is ready to decide.</p>
          </article>

          <article class="kf-benefit">
            <div class="kf-benefit-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M3 5a2 2 0 0 1 2-2h3.28a1 1 0 0 1 .948.684l1.498 4.493a1 1 0 0 1-.502 1.21l-2.257 1.13a11.042 11.042 0 0 0 5.516 5.516l1.13-2.257a1 1 0 0 1 1.21-.502l4.493 1.498a1 1 0 0 1 .684.949V19a2 2 0 0 1-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <h3 class="kf-benefit-h3">A Phone That Always Gets Answered</h3>
            <p>One named contact, one number. If something needs adjusting in the moment, we adjust. You shouldn&rsquo;t have to project-manage your removals firm &mdash; not while you have a building to run.</p>
          </article>

          <article class="kf-benefit">
            <div class="kf-benefit-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M9 13h6M9 17h4"/></svg>
            </div>
            <h3 class="kf-benefit-h3">The Admin Tail, Handled</h3>
            <p>Post redirection, telephone disconnection, broadband, utilities, council tax, GP, bank, pension. We work the checklist with the family &mdash; or instead of them. For an older resident the list is overwhelming; for us it&rsquo;s a checklist we&rsquo;ve done hundreds of times.</p>
          </article>

          <article class="kf-benefit">
            <div class="kf-benefit-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><path d="m17 11 2 2 4-4"/></svg>
            </div>
            <h3 class="kf-benefit-h3">Crews Chosen for Character</h3>
            <p>Calm, quiet voices in shared corridors. Politeness as the default, with residents and with your team. Not just lifters &mdash; the kind of people you&rsquo;d be happy to introduce to a resident in their own room.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ============================================================
         CALLBACK FORM
    ============================================================ -->
    <section class="kf-callback" id="callback">
      <div class="kf-narrow">
        <div class="kf-callback-card">
          <div class="kf-callback-head">
            <div class="kf-eyebrow">Book a free walk-through</div>
            <h2 class="kf-h2">Tell us about your home.<br /><em>We&rsquo;ll come and listen.</em></h2>
            <p class="kf-callback-lead">
              Free, friendly, no obligation. We come to you, meet your team, and learn the building.
              Then we plan around it &mdash; not the other way around.
              Mon&ndash;Fri 9am&ndash;5pm; weekends on request.
            </p>
          </div>

          <!-- Success state (hidden by default) -->
          <div id="kf-form-success" class="kf-form-success" hidden>
            <div class="kf-success-mark">{'✓'}</div>
            <h3 class="kf-h3">Thank you &mdash; we have your details.</h3>
            <p>We&rsquo;ll be in touch within one working day to arrange a walk-through. If it&rsquo;s urgent, please call <a href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a>.</p>
          </div>

          <form id="kf-form" class="kf-form" novalidate data-phone={PHONE_DISPLAY}>
            <!-- Honeypot -->
            <div class="kf-honeypot" aria-hidden="true">
              <label for="kf-website">Leave this blank</label>
              <input type="text" id="kf-website" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <div class="kf-field">
              <label for="kf-name">Your name <span class="kf-req">*</span></label>
              <input type="text" id="kf-name" name="contactName" required autocomplete="name" placeholder="e.g. Sarah Mitchell" />
            </div>

            <div class="kf-field">
              <label for="kf-org">Home or organisation <span class="kf-req">*</span></label>
              <input type="text" id="kf-org" name="orgName" required autocomplete="organization" placeholder="e.g. Stoke Lodge Care Home" />
            </div>

            <div class="kf-field-row">
              <div class="kf-field">
                <label for="kf-phone">Phone <span class="kf-req">*</span></label>
                <input type="tel" id="kf-phone" name="contactPhone" required autocomplete="tel" placeholder="07… or 0117…" />
              </div>
              <div class="kf-field">
                <label for="kf-email">Email <span class="kf-req">*</span></label>
                <input type="email" id="kf-email" name="contactEmail" required autocomplete="email" placeholder="you@example.com" />
              </div>
            </div>

            <div class="kf-field">
              <label for="kf-message">Anything we should know? <span class="kf-optional">(optional)</span></label>
