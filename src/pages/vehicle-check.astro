---
/**
 * Daily Vehicle Inspection Form
 *
 * Internal page for van drivers to complete before each shift.
 * noindex — not for public/search engines.
 * Sends multipart FormData (supports image uploads).
 */

import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config/site.config';

const pageTitle = 'Daily Vehicle Inspection';
const pageDescription = 'Internal daily vehicle check form for Painless Removals drivers.';

const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;

// Van fleet
const vans = [
  { value: 'W554 AOH', label: 'W554 AOH — "Green Goddess"' },
  { value: 'VA16 VKH', label: 'VA16 VKH — Renault Master' },
  { value: 'CN19 TJO', label: 'CN19 TJO — Citroën Relay' },
  { value: 'CF19 GBY', label: 'CF19 GBY — Citroën Relay' },
  { value: 'WN71 EVY', label: 'WN71 EVY — Ford Transit' },
  { value: 'HG21 KDK', label: 'HG21 KDK — "Little Van"' },
];

// Fluids checklist items
const fluidItems = [
  'Water levels',
  'Oil levels',
  'Tyre pressure',
  'Lights',
  'AdBlue',
];

// Condition checklist items
const conditionItems = [
  'Cabin is tidy',
  'Back is swept',
  'Blankets are folded',
  'Straps are stowed',
];

// Schema: WebPage
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": pageTitle,
  "description": pageDescription,
  "url": `${siteConfig.brand.domain}/vehicle-check/`,
};
---

<Layout title={pageTitle} description={pageDescription} schema={pageSchema} noindex={true}>

  <section class="section bg-cream">
    <div class="container-narrow">

      <!-- Heading -->
      <div class="text-center mb-10">
        <h1 class="text-3xl lg:text-4xl font-bold mb-3">Daily Vehicle Inspection</h1>
        <p class="text-warm-gray text-lg">Complete this form before each shift</p>
      </div>

      <!-- Form -->
      <form id="vehicle-check-form" class="space-y-8 bg-white rounded-xl p-6 sm:p-8 shadow-sm border border-gray-100" novalidate>

        <!-- Honeypot – hidden from humans, bots fill it -->
        <div style="position: absolute; left: -9999px;" aria-hidden="true">
          <label for="website">Leave this blank</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <!-- 1. Employee Name -->
        <div>
          <label for="name" class="block text-sm font-semibold text-primary-600 mb-1.5">Your Name <span class="text-secondary-500">*</span></label>
          <input type="text" id="name" name="name" required autocomplete="name" placeholder="Please enter your name here"
            class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" />
        </div>

        <!-- 2. Van Selection (radio cards) -->
        <fieldset>
          <legend class="block text-sm font-semibold text-primary-600 mb-3">Select Van <span class="text-secondary-500">*</span></legend>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {vans.map((van) => (
              <label class="van-card relative flex items-center gap-3 p-4 border-2 border-gray-200 rounded-lg cursor-pointer hover:border-primary-400 transition-colors has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
                <input type="radio" name="van" value={van.value} required
                  class="w-4 h-4 text-primary-600 border-gray-300 focus:ring-primary-500" />
                <span class="text-sm font-medium text-primary-600">{van.label}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <!-- 3. Fluids Checklist -->
        <fieldset>
          <legend class="block text-sm font-semibold text-primary-600 mb-1.5">Fluids &amp; Safety <span class="text-secondary-500">*</span></legend>
          <p class="text-warm-gray text-sm mb-3">I declare all below are in working order:</p>
          <div class="space-y-2.5">
            {fluidItems.map((item) => (
              <label class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors cursor-pointer">
                <input type="checkbox" name="fluids" value={item}
                  class="w-4 h-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500" />
                <span class="text-sm text-gray-700">{item}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <!-- 4. Condition Checklist -->
        <fieldset>
          <legend class="block text-sm font-semibold text-primary-600 mb-1.5">Vehicle Condition <span class="text-secondary-500">*</span></legend>
          <p class="text-warm-gray text-sm mb-3">I declare that the:</p>
          <div class="space-y-2.5">
            {conditionItems.map((item) => (
              <label class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors cursor-pointer">
                <input type="checkbox" name="condition" value={item}
                  class="w-4 h-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500" />
                <span class="text-sm text-gray-700">{item}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <!-- 5. Image Upload -->
        <div>
          <label for="images" class="block text-sm font-semibold text-primary-600 mb-1.5">Photos (optional)</label>
          <p class="text-warm-gray text-sm mb-3">Upload up to 3 photos of any issues or damage.</p>
          <input type="file" id="images" name="images" accept=".jpg,.jpeg,.png,.heic" multiple
            class="w-full text-sm text-gray-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-primary-50 file:text-primary-600 hover:file:bg-primary-100 file:cursor-pointer cursor-pointer" />
          <div id="image-previews" class="flex gap-3 mt-3 flex-wrap"></div>
        </div>

        <!-- 6. Comments -->
        <div>
          <label for="comments" class="block text-sm font-semibold text-primary-600 mb-1.5">Comments (optional)</label>
          <textarea id="comments" name="comments" rows="3" placeholder="Please enter here your comments"
            class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors resize-y"></textarea>
        </div>

        <!-- Cloudflare Turnstile -->
        <div>
          <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="light" data-language="en"></div>
        </div>

        <!-- Error message area -->
        <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm"></div>

        <!-- Submit -->
        <div>
          <button type="submit" id="submit-btn"
            class="btn-cta-orange no-underline duration-300 hover:shadow-orange-600/40 cursor-pointer w-full sm:w-auto">
            SUBMIT INSPECTION
          </button>
        </div>
      </form>

      <!-- Success Confirmation (hidden by default) -->
      <div id="form-success" class="hidden text-center py-16">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 rounded-full mb-6">
          <svg width="32" height="32" class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-primary-600 mb-3" id="success-heading">Inspection Saved</h2>
        <p class="text-warm-gray text-lg" id="success-message"></p>
      </div>

    </div>
  </section>

  <!-- Cloudflare Turnstile script -->
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <!-- Form submission + image preview -->
  <script is:inline>
    (function() {
      var form = document.getElementById('vehicle-check-form');
      var errorDiv = document.getElementById('form-error');
      var submitBtn = document.getElementById('submit-btn');
      var successDiv = document.getElementById('form-success');
      var successMessage = document.getElementById('success-message');
      var imageInput = document.getElementById('images');
      var previewContainer = document.getElementById('image-previews');

      // =============================================
      // Image preview thumbnails
      // =============================================
      if (imageInput) {
        imageInput.addEventListener('change', function() {
          previewContainer.innerHTML = '';
          var files = imageInput.files;

          // Limit to 3 files
          if (files.length > 3) {
            errorDiv.textContent = 'Please select a maximum of 3 images.';
            errorDiv.classList.remove('hidden');
            imageInput.value = '';
            return;
          }

          errorDiv.classList.add('hidden');

          for (var i = 0; i < files.length; i++) {
            var file = files[i];
            if (file && file.type.startsWith('image/')) {
              var reader = new FileReader();
              reader.onload = (function(f) {
                return function(e) {
                  var wrapper = document.createElement('div');
                  wrapper.className = 'relative w-20 h-20 rounded-lg overflow-hidden border border-gray-200';
                  var img = document.createElement('img');
                  img.src = e.target.result;
                  img.alt = f.name;
                  img.className = 'w-full h-full object-cover';
                  wrapper.appendChild(img);
                  previewContainer.appendChild(wrapper);
                };
              })(file);
              reader.readAsDataURL(file);
            }
          }
        });
      }

      // =============================================
      // Form submission via fetch (multipart FormData)
      // =============================================
      if (form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault();

          errorDiv.classList.add('hidden');
          errorDiv.textContent = '';

          // Gather values
          var name = form.querySelector('#name').value.trim();
          var honeypot = form.querySelector('#website').value;
          var comments = form.querySelector('#comments').value.trim();

          // Van selection
          var vanRadio = form.querySelector('input[name="van"]:checked');
          var van = vanRadio ? vanRadio.value : '';

          // Fluids checklist
          var fluidCheckboxes = form.querySelectorAll('input[name="fluids"]:checked');
          var fluids = [];
          fluidCheckboxes.forEach(function(cb) { fluids.push(cb.value); });

          // Condition checklist
          var conditionCheckboxes = form.querySelectorAll('input[name="condition"]:checked');
          var conditions = [];
          conditionCheckboxes.forEach(function(cb) { conditions.push(cb.value); });

          // Client-side validation
          if (!name) {
            window.showToast('Please enter your name before submitting the inspection.', 'error');
            form.querySelector('#name').focus();
            return;
          }

          if (!van) {
            window.showToast('Please select which van you are inspecting.', 'error');
            return;
          }

          var totalFluids = form.querySelectorAll('input[name="fluids"]').length;
          if (fluids.length < totalFluids) {
            var missing = totalFluids - fluids.length;
            window.showToast('Please tick all fluids & safety items (' + missing + ' remaining) to confirm they are in working order.', 'warning');
            return;
          }

          var totalConditions = form.querySelectorAll('input[name="condition"]').length;
          if (conditions.length < totalConditions) {
            var missingC = totalConditions - conditions.length;
            window.showToast('Please tick all vehicle condition items (' + missingC + ' remaining) to confirm they are satisfactory.', 'warning');
            return;
          }

          // Turnstile
          var turnstileResponse = '';
          var turnstileInput = form.querySelector('[name="cf-turnstile-response"]');
          if (turnstileInput) {
            turnstileResponse = turnstileInput.value;
          }

          if (!turnstileResponse) {
            window.showToast('Please complete the security check before submitting.', 'warning');
            return;
          }

          // File count check
          var imageFiles = form.querySelector('#images').files;
          if (imageFiles.length > 3) {
            window.showToast('You\'ve selected ' + imageFiles.length + ' images — please select a maximum of 3.', 'error');
            return;
          }

          // Build FormData
          var formData = new FormData();
          formData.append('name', name);
          formData.append('van', van);
          formData.append('fluids', fluids.join(', '));
          formData.append('condition', conditions.join(', '));
          formData.append('comments', comments);
          formData.append('honeypot', honeypot);
          formData.append('turnstileToken', turnstileResponse);

          for (var i = 0; i < imageFiles.length; i++) {
            formData.append('images', imageFiles[i]);
          }

          submitBtn.disabled = true;
          submitBtn.textContent = 'SUBMITTING...';

          fetch('/api/vehicle-check', {
            method: 'POST',
            body: formData,
          })
          .then(function(res) { return res.json(); })
          .then(function(data) {
            if (data.success) {
              // Hide form, show confirmation
              form.classList.add('hidden');
              successMessage.textContent = 'Thank you ' + (data.name || name) + ', your assessment is saved!';
              successDiv.classList.remove('hidden');
              // Scroll to top of page
              window.scrollTo({ top: 0, behavior: 'smooth' });
            } else {
              window.showToast(data.error || 'Something went wrong submitting the inspection. Please try again.', 'error');
              submitBtn.disabled = false;
              submitBtn.textContent = 'SUBMIT INSPECTION';
              if (window.turnstile) { window.turnstile.reset(); }
            }
          })
          .catch(function() {
            window.showToast('Connection error — please check your internet connection and try again.', 'error');
            submitBtn.disabled = false;
            submitBtn.textContent = 'SUBMIT INSPECTION';
          });
        });
      }
    })();
  </script>

</Layout>
