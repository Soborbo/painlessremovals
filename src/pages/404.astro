---
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config/site.config';
---

<Layout title="Page Not Found | Painless Removals" description="The page you are looking for does not exist or has been moved.">
  <section class="section bg-white">
    <div class="container-narrow text-center py-16 md:py-24">
      <p class="text-6xl font-bold text-primary-200 mb-4">404</p>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Page Not Found</h1>
      <p class="text-lg text-warm-gray mb-8 max-w-md mx-auto">
        Sorry, the page you are looking for does not exist or has been moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-cta-orange no-underline duration-300 hover:shadow-orange-600/30">
          Go to Homepage
        </a>
        <a href={`tel:${siteConfig.company.contact.phone.replace(/\s/g, '')}`} class="inline-block border-2 border-primary-600 text-primary-600 hover:bg-primary-600 hover:text-white px-8 py-3 text-base font-bold uppercase no-underline rounded-sm transition-all duration-300 hover:-translate-y-0.5">
          Call {siteConfig.company.contact.phone}
        </a>
      </div>
    </div>
  </section>
</Layout>
