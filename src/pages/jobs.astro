---
/**
 * Jobs Page
 *
 * Careers page for Painless Removals.
 * Includes application form with Cloudflare Turnstile and honeypot spam protection.
 */

import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config/site.config';
import { ref, breadcrumbs } from '@/utils/schema';

// Page metadata
const pageTitle = 'Jobs – Join the Painless Removals Team';
const pageDescription = 'Looking for removal jobs in Bristol? Join the Painless Removals team. We are hiring removal crew, drivers, and packing specialists. Apply today.';

// Turnstile site key
const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;

// Benefits
const benefits = [
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    title: 'Family-Run Team',
    description: 'We\'re a tight-knit crew, not a faceless corporation. Everyone knows your name and has your back.',
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: 'Competitive Pay',
    description: 'Fair wages that reflect your hard work, plus tips on top. We value the people who make this company run.',
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: 'Stable Work',
    description: 'We\'ve been going since 1978. Regular work with a company that\'s not going anywhere.',
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    title: 'No Two Days the Same',
    description: 'Different homes, different people, different challenges every day. If you hate being stuck behind a desk, you\'ll love it.',
  },
];

// Current roles
const roles = [
  {
    title: 'Removal Crew Member',
    type: 'Full-Time',
    description: 'The backbone of every move. You\'ll be loading, carrying, and unloading household items with care. Physical fitness and a positive attitude are essential.',
    requirements: [
      'Physically fit and able to lift heavy items',
      'Reliable and punctual',
      'Friendly and respectful with customers',
      'No experience necessary — we\'ll train you',
    ],
  },
  {
    title: 'Removal Driver',
    type: 'Full-Time',
    description: 'Drive our vans across Bristol and beyond. You\'ll also help with loading and unloading. Clean driving licence required.',
    requirements: [
      'Full, clean UK driving licence (Category C preferred)',
      'Confident driving large vehicles',
      'Good knowledge of Bristol and surrounding areas',
      'Minimum 2 years driving experience',
    ],
  },
  {
    title: 'Packing Specialist',
    type: 'Full-Time / Part-Time',
    description: 'Carefully wrap and pack customers\' belongings for safe transport. Attention to detail and a gentle touch are key.',
    requirements: [
      'Careful and methodical approach',
      'Good communication skills',
      'Able to work efficiently under time pressure',
      'Previous packing experience a plus, but not essential',
    ],
  },
];

// Company values
const values = [
  { title: 'Respect', description: 'We treat every customer\'s home like our own. Their belongings matter to us.' },
  { title: 'Reliability', description: 'We turn up on time, every time. Our customers depend on us and we don\'t let them down.' },
  { title: 'Teamwork', description: 'A move goes smoothly when the crew works together. We look out for each other.' },
  { title: 'Pride', description: 'We take pride in doing a proper job. No shortcuts, no cutting corners.' },
];

const pageSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": pageTitle,
    "description": pageDescription,
    "url": `${siteConfig.brand.domain}/jobs`,
    "publisher": ref.business(),
  },
  breadcrumbs([
    { name: "Home", path: "/" },
    { name: "Jobs" },
  ]),
];
---

<Layout title={pageTitle} description={pageDescription} schema={pageSchema}>

  <!-- ============================================
       HERO – Join the Team
  ============================================ -->
  <section class="gradient-hero py-14 lg:py-20">
    <div class="container-wide text-center">
      <p class="text-primary-600 text-sm font-semibold uppercase tracking-wide mb-3">
        Careers at Painless Removals
      </p>
      <h1 class="text-3xl lg:text-5xl xl:text-6xl font-bold mb-6 max-w-3xl mx-auto">
        Join the Painless Removals Team
      </h1>
      <p class="text-lg text-warm-gray max-w-2xl mx-auto mb-8 leading-relaxed">
        We've been moving Bristol families since 1978. If you're hard-working, reliable, and
        like the idea of a job where no two days are the same — we'd love to hear from you.
      </p>
      <a href="#application-form"
        class="btn-cta-orange no-underline duration-300 hover:shadow-orange-600/40 hover:text-white/90">
        Apply Now
      </a>
    </div>
  </section>

  <!-- ============================================
       WHY WORK WITH US
  ============================================ -->
  <section class="section bg-cream">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold mb-4">Why Work With Us</h2>
        <p class="text-warm-gray text-lg max-w-2xl mx-auto">
          We're not just a removals company — we're a team that genuinely enjoys what we do.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {benefits.map((benefit) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 text-center hover:shadow-md hover:-translate-y-1 transition-all duration-300">
            <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-primary-50 flex items-center justify-center text-primary-600">
              <Fragment set:html={benefit.icon} />
            </div>
            <h3 class="text-lg font-semibold text-primary-600 mb-2">{benefit.title}</h3>
            <p class="text-warm-gray text-sm leading-relaxed">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       CURRENT ROLES
  ============================================ -->
  <section class="section bg-white">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold mb-4">Current Roles</h2>
        <p class="text-warm-gray text-lg max-w-2xl mx-auto">
          We're always looking for good people. See if one of these roles suits you.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {roles.map((role) => (
          <div class="bg-cream rounded-xl p-6 border border-gray-100 flex flex-col">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-bold text-primary-600">{role.title}</h3>
            </div>
            <span class="inline-block bg-primary-100 text-primary-600 text-xs font-semibold uppercase tracking-wide px-3 py-1 rounded-full w-fit mb-4">
              {role.type}
            </span>
            <p class="text-warm-gray text-sm leading-relaxed mb-5">{role.description}</p>
            <div class="mt-auto">
              <p class="text-sm font-semibold text-primary-600 mb-2">What we're looking for:</p>
              <ul class="space-y-1.5">
                {role.requirements.map((req) => (
                  <li class="flex items-start gap-2 text-sm text-warm-gray">
                    <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    <span>{req}</span>
                  </li>
                ))}
              </ul>
            </div>
            <a href="#application-form" class="mt-6 text-center bg-primary-600 hover:bg-primary-700 text-white px-6 py-3 font-semibold no-underline rounded-lg transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg text-sm">
              Apply for this role
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       APPLICATION FORM
  ============================================ -->
  <section class="section bg-cream" id="application-form" style="scroll-margin-top: 5rem;">
    <div class="container-narrow">
      <div class="text-center mb-10">
        <h2 class="text-3xl lg:text-4xl font-bold mb-4">Looking for a Removals Job in North Bristol?</h2>
        <div class="text-warm-gray text-lg max-w-xl mx-auto text-left space-y-4">
          <p>
            We're always on the lookout for reliable, capable removals staff to join our team. No experience? No problem — we'll teach you everything you need to know. You'll be part of a supportive, friendly team where your efforts are valued.
          </p>
          <p class="font-semibold text-primary-600">What we're looking for:</p>
          <ul class="list-disc list-inside space-y-1 text-base">
            <li>Good level of fitness</li>
            <li>Full driving licence (van driving experience an advantage)</li>
            <li>Polite and professional manner</li>
            <li>Punctuality</li>
            <li>Attention to detail</li>
            <li>Proactive attitude</li>
          </ul>
          <p>Fill in the form, and we'll be in touch soon!</p>
        </div>
      </div>

      <div class="bg-white rounded-xl p-6 sm:p-8 shadow-sm border border-gray-100 max-w-2xl mx-auto">
        <form id="jobs-form-el" class="space-y-5" novalidate data-phone={siteConfig.company.contact.phone}>
          <!-- Honeypot -->
          <div style="position: absolute; left: -9999px;" aria-hidden="true">
            <label for="website">Leave this blank</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <!-- Name -->
          <div>
            <label for="name" class="block text-sm font-semibold text-primary-600 mb-1.5">Your Name <span class="text-secondary-500">*</span></label>
            <input type="text" id="name" name="name" required autocomplete="name"
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" />
          </div>

          <!-- Email and Phone row -->
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="email" class="block text-sm font-semibold text-primary-600 mb-1.5">Email Address <span class="text-secondary-500">*</span></label>
              <input type="email" id="email" name="email" required autocomplete="email"
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-semibold text-primary-600 mb-1.5">Phone Number <span class="text-secondary-500">*</span></label>
              <input type="tel" id="phone" name="phone" required autocomplete="tel"
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" />
            </div>
          </div>

          <!-- Position -->
          <div>
            <label for="position" class="block text-sm font-semibold text-primary-600 mb-1.5">Position <span class="text-secondary-500">*</span></label>
            <select id="position" name="position" required
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors">
              <option value="">Select a position...</option>
              <option value="Removal Crew">Removal Crew Member</option>
              <option value="Driver">Removal Driver</option>
              <option value="Packing Specialist">Packing Specialist</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <!-- Driving Licence -->
          <div>
            <fieldset>
              <legend class="block text-sm font-semibold text-primary-600 mb-2">What type of driving licence do you hold? <span class="text-secondary-500">*</span></legend>
              <div class="space-y-2">
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                  <input type="radio" name="licence" value="None" required class="w-4 h-4 text-primary-600 border-gray-300 focus:ring-primary-500" />
                  None
                </label>
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                  <input type="radio" name="licence" value="Category B" class="w-4 h-4 text-primary-600 border-gray-300 focus:ring-primary-500" />
                  Category B
                </label>
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                  <input type="radio" name="licence" value="Category C1" class="w-4 h-4 text-primary-600 border-gray-300 focus:ring-primary-500" />
                  Category C1
                </label>
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                  <input type="radio" name="licence" value="Category C" class="w-4 h-4 text-primary-600 border-gray-300 focus:ring-primary-500" />
                  Category C
                </label>
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                  <input type="radio" name="licence" value="Category C+E" class="w-4 h-4 text-primary-600 border-gray-300 focus:ring-primary-500" />
                  Category C+E
                </label>
              </div>
            </fieldset>
          </div>

          <!-- Message / Cover Letter -->
          <div>
            <label for="message" class="block text-sm font-semibold text-primary-600 mb-1.5">Tell Us About Yourself</label>
            <textarea id="message" name="message" rows="5"
              placeholder="A bit about your experience, why you'd like to join, availability..."
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors resize-y"></textarea>
          </div>

          <!-- Cloudflare Turnstile -->
          <div>
            <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="light"></div>
          </div>

          <!-- Error message area -->
          <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm"></div>

          <!-- CV upload -->
          <div>
            <label for="cv" class="block text-sm font-semibold text-primary-600 mb-1.5">Attach Your CV <span class="text-warm-gray font-normal">(optional)</span></label>
            <input type="file" id="cv" name="cv"
              accept=".pdf,.doc,.docx,.txt,.rtf,.odt"
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors text-sm file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-primary-50 file:text-primary-600 hover:file:bg-primary-100 file:cursor-pointer" />
            <p class="text-warm-gray text-xs mt-1.5">Accepted formats: PDF, DOC, DOCX, TXT, RTF, ODT. Maximum 5 MB.</p>
          </div>

          <!-- Consent -->
          <div>
            <fieldset>
              <legend class="block text-sm font-semibold text-primary-600 mb-2">Consent <span class="text-secondary-500">*</span></legend>
              <label class="flex items-start gap-2 text-sm text-gray-700 cursor-pointer">
                <input type="checkbox" id="consent" name="consent" required class="w-4 h-4 mt-0.5 text-primary-600 border-gray-300 rounded focus:ring-primary-500" />
                <span>I agree to the <a href="/privacy-policy" class="text-primary-600 underline hover:text-primary-700">privacy policy</a>.</span>
              </label>
            </fieldset>
          </div>

          <!-- Submit -->
          <div>
            <button type="submit" id="submit-btn"
              class="btn-cta-orange no-underline duration-300 hover:shadow-orange-600/40 cursor-pointer w-full sm:w-auto">
              SUBMIT APPLICATION
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- ============================================
       COMPANY VALUES
  ============================================ -->
  <section class="section bg-primary-600 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute top-10 left-10 w-40 h-40 border border-white rounded-full"></div>
      <div class="absolute bottom-10 right-10 w-60 h-60 border border-white rounded-full"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 border border-white rounded-full"></div>
    </div>

    <div class="container-wide relative z-10">
      <div class="text-center mb-12">
        <h2 class="text-white text-3xl lg:text-4xl font-bold mb-4">What We Stand For</h2>
        <p class="text-primary-100 text-lg max-w-2xl mx-auto">
          These aren't just words on a wall. They're how we work, every single day.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
        {values.map((value) => (
          <div class="stat-card-blue group text-center">
            <h3 class="text-xl font-bold text-white mb-2">{value.title}</h3>
            <p class="text-sm text-primary-200 group-hover:text-white transition-colors duration-300 leading-relaxed">{value.description}</p>
            <div class="w-0 h-0.5 bg-white/40 mx-auto mt-4 group-hover:w-12 transition-all duration-500"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       FINAL CTA
  ============================================ -->
  <section class="py-16 md:py-20 bg-cream text-center">
    <div class="container-wide">
      <h2 class="mb-4">Got Questions About Working With Us?</h2>
      <p class="text-warm-gray text-lg mb-8 max-w-xl mx-auto">
        Give Jay a call. He's always happy to chat about what it's like to work at Painless Removals.
      </p>

      <a href={`tel:${siteConfig.company.contact.phone.replace(/\s/g, '')}`}
        class="btn-cta-orange inline-flex items-center gap-3 no-underline duration-300 hover:shadow-orange-600/40 hover:text-white/90">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        Call {siteConfig.company.contact.phone}
      </a>
    </div>
  </section>

  <!-- Cloudflare Turnstile script -->
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <!-- Jobs form submission -->
  <script is:inline>
    (function() {
      var form = document.getElementById('jobs-form-el');
      var PHONE = form && form.dataset.phone || '0117 287 0082';
      var errorDiv = document.getElementById('form-error');
      var submitBtn = document.getElementById('submit-btn');

      if (form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault();

          errorDiv.classList.add('hidden');
          errorDiv.textContent = '';

          var name = form.querySelector('#name').value.trim();
          var email = form.querySelector('#email').value.trim();
          var phone = form.querySelector('#phone').value.trim();
          var position = form.querySelector('#position').value;
          var message = form.querySelector('#message').value.trim();
          var honeypot = form.querySelector('#website').value;

          if (!name) {
            window.showToast('Please enter your full name.', 'error');
            form.querySelector('#name').focus();
            return;
          }
          if (!email) {
            window.showToast('Please enter your email address.', 'error');
            form.querySelector('#email').focus();
            return;
          }
          if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
            window.showToast('That email address doesn\'t look right — please check it and try again.', 'error');
            form.querySelector('#email').focus();
            return;
          }
          if (!phone) {
            window.showToast('Please enter your phone number.', 'error');
            form.querySelector('#phone').focus();
            return;
          }
          if (!position) {
            window.showToast('Please select the position you\'re applying for.', 'error');
            form.querySelector('#position').focus();
            return;
          }

          var licenceRadio = form.querySelector('input[name="licence"]:checked');
          if (!licenceRadio) {
            window.showToast('Please select your driving licence type.', 'error');
            return;
          }
          var licence = licenceRadio.value;

          var consentBox = form.querySelector('#consent');
          if (!consentBox.checked) {
            window.showToast('Please agree to the privacy policy before submitting.', 'error');
            consentBox.focus();
            return;
          }

          var turnstileResponse = '';
          var turnstileInput = form.querySelector('[name="cf-turnstile-response"]');
          if (turnstileInput) {
            turnstileResponse = turnstileInput.value;
          }

          if (!turnstileResponse) {
            window.showToast('Please complete the security check before submitting your application.', 'warning');
            return;
          }

          // Validate CV file if attached
          var cvInput = form.querySelector('#cv');
          var cvFile = cvInput && cvInput.files && cvInput.files[0];
          if (cvFile) {
            var maxSize = 5 * 1024 * 1024; // 5 MB
            if (cvFile.size > maxSize) {
              window.showToast('Your CV file is too large (' + (cvFile.size / 1024 / 1024).toFixed(1) + ' MB). Maximum allowed size is 5 MB — please compress it and try again.', 'error');
              return;
            }
            var allowedTypes = ['.pdf', '.doc', '.docx', '.txt', '.rtf', '.odt'];
            var ext = cvFile.name.toLowerCase().substring(cvFile.name.lastIndexOf('.'));
            if (allowedTypes.indexOf(ext) === -1) {
              window.showToast('That file type isn\'t accepted. Please upload your CV as a PDF, DOC, DOCX, TXT, RTF, or ODT.', 'error');
              return;
            }
          }

          submitBtn.disabled = true;
          submitBtn.textContent = 'SUBMITTING...';

          var formData = new FormData();
          formData.append('name', name);
          formData.append('email', email);
          formData.append('phone', phone);
          formData.append('position', position);
          formData.append('licence', licence);
          formData.append('message', message);
          formData.append('honeypot', honeypot);
          formData.append('turnstileToken', turnstileResponse);
          if (cvFile) {
            formData.append('cv', cvFile);
          }

          fetch('/api/jobs', {
            method: 'POST',
            body: formData,
            headers: {
              'Accept': 'application/json'
            }
          })
          .then(function(res) {
            return res.text().then(function(text) {
              var data = {};
              if (text) {
                try {
                  data = JSON.parse(text);
                } catch (_e) {
                  data = {};
                }
              }

              if (!res.ok) {
                throw new Error((data && data.error) || ('Server returned ' + res.status));
              }

              return data;
            });
          })
          .then(function(data) {
            if (data.success) {
              // Analytics-only event (NOT a conversion).
              var eventId = (window.crypto && window.crypto.randomUUID)
                ? window.crypto.randomUUID()
                : ('id-' + Date.now() + '-' + Math.random().toString(36).slice(2));
              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push({
                event: 'form_submission',
                event_id: eventId,
                form_name: 'job_application',
                form_source: 'jobs-page',
              });
              window.location.href = '/jobs/thank-you/';
            } else {
              window.showToast(data.error || 'Something went wrong submitting your application. Please try again or call us on ' + PHONE + '.', 'error');
              submitBtn.disabled = false;
              submitBtn.textContent = 'SUBMIT APPLICATION';
              if (window.turnstile) { window.turnstile.reset(); }
            }
          })
          .catch(function(err) {
            console.error('Jobs form error:', err);
            window.showToast('Connection error — please check your internet and try again, or call us on ' + PHONE + '.', 'error');
            submitBtn.disabled = false;
            submitBtn.textContent = 'SUBMIT APPLICATION';
          });
        });
      }
    })();
  </script>

</Layout>
