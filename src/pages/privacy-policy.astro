---
/**
 * Privacy Policy — UK GDPR Compliant
 *
 * Covers data protection for Painless Removals website.
 * References UK GDPR (retained EU law), DPA 2018, PECR 2003.
 * Cookies section folded into this page.
 */

import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config/site.config';

const pageTitle = 'Privacy Policy';
const pageDescription = 'Privacy policy for Painless Removals Ltd. How we collect, use, and protect your personal data under UK GDPR.';

const tocSections = [
  { id: 'data-controller', label: 'Data Controller' },
  { id: 'what-we-collect', label: 'What We Collect' },
  { id: 'how-we-collect', label: 'How We Collect It' },
  { id: 'lawful-basis', label: 'Lawful Basis' },
  { id: 'third-parties', label: 'Third Parties' },
  { id: 'cookies', label: 'Cookies' },
  { id: 'retention', label: 'Data Retention' },
  { id: 'your-rights', label: 'Your Rights' },
  { id: 'international-transfers', label: 'International Transfers' },
  { id: 'ico', label: 'ICO Complaints' },
  { id: 'changes', label: 'Changes to This Policy' },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": pageTitle,
  "description": pageDescription,
  "url": `${siteConfig.brand.domain}/privacy-policy`,
  "publisher": { "@id": `${siteConfig.brand.domain}/#business` },
  "dateModified": "2026-02-14",
};
---

<Layout title={pageTitle} description={pageDescription} schema={schema}>

  <!-- Breadcrumbs -->
  <div class="bg-white border-b border-gray-100">
    <div class="container-wide py-3">
      <nav class="text-sm text-warm-gray" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="text-primary-600 hover:text-primary-700 no-underline">Home</a></li>
          <li class="text-warm-gray/50">/</li>
          <li class="text-warm-gray">Privacy Policy</li>
        </ol>
      </nav>
    </div>
  </div>

  <section class="section bg-cream">
    <div class="container-narrow">

      <h1 class="text-3xl lg:text-4xl font-bold mb-2">Privacy Policy</h1>
      <p class="text-warm-gray mb-8">Last updated: 14 February 2026</p>

      <!-- Table of Contents -->
      <nav class="bg-white rounded-lg border border-gray-100 p-5 mb-10" aria-label="Table of contents">
        <p class="font-semibold text-primary-600 mb-3">Contents</p>
        <ol class="space-y-1.5 list-decimal list-inside text-sm">
          {tocSections.map((s) => (
            <li>
              <a href={`#${s.id}`} class="text-primary-600 hover:text-secondary-500 no-underline">{s.label}</a>
            </li>
          ))}
        </ol>
      </nav>

      <!-- 1. Data Controller -->
      <div class="space-y-10 text-warm-gray leading-relaxed">

        <div id="data-controller" style="scroll-margin-top: 5rem;">
          <h2 class="text-xl font-bold text-primary-600 mb-3">1. Data Controller</h2>
          <p class="mb-3">The data controller for your personal data is:</p>
          <div class="bg-white rounded-lg border border-gray-100 p-5 mb-3">
            <p class="font-semibold text-primary-600">{siteConfig.company.name}</p>
            <p>{siteConfig.company.address.streetAddress}, {siteConfig.company.address.addressLocality} {siteConfig.company.address.postalCode}</p>
            <p>Email: {siteConfig.company.contact.email}</p>
            <p>Phone: {siteConfig.company.contact.phone}</p>
          </div>
          <p>If you have questions about how we handle your data, contact us using the details above.</p>
        </div>

        <!-- 2. What We Collect -->
        <div id="what-we-collect" style="scroll-margin-top: 5rem;">
          <h2 class="text-xl font-bold text-primary-600 mb-3">2. What We Collect</h2>
          <p class="mb-3">We may collect and process the following personal data:</p>
          <ul class="list-disc pl-6 space-y-1.5 mb-3">
            <li><strong>Identity data:</strong> your name</li>
            <li><strong>Contact data:</strong> email address, phone number, postal address</li>
            <li><strong>Move data:</strong> property details, move dates, inventory of belongings, access requirements</li>
            <li><strong>Technical data:</strong> IP address, browser type and version, time zone, operating system</li>
            <li><strong>Usage data:</strong> pages visited, time on site, referral source</li>
            <li><strong>Communications:</strong> records of correspondence, form submissions, and phone call notes</li>
            <li><strong>Employment data:</strong> CV, cover letter, and application details (if you apply for a role)</li>
            <li><strong>Referral data:</strong> names and contact details submitted via our affiliate referral form, with consent</li>
          </ul>
          <p>We do not collect any special category (sensitive) data unless you voluntarily provide it.</p>
        </div>

        <!-- 3. How We Collect It -->
        <div id="how-we-collect" style="scroll-margin-top: 5rem;">
          <h2 class="text-xl font-bold text-primary-600 mb-3">3. How We Collect It</h2>
          <p class="mb-3">We collect personal data through:</p>
          <ul class="list-disc pl-6 space-y-1.5">
            <li><strong>Direct interactions:</strong> when you fill in forms on our website (contact, quote, job application, vehicle check, affiliate referral), call us, or email us</li>
            <li><strong>Automated technologies:</strong> cookies, server logs, and analytics tools that collect technical and usage data as you browse our site</li>
            <li><strong>Third parties:</strong> referral partners who submit your details with your consent via our affiliate form</li>
          </ul>
        </div>

        <!-- 4. Lawful Basis -->
        <div id="lawful-basis" style="scroll-margin-top: 5rem;">
          <h2 class="text-xl font-bold text-primary-600 mb-3">4. Lawful Basis for Processing</h2>
          <p class="mb-3">Under UK GDPR (retained EU law) and the Data Protection Act 2018, we rely on the following lawful bases:</p>
          <div class="overflow-x-auto">
            <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden mb-3">
              <thead class="bg-primary-600 text-white">
                <tr>
                  <th class="text-left px-4 py-2.5 font-semibold">Purpose</th>
                  <th class="text-left px-4 py-2.5 font-semibold">Lawful Basis</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 bg-white">
                <tr><td class="px-4 py-2.5">Responding to your enquiry or providing a quote</td><td class="px-4 py-2.5">Contract / Pre-contract</td></tr>
                <tr><td class="px-4 py-2.5">Carrying out your removal, packing, or storage service</td><td class="px-4 py-2.5">Contract</td></tr>
                <tr><td class="px-4 py-2.5">Processing job applications</td><td class="px-4 py-2.5">Legitimate interest</td></tr>
                <tr><td class="px-4 py-2.5">Sending marketing emails (only with your opt-in)</td><td class="px-4 py-2.5">Consent</td></tr>
                <tr><td class="px-4 py-2.5">Preventing fraud and spam (Turnstile, honeypot)</td><td class="px-4 py-2.5">Legitimate interest</td></tr>
                <tr><td class="px-4 py-2.5">Website analytics and performance monitoring</td><td class="px-4 py-2.5">Legitimate interest</td></tr>
                <tr><td class="px-4 py-2.5">Complying with legal obligations (insurance records, tax)</td><td class="px-4 py-2.5">Legal obligation</td></tr>
                <tr><td class="px-4 py-2.5">Processing affiliate referrals</td><td class="px-4 py-2.5">Consent (confirmed by referring agent)</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- 5. Third Parties -->
        <div id="third-parties" style="scroll-margin-top: 5rem;">
          <h2 class="text-xl font-bold text-primary-600 mb-3">5. Third Parties We Share Data With</h2>
          <p class="mb-3">We share your data only where necessary and with appropriate safeguards:</p>
          <ul class="list-disc pl-6 space-y-3">
            <li>
              <strong>Cloudflare</strong> — website hosting, CDN, DDoS protection, and Turnstile CAPTCHA verification. Cloudflare processes technical data (IP address, browser fingerprint) to protect the site from malicious traffic. <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener" class="text-primary-600 underline hover:text-secondary-500">Cloudflare Privacy Policy</a>.
            </li>
            <li>
              <strong>Resend</strong> — email delivery service used to send form submissions and transactional emails. Resend processes the name, email, and message content you submit via our forms. <a href="https://resend.com/legal/privacy-policy" target="_blank" rel="noopener" class="text-primary-600 underline hover:text-secondary-500">Resend Privacy Policy</a>.
            </li>
            <li>
              <strong>Google Tag Manager / Google Analytics</strong> — website analytics. Collects anonymised usage data including pages visited, session duration, and referral source. We use IP anonymisation where available. <a href="https://policies.google.com/privacy" target="_blank" rel="noopener" class="text-primary-600 underline hover:text-secondary-500">Google Privacy Policy</a>.
            </li>
            <li>
              <strong>Meta Pixel (Facebook)</strong> — conversion tracking for advertising. Collects usage data to measure the effectiveness of our ads on Facebook and Instagram. You can opt out via your Facebook ad preferences. <a href="https://www.facebook.com/privacy/policy/" target="_blank" rel="noopener" class="text-primary-600 underline hover:text-secondary-500">Meta Privacy Policy</a>.
            </li>
          </ul>
          <p class="mt-3">We do not sell your personal data to any third party.</p>
        </div>

        <!-- 6. Cookies -->
        <div id="cookies" style="scroll-margin-top: 5rem;">
          <h2 class="text-xl font-bold text-primary-600 mb-3">6. Cookies</h2>
          <p class="mb-3">Our website uses cookies and similar technologies. Under the Privacy and Electronic Communications Regulations 2003 (PECR), we are required to inform you about cookies and obtain consent for non-essential ones.</p>

          <h3 class="font-semibold text-primary-600 mt-4 mb-2">Strictly Necessary Cookies</h3>
          <p class="mb-3">These are required for the website to function. They cannot be switched off. They include Cloudflare security cookies and session identifiers.</p>

          <h3 class="font-semibold text-primary-600 mt-4 mb-2">Analytics Cookies</h3>
          <p class="mb-3">Google Analytics cookies help us understand how visitors use the site. They collect anonymised data about page views, session duration, and navigation paths. These are only set with your consent.</p>

          <h3 class="font-semibold text-primary-600 mt-4 mb-2">Marketing Cookies</h3>
          <p class="mb-3">Meta Pixel cookies track conversions from our Facebook and Instagram advertising. These are only set with your consent.</p>

          <h3 class="font-semibold text-primary-600 mt-4 mb-2">Managing Cookies</h3>
          <p>You can manage or delete cookies through your browser settings. Most browsers allow you to block or delete cookies. Please note that blocking essential cookies may affect site functionality. You can also opt out of Google Analytics using the <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener" class="text-primary-600 underline hover:text-secondary-500">Google Analytics opt-out browser add-on</a>.</p>
        </div>

        <!-- 7. Data Retention -->
        <div id="retention" style="scroll-margin-top: 5rem;">
          <h2 class="text-xl font-bold text-primary-600 mb-3">7. Data Retention</h2>
          <p class="mb-3">We retain your personal data only for as long as necessary:</p>
          <ul class="list-disc pl-6 space-y-1.5">
            <li><strong>Enquiry and quote data:</strong> 2 years from last contact</li>
            <li><strong>Customer records (completed moves):</strong> 6 years (in line with HMRC requirements)</li>
            <li><strong>Job application data:</strong> 6 months from decision (or longer with your consent)</li>
            <li><strong>Vehicle inspection records:</strong> 15 months (in line with DVSA guidance)</li>
            <li><strong>Marketing consent records:</strong> until you withdraw consent</li>
            <li><strong>Website analytics data:</strong> 14 months (Google Analytics default)</li>
          </ul>
          <p class="mt-3">When data is no longer needed, it is securely deleted or anonymised.</p>
        </div>

        <!-- 8. Your Rights -->
        <div id="your-rights" style="scroll-margin-top: 5rem;">
          <h2 class="text-xl font-bold text-primary-600 mb-3">8. Your Rights</h2>
          <p class="mb-3">Under UK GDPR, you have the following rights:</p>
          <ul class="list-disc pl-6 space-y-1.5 mb-3">
            <li><strong>Right of access</strong> — request a copy of your personal data (Data Subject Access Request / DSAR)</li>
            <li><strong>Right to rectification</strong> — ask us to correct inaccurate data</li>
            <li><strong>Right to erasure</strong> — ask us to delete your data (where there is no legal reason to keep it)</li>
            <li><strong>Right to restrict processing</strong> — ask us to limit how we use your data</li>
            <li><strong>Right to data portability</strong> — receive your data in a structured, machine-readable format</li>
            <li><strong>Right to object</strong> — object to processing based on legitimate interest</li>
            <li><strong>Right to withdraw consent</strong> — where processing is based on consent, withdraw at any time</li>
          </ul>
          <p class="mb-3">To exercise any of these rights, contact us at <strong>{siteConfig.company.contact.email}</strong> or write to us at the address above. We will respond within one calendar month.</p>
          <p>There is no fee for most requests. We may charge a reasonable fee or refuse the request if it is clearly unfounded or excessive.</p>
        </div>

        <!-- 9. International Transfers -->
        <div id="international-transfers" style="scroll-margin-top: 5rem;">
          <h2 class="text-xl font-bold text-primary-600 mb-3">9. International Transfers</h2>
          <p class="mb-3">Some of our third-party service providers are based outside the UK. Where personal data is transferred internationally, we ensure appropriate safeguards are in place:</p>
          <ul class="list-disc pl-6 space-y-1.5">
            <li><strong>UK adequacy decisions:</strong> where the UK Government has determined that a country provides adequate data protection (e.g. the EU, EEA countries)</li>
            <li><strong>Standard Contractual Clauses (SCCs):</strong> approved by the ICO, these contractual terms ensure your data receives equivalent protection when transferred to countries without an adequacy decision</li>
          </ul>
          <p class="mt-3">If you would like details of the specific safeguards applied to any transfer, please contact us.</p>
        </div>

        <!-- 10. ICO Complaints -->
        <div id="ico" style="scroll-margin-top: 5rem;">
          <h2 class="text-xl font-bold text-primary-600 mb-3">10. ICO Complaints</h2>
          <p class="mb-3">If you are unhappy with how we have handled your personal data, we encourage you to contact us first so we can try to resolve the issue.</p>
          <p class="mb-3">You also have the right to lodge a complaint with the Information Commissioner's Office (ICO):</p>
          <div class="bg-white rounded-lg border border-gray-100 p-5">
            <p class="font-semibold text-primary-600">Information Commissioner's Office</p>
            <p>Wycliffe House, Water Lane, Wilmslow, Cheshire SK9 5AF</p>
            <p>Helpline: 0303 123 1113</p>
            <p>Website: <a href="https://ico.org.uk" target="_blank" rel="noopener" class="text-primary-600 underline hover:text-secondary-500">ico.org.uk</a></p>
          </div>
        </div>

        <!-- 11. Changes -->
        <div id="changes" style="scroll-margin-top: 5rem;">
          <h2 class="text-xl font-bold text-primary-600 mb-3">11. Changes to This Policy</h2>
          <p class="mb-3">We may update this privacy policy from time to time. Any changes will be posted on this page with an updated revision date. We will not reduce your rights under this policy without your explicit consent.</p>
          <p>This policy was last reviewed on <strong>14 February 2026</strong>.</p>
        </div>

      </div>

    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-14 bg-primary-600 text-white text-center">
    <div class="container-narrow">
      <h2 class="font-heading text-2xl md:text-3xl font-semibold text-white mb-2">Questions About Your Data?</h2>
      <p class="text-white/80 mb-6 max-w-md mx-auto">Contact us and we will respond within one working day.</p>
      <a href="/contact/" class="btn-cta-orange no-underline duration-300 hover:shadow-orange-600/40">
        Contact Us
      </a>
    </div>
  </section>

</Layout>
