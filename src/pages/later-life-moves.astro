---
/**
 * Later Life Moves — Comprehensive Downsizing Concierge Landing Page
 *
 * Bristol's first integrated downsizing service. 21 sections covering
 * the full journey from discovery to settlement.
 *
 * Primary audience: Adult children (45–65) worried about ageing parents
 * Secondary audience: Over-65 homeowners considering downsizing
 * Tone: Warm, calm, confident. Never clinical. Never salesy.
 */

import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config/site.config';
import EquityCalculator from '@/components/later-life/EquityCalculator.astro';
import PostcodeLookup from '@/components/later-life/PostcodeLookup.astro';
import WorryCard from '@/components/later-life/WorryCard.astro';
import TrustpilotStrip from '@/components/TrustpilotStrip.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';

// Page metadata
const pageTitle = 'Later Life Moves Bristol | Downsizing Concierge | Painless Removals';
const pageDescription = 'Bristol\'s first integrated downsizing concierge. One trusted team guides you from the first conversation to settling into your new home — 47 years of caring service. Free discovery visit.';

// ===== DATA: 7 Phases =====
const phases = [
  {
    number: 1,
    title: 'Discovery & Planning',
    summary: 'A free home visit. We listen, we understand, we build a plan.',
    detail: 'Your Transition Coordinator visits the home — no pressure, no sales pitch. This is about understanding: what does your parent (or you) actually want? What are the fears? What are the practical constraints? We map the timeline together and agree on next steps. If it is not right for us, we will say so. If it is, you will leave with a personalised transition plan, not a quote.',
  },
  {
    number: 2,
    title: 'Financial Roadmap',
    summary: 'We introduce you to vetted IFAs and equity release specialists. We never advise — we connect.',
    detail: 'Downsizing is not just emotional — it is financial. How much equity is locked in the property? What are the tax implications? Is equity release the right option, or is selling outright better? We do not answer these questions because we are not financial advisors. But we introduce you to people who are — vetted, local, patient professionals who specialise in later-life finance. No commission-driven recommendations. No pressure.',
  },
  {
    number: 3,
    title: 'Property & Legal',
    summary: 'Estate agent coordination, solicitor introductions, care home search.',
    detail: 'We work with a network of approved partners — estate agents, solicitors, and care home specialists — who understand later-life transitions. They will not rush your parent. They will not use jargon. They will communicate clearly, patiently, and with respect. If the next step is a care home, we search with you — not for you.',
  },
  {
    number: 4,
    title: 'The Emotional Sort',
    summary: 'Heritage cataloguing. Cherished items rehoming. Family distribution support.',
    detail: 'This is where most people get stuck — and where most removal companies do not even show up. A lifetime of belongings does not fit into a two-bedroom flat. But this is not about throwing things away. It is about deciding what matters, preserving the stories behind the things that do, and finding good homes for the things that cannot come along. We photograph treasured items, record the stories behind them, and create a digital memory book.',
  },
  {
    number: 5,
    title: 'The Move Itself',
    summary: 'Our own crew, at your pace. New home ready before you arrive.',
    detail: 'This is what we have done for 47 years — except now we do it slower, gentler, and with more care. Our team is DBS-checked, Dementia Friends trained, and briefed on your parent\'s specific needs. We take two to three days instead of one. We set up the new home before they arrive: bed made, kettle on, milk in the fridge, familiar photos on the wall. When they walk in, it already feels like theirs.',
  },
  {
    number: 6,
    title: 'Admin & Settlement',
    summary: 'GP, council tax, utilities, Royal Mail, ID — we handle it or sit alongside every form.',
    detail: 'Nobody tells you how much admin comes with a move. We do all of it or help you do it: GP registration, council tax notification, utility transfers, Royal Mail redirect, driving licence update, electoral roll, TV licence, insurance updates, bank address changes, pension notifications. For someone in their seventies or eighties, this is overwhelming. For us, it is a checklist we have done hundreds of times.',
  },
  {
    number: 7,
    title: '30-Day Aftercare',
    summary: 'Follow-up calls, community welcome pack, ongoing support.',
    detail: 'The first month is the hardest. Everything is new. The shops are different. The sounds are different. So we stay in touch. Your Transition Coordinator calls at 7 days, 14 days, and 30 days. We provide a personalised Community Welcome Pack — local activities, walking clubs, coffee mornings, library events. If something is not right — the curtains do not fit, the washing machine is playing up — we help.',
  },
];

// ===== DATA: Margaret's Day =====
const margaretBefore = [
