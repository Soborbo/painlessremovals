const margaretAfter = [
  { time: '7:00', text: 'Wakes up. Everything is on one level. No stairs. Walks straight to the kitchen.' },
  { time: '8:30', text: 'Breakfast. The flat is warm — the heating costs a third of what the house did.' },
  { time: '10:00', text: 'Walks to the community centre. She joined a watercolour class her Transition Coordinator found for her.' },
  { time: '11:30', text: 'Coffee with Jean at the café on the corner. It is a three-minute walk.' },
  { time: '13:00', text: 'Lunch. Her daughter pops in — she is 10 minutes away now, not 45.' },
  { time: '15:00', text: 'Reads in the living room. David\'s favourite armchair is here. So is his bookshelf. The things that matter came with her.' },
  { time: '17:00', text: 'FaceTimes her grandson. The Painless team set up her tablet and showed her how.' },
  { time: '19:30', text: 'The building has a secure entry system. She locks the front door once and that is it.' },
  { time: '21:00', text: 'Bed. Her own bed. Her own bedroom. She sleeps properly for the first time in years.' },
];

