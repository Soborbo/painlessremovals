<!-- Stats countUp animation -->
<script>
  // CountUp for stats bar
  function animateCountUp(el: HTMLElement, target: string, duration = 1500) {
    const numericPart = parseFloat(target.replace(/[^0-9.]/g, ''));
    const prefix = target.match(/^[^0-9]*/)?.[0] || '';
    const suffix = target.replace(/^[^0-9]*[0-9.,]*/, '') || '';
    const start = performance.now();
    const isDecimal = target.includes('.');

    function tick(now: number) {
      const t = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - t, 3);
      const val = eased * numericPart;
      if (isDecimal) {
        el.textContent = prefix + val.toFixed(1) + suffix;
      } else {
        el.textContent = prefix + Math.round(val).toLocaleString('en-GB') + suffix;
      }
      if (t < 1) requestAnimationFrame(tick);
      else el.textContent = target; // Ensure final value is exact
    }

    requestAnimationFrame(tick);
  }

  const statsSection = document.getElementById('stats-bar');
  let statsAnimated = false;

  if (statsSection) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !statsAnimated) {
          statsAnimated = true;
          const stat1 = document.getElementById('stat-millions');
          const stat2 = document.getElementById('stat-percent');
          const stat3 = document.getElementById('stat-wealth');
          if (stat1) animateCountUp(stat1, '3.1 million', 1500);
          if (stat2) animateCountUp(stat2, '86%', 1200);
          if (stat3) animateCountUp(stat3, '£2.9 trillion', 1800);
        }
      });
    }, { threshold: 0.3 });
    observer.observe(statsSection);
  }
</script>

<!-- Memory Keeper carousel arrows -->
