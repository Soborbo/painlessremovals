const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Later Life Moves Bristol",
  "description": pageDescription,
  "provider": { "@id": `${siteConfig.brand.domain}/#business` },
  "areaServed": { "@type": "City", "name": "Bristol" },
  "serviceType": "Later Life Moving Service",
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": { "@type": "Answer", "text": faq.answer.replace(/<[^>]*>/g, '') },
  })),
};

const howToSchema = {
