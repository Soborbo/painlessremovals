<Layout title={pageTitle} description={pageDescription} schema={pageSchema} noindex>

  <!-- ============================================
       SECTION 1: HERO
  ============================================ -->
  <section class="relative lg:grid lg:grid-rows-[1fr_auto]">
    <!-- Mobile: Image at top -->
    <div class="lg:hidden w-full h-[50vh] min-h-[280px] relative overflow-hidden bg-primary-50">
      <div class="absolute inset-0 flex items-center justify-center bg-primary-50 text-primary-400">
        <div class="text-center p-6">
          <svg class="w-20 h-20 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          <p class="text-sm font-medium">Hero image: Warm later-life scene</p>
          <p class="text-xs mt-1 opacity-70">Recommended: 1280&times;720 or larger</p>
        </div>
      </div>
    </div>

    <!-- Desktop: Split layout -->
    <div class="lg:grid lg:grid-cols-2 lg:min-h-0 lg:overflow-hidden">
      <!-- Left: Content -->
      <div class="gradient-hero px-6 py-8 lg:py-10 lg:px-12 xl:px-16 flex flex-col justify-center">
        <div class="max-w-xl mx-auto text-center">
          <p class="text-primary-600 text-sm font-semibold uppercase tracking-wide mb-2">
            Later Life Moves &middot; Bristol
          </p>

          <h1 class="text-3xl lg:text-4xl xl:text-5xl mb-3 lg:mb-4 font-bold leading-tight">
            Your home held a lifetime of memories. <span class="text-secondary-500">We help you carry them forward.</span>
          </h1>

          <p class="text-lg lg:text-xl text-warm-gray mb-5 lg:mb-6 leading-relaxed">
            Bristol&rsquo;s first integrated downsizing concierge. One trusted team guides you from the first conversation to settling into your new home &mdash; and every step in between.
          </p>

          <div class="flex flex-col sm:flex-row gap-3 mb-5 justify-center">
            <a href="#callback" class="btn-cta-orange">
              Get a Free Discovery Visit
            </a>
            <a href="#calculator" class="inline-block border-2 border-primary-600 text-primary-600 hover:bg-primary-600 hover:text-white px-8 py-4 text-base font-bold uppercase tracking-wide no-underline rounded-sm transition-all duration-300 hover:-translate-y-1">
              See Your Equity Estimate
            </a>
          </div>

          <!-- Trust strip -->
          <p class="text-xs text-warm-gray/70 mb-4">
            EST. 1978 &middot; 47 Years of Trusted Service &middot; BAR Member &middot; Dementia Friends Trained &middot; DBS-Checked Staff
          </p>

          <TrustpilotStrip />
        </div>
      </div>

      <!-- Right: Image placeholder (desktop) -->
      <div class="hidden lg:block relative overflow-hidden bg-primary-50">
        <div class="absolute inset-0 flex items-center justify-center bg-primary-50 text-primary-400">
          <div class="text-center p-6">
            <svg class="w-20 h-20 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            <p class="text-sm font-medium">Hero image: Warm later-life scene</p>
            <p class="text-xs mt-1 opacity-70">Recommended: 1280&times;720 or larger</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================
       SECTION 2: STATS BAR
  ============================================ -->
  <section class="py-12 md:py-16 bg-primary-600" id="stats-bar">
    <div class="container-wide">
      <div class="grid md:grid-cols-3 gap-6">
        <div class="stat-card-blue">
          <p class="font-heading text-4xl md:text-5xl font-bold text-white leading-none mb-2" id="stat-millions">3.1 million</p>
          <p class="text-sm text-white/80">over-65s want to downsize but cannot face the process</p>
        </div>
        <div class="stat-card-blue">
          <p class="font-heading text-4xl md:text-5xl font-bold text-white leading-none mb-2" id="stat-percent">86%</p>
          <p class="text-sm text-white/80">of 65+ households have more bedrooms than they need</p>
        </div>
