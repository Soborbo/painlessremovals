const title = "How to Pack a Van for Moving House — Step-by-Step Guide";
const description = "Learn how to pack a removal van properly for moving house. Step-by-step loading order, weight distribution, professional equipment, and common mistakes to avoid. Expert advice from Bristol movers with 45+ years' experience.";

