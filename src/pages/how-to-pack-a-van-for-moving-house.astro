  { id: 'before-you-start', label: 'Before You Start' },
  { id: 'equipment', label: 'Equipment You Need' },
  { id: 'loading-order', label: 'The Loading Order' },
  { id: 'weight-distribution', label: 'Weight Distribution' },
  { id: 'protecting-items', label: 'Protecting Your Items' },
  { id: 'securing-the-load', label: 'Securing the Load' },
  { id: 'special-items', label: 'Special Items' },
  { id: 'common-mistakes', label: 'Common Mistakes' },
  { id: 'diy-vs-pro', label: 'DIY vs Professional' },
  { id: 'faq', label: 'FAQ' },
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "author": { "@id": `${siteConfig.brand.domain}/about/jay-newton/#person` },
  "publisher": { "@id": `${siteConfig.brand.domain}/#business` },
  "datePublished": "2022-01-20",
  "dateModified": "2026-03-18",
};

const faqs = [
  { question: "What size van do I need for a house move?", answer: "A one-bedroom flat typically fits in a large transit van (3.5 tonne). A two- to three-bedroom house usually needs a 7.5-tonne Luton van or larger. For a four-bedroom house, you are looking at an 18-tonne removal truck or two trips in a smaller van. If in doubt, go bigger — an overloaded van is dangerous and illegal, while a half-empty one just means less Tetris." },
  { question: "Should I load heavy items first or last?", answer: "Heavy items go on first and at the bottom. Washing machines, fridges, and heavy furniture should sit against the bulkhead (the wall behind the cab) to keep the centre of gravity low and forward. Never stack heavy items on top of light ones — the whole stack will shift in transit." },
  { question: "How do I stop furniture getting damaged in the van?", answer: "Use removal blankets, old duvets, or furniture covers to wrap everything. Stand mattresses on their side against the van wall. Use ratchet straps to secure tall items. Fill gaps between furniture with soft items like bin bags of bedding — movement is what causes damage, so the tighter the pack, the safer your belongings." },
  { question: "Can I pack a fridge freezer in a removal van?", answer: "Yes, but defrost it at least 24 hours before the move. Wipe down the interior and leave the door slightly open overnight to prevent mould. Transport it upright if possible. If it must be tilted, leave it standing at the new property for the same number of hours it was tilted before switching it back on." },
  { question: "How do professional movers pack a van so quickly?", answer: "Practice and system. A professional crew loads hundreds of vans a year. They pre-sort items by weight and size, work in pairs with one person on the van and one carrying, and follow a fixed loading sequence that maximises space. They also have the right equipment — trolleys, ramps, straps, and blankets — which eliminates the fumbling and improvising that slows a DIY move down." },
  { question: "How long does it take to load a removal van?", answer: "For a two-bedroom house with two people loading, expect two to three hours. A three-bedroom house takes three to four hours. Professional removal teams can do it faster because they load hundreds of vans a year and know exactly how to fit everything. The time varies significantly depending on access — flights of stairs, narrow hallways, and long walks to the van all add time." },
  { question: "What is the most common cause of damage during a house move?", answer: "Movement within the van. Items that are not properly secured shift when the van brakes, accelerates, or corners. A wardrobe that falls forward, a mirror that slides, or boxes that topple — these are all caused by inadequate strapping and gaps in the load. The second most common cause is rubbing — two hard surfaces touching without padding between them will scratch each other over even a short journey." },
  { question: "Is it worth hiring professional movers instead of packing the van myself?", answer: "If you have a lot of heavy furniture, fragile items, or limited help on moving day, professional movers are almost always worth it. They bring the right equipment (trolleys, ramps, straps), they know how to protect your belongings, and they are insured. A DIY van load that goes wrong — a dropped washing machine, a scratched bannister, a back injury — costs more than hiring professionals in the first place." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer },
  })),
};

const schema = [articleSchema, faqSchema];
