---
/**
 * Partners: Home Staging & Interior Design
 *
 * B2B page targeting staging companies and interior designers
 * who need careful, punctual furniture handling.
 */

import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config/site.config';
import FAQAccordion from '@/components/FAQAccordion.astro';

// Page metadata
const pageTitle = 'For Home Staging & Interior Design | Painless Removals — Careful Handling Since 1978';
const pageDescription = 'Careful, punctual furniture delivery for staging and interior design professionals. No rushed handling. No damaged pieces. A removal team that treats your furniture like the investment it is.';

// FAQs
const faqs = [
  {
    question: 'Can you do both delivery and collection for a staging cycle?',
    answer: 'Yes. We deliver the furniture before the open house period and collect it afterwards. Both bookings are coordinated at the outset and priced as a package.',
  },
  {
    question: 'What if the furniture is damaged in transit?',
    answer: 'We carry &pound;15,000 insurance per van for goods in transit. For items valued over &pound;2,000, please declare them before the move so they\'re fully covered. In 47 years, our track record speaks for itself &mdash; but the insurance is there for peace of mind.',
  },
  {
    question: 'Do you handle antiques?',
    answer: 'Yes. Antique furniture, art, and fragile decorative items are handled with specialist wrapping and care. We assess each piece during the booking process and brief the team on specific handling requirements.',
  },
  {
    question: 'Can you store staging furniture between rotations?',
    answer: 'Yes. Our Clifton warehouse provides secure, climate-appropriate <a href="/storage-service/" class="text-secondary-500 underline decoration-secondary-300 underline-offset-2 hover:text-secondary-700">storage</a>. Access is by appointment. Monthly rates start from &pound;41 for small units.',
  },
  {
    question: 'How quickly can you turn around a booking?',
    answer: 'For established trade accounts, we can typically accommodate bookings within 3&ndash;5 working days. For urgent requests, call your named contact directly &mdash; we\'ll do our best.',
  },
];

// Schema markup
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Furniture Logistics for Home Staging & Interior Design — Painless Removals Bristol",
  "description": pageDescription,
  "provider": {
    "@type": "MovingCompany",
    "@id": `${siteConfig.brand.domain}/#business`,
    "name": siteConfig.company.name,
    "url": siteConfig.brand.domain,
    "telephone": siteConfig.company.contact.phoneInternational,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Bristol",
      "addressRegion": "Bristol",
      "addressCountry": "GB",
    },
  },
  "areaServed": [
    { "@type": "City", "name": "Bristol" },
    { "@type": "City", "name": "Bath" },
  ],
  "serviceType": "Furniture Logistics for Home Staging & Interior Design",
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer.replace(/<[^>]*>/g, '').replace(/&ndash;/g, '–').replace(/&mdash;/g, '—').replace(/&pound;/g, '£'),
    },
  })),
};

const pageSchema = [serviceSchema, faqSchema];
---

<Layout title={pageTitle} description={pageDescription} schema={pageSchema} noindex>

  <!-- ============================================
       HERO
  ============================================ -->
  <section class="gradient-hero py-12 lg:py-20">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-primary-600 text-sm font-semibold uppercase tracking-wide mb-3">
          For Home Staging & Interior Design
        </p>
        <h1 class="text-3xl lg:text-4xl xl:text-5xl font-bold mb-5">
          Your Furniture Is an Investment. <span class="text-secondary-500">We Treat It Like One.</span>
        </h1>
        <p class="text-lg lg:text-xl text-warm-gray leading-relaxed mb-6 max-w-2xl mx-auto">
          Staging and design professionals need a delivery team that understands careful handling isn't a bonus &mdash; it's the baseline.
        </p>

        <!-- Proof bar -->
        <div class="grid sm:grid-cols-2 gap-3 max-w-xl mx-auto text-left text-sm text-warm-gray mb-8">
          <div class="flex items-start gap-2">
            <span class="text-green-500 mt-0.5 shrink-0">&#10003;</span>
            <span>Specialist wrapping for high-value furniture</span>
          </div>
          <div class="flex items-start gap-2">
            <span class="text-green-500 mt-0.5 shrink-0">&#10003;</span>
            <span>Punctual &mdash; your staging schedule depends on us arriving on time</span>
          </div>
          <div class="flex items-start gap-2">
            <span class="text-green-500 mt-0.5 shrink-0">&#10003;</span>
            <span>Repeat booking rates for regular staging rotations</span>
          </div>
          <div class="flex items-start gap-2">
            <span class="text-green-500 mt-0.5 shrink-0">&#10003;</span>
            <span>Furniture-only moves from 1&ndash;10+ items</span>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/partners/#partner-form" class="btn-cta-orange">
            Set Up a Trade Account
          </a>
          <a href={`tel:${siteConfig.company.contact.phone.replace(/\s/g, '')}`} class="flex items-center gap-2 text-primary-600 font-semibold no-underline hover:text-secondary-500 transition-colors text-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {siteConfig.company.contact.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECTION 1: THE STAGING PROBLEM
  ============================================ -->
  <section class="section bg-cream">
    <div class="container-narrow">
      <h2 class="text-center mb-6">Why Most Removal Companies Don't Work for Staging</h2>
      <div class="space-y-4 text-warm-gray text-lg leading-relaxed">
        <p>
          Your business runs on tight timelines. The property is photographed on Thursday. The open house is Saturday. The furniture needs to arrive Tuesday, be placed precisely by Wednesday afternoon, and collected the following Monday.
        </p>
        <p>
          Most removal companies treat furniture deliveries as filler work between house moves. The crew is whatever's available. The timeline is approximate. And if a &pound;3,000 sofa gets a tear because it was loaded sideways by someone who was rushing to their next job &mdash; well, that's your problem.
        </p>
        <p>
          We don't work that way. Every furniture move gets the same care as a full house move. Items are individually wrapped with blankets and protective materials. The team is briefed on handling requirements. And <strong class="text-primary-600">the delivery window is a commitment, not an estimate</strong>.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECTION 2: WHAT STAGING COMPANIES NEED
  ============================================ -->
  <section class="section bg-white">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="text-2xl lg:text-3xl mb-4">Built for Repeat, High-Value Furniture Handling</h2>
      </div>

      <div class="max-w-3xl mx-auto space-y-4">
        <div class="flex items-start gap-3 text-warm-gray">
          <span class="text-green-500 mt-1 shrink-0">&#10003;</span>
          <span><strong class="text-primary-600">Punctuality matters more than speed.</strong> If you need the furniture at the property by 10am, we're there at 10am. Your staging schedule is coordinated around multiple suppliers and contractors &mdash; we understand that being late cascades.</span>
        </div>
        <div class="flex items-start gap-3 text-warm-gray">
          <span class="text-green-500 mt-1 shrink-0">&#10003;</span>
          <span><strong class="text-primary-600">Careful handling is standard, not premium.</strong> Every item is wrapped in furniture blankets and secured for transit. Legs are protected. Glass is covered. We don't stack sofas on dining tables.</span>
        </div>
        <div class="flex items-start gap-3 text-warm-gray">
          <span class="text-green-500 mt-1 shrink-0">&#10003;</span>
          <span><strong class="text-primary-600">Placement, not just delivery.</strong> We position furniture exactly where you want it. You direct, we place. No "just leave it in the hallway" &mdash; that defeats the purpose.</span>
        </div>
        <div class="flex items-start gap-3 text-warm-gray">
          <span class="text-green-500 mt-1 shrink-0">&#10003;</span>
          <span><strong class="text-primary-600">Flexible crew size.</strong> Some deliveries need one person with a van. Some need a three-person team for a full property staging. We quote based on the actual requirement, not a one-size-fits-all rate.</span>
        </div>
        <div class="flex items-start gap-3 text-warm-gray">
          <span class="text-green-500 mt-1 shrink-0">&#10003;</span>
          <span><strong class="text-primary-600">Repeat booking simplicity.</strong> For regular staging rotations, we set up a standing arrangement. Same crew where possible, same pricing structure, simplified booking. You send a text with the address and date, and it's handled.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECTION 3: INTERIOR DESIGN DELIVERY
  ============================================ -->
  <section class="section bg-cream">
    <div class="container-narrow">
      <h2 class="text-center mb-6">For Interior Designers: Delivering the Pieces That Complete the Project</h2>
      <div class="space-y-4 text-warm-gray text-lg leading-relaxed">
        <p>
          When a client has invested &pound;15,000 in a bespoke dining table and you need it transported from the workshop to a Grade II listed townhouse in Clifton with a narrow staircase and no lift &mdash; you can't use any removal company.
        </p>
        <p>
          We handle high-value, fragile, and oversized furniture for interior designers across Bristol and Bath. Antique pieces, custom-built items, artwork, marble surfaces &mdash; our team knows how to handle materials that don't get a second chance.
        </p>
        <p>
          We also work with designers on full property setups &mdash; delivering, placing, and assembling furniture for new-build installations, renovation completions, and client reveals. If you need 14 pieces delivered from three different suppliers to one property in a single morning, that's a coordination job we're built for.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECTION 4: PRICING
  ============================================ -->
  <section class="section bg-white">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="text-2xl lg:text-3xl mb-4">Clear, Predictable Pricing for Furniture Moves</h2>
        <p class="text-warm-gray text-lg max-w-2xl mx-auto">
          We price furniture moves based on the number of items, whether they require a two-person lift, and the distance involved.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="bg-cream rounded-lg p-6 border border-gray-100 text-center">
          <h3 class="font-bold text-primary-600 mb-1">1&ndash;5 Items</h3>
          <p class="text-sm text-warm-gray mb-2">One person</p>
          <p class="font-heading text-3xl font-bold text-primary-600 mb-2">From ~&pound;200</p>
          <p class="text-xs text-warm-gray">Local, half-day</p>
        </div>
        <div class="bg-cream rounded-lg p-6 border border-gray-100 text-center">
          <h3 class="font-bold text-primary-600 mb-1">6&ndash;10 Items</h3>
          <p class="text-sm text-warm-gray mb-2">Two-person team</p>
          <p class="font-heading text-3xl font-bold text-primary-600 mb-2">From ~&pound;350</p>
          <p class="text-xs text-warm-gray">Local, half-day</p>
        </div>
        <div class="bg-cream rounded-lg p-6 border border-gray-100 text-center">
          <h3 class="font-bold text-primary-600 mb-1">Full Staging</h3>
          <p class="text-sm text-warm-gray mb-2">Delivery & collection</p>
          <p class="font-heading text-3xl font-bold text-primary-600 mb-2">Bespoke</p>
          <p class="text-xs text-warm-gray">Based on property & requirements</p>
        </div>
      </div>

      <p class="text-warm-gray text-center mt-6 max-w-2xl mx-auto text-sm">
        For regular staging clients, we offer a simplified rate structure based on your typical booking profile. No re-quoting every time. Specialist items &mdash; pianos, safes, marble pieces, gym equipment &mdash; require a separate assessment.
      </p>
    </div>
  </section>

  <!-- ============================================
       FAQ
  ============================================ -->
  <FAQAccordion faqs={faqs} heading="Questions Staging & Design Professionals Ask" />

  <!-- ============================================
       FOOTER CTA
  ============================================ -->
  <section class="py-16 md:py-20 bg-primary-600 text-white text-center">
    <div class="container-wide">
      <h2 class="text-white mb-4">Your Furniture Deserves Better Than a Man with a Van</h2>
      <p class="text-primary-100 text-lg mb-8 max-w-xl mx-auto">
        Set up a trade account and get the careful, punctual handling your pieces deserve.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/partners/#partner-form" class="btn-cta-orange inline-block">
          Set Up a Trade Account
        </a>
        <a href={`tel:${siteConfig.company.contact.phone.replace(/\s/g, '')}`} class="flex items-center gap-2 text-white font-semibold no-underline hover:text-primary-200 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {siteConfig.company.contact.phone}
        </a>
      </div>

      <p class="text-sm text-primary-200 mt-8">
        <a href="/partners/" class="text-primary-200 no-underline hover:text-white transition-colors">&larr; Back to all partnerships</a>
      </p>
    </div>
  </section>

</Layout>
