---
/**
 * Partners: Knight Frank Bristol — bespoke partnership landing page
 *
 * Sent by Knight Frank agents to clients they refer to Painless Removals.
 * Functions as both a brand showcase and a callback-request form.
 *
 * Form posts to /api/affiliate/ with referringAgent baked in as
 * "Knight Frank Bristol" — same flow as the standard partner referral
 * (admin notification + auto-intro email to the client).
 *
 * noindex — shared via direct URL, not for search.
 */

import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config/site.config';

const pageTitle = 'Knight Frank Bristol × Painless Removals';
const pageDescription = 'A private moving partnership prepared for Knight Frank Bristol. Discreet, careful, fully insured — since 1978.';

const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const PHONE_DISPLAY = siteConfig.company.contact.phone;
const PHONE_TEL = PHONE_DISPLAY.replace(/\s/g, '');
---

<Layout title={pageTitle} description={pageDescription} noindex={true}>

  <main class="kf">

    <!-- ============================================================
         HERO
    ============================================================ -->
    <section class="kf-hero">
      <div class="kf-hero-inner">
        <div class="kf-hero-copy">
          <div class="kf-eyebrow">A bespoke moving partnership</div>
          <h1 class="kf-h1">
            Your move.<br />
            <em>Handled</em><span class="kf-period">.</span> Painlessly<span class="kf-period">.</span>
          </h1>
          <div class="kf-hero-kicker">Discreet · Careful · Independent since 1978</div>
          <p class="kf-hero-lead">
            For Knight Frank Bristol clients who value their homes, their time,
            and a move that is handled with the same care as the sale itself
            — from first box to the last picture back on the wall.
          </p>

          <div class="kf-hero-cta">
            <a href="#callback" class="kf-btn kf-btn-orange">Request a callback</a>
            <a href={`tel:${PHONE_TEL}`} class="kf-btn-text">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              Or call {PHONE_DISPLAY}
            </a>
          </div>

          <div class="kf-hero-stats">
            <div class="kf-stat">
              <span class="kf-stat-num">1978</span>
              <span class="kf-stat-label">Independent since</span>
            </div>
            <div class="kf-stat-divider"></div>
            <div class="kf-stat">
              <span class="kf-stat-num">2,000+</span>
              <span class="kf-stat-label">Moves led by Jay personally</span>
            </div>
            <div class="kf-stat-divider"></div>
            <div class="kf-stat">
              <span class="kf-stat-num">{siteConfig.company.rating.value}{'★'}</span>
              <span class="kf-stat-label">{siteConfig.company.rating.count} Google reviews</span>
            </div>
          </div>
        </div>

        <aside class="kf-hero-cobrand" aria-label="Prepared for Knight Frank">
          <span class="kf-eyebrow-tiny">Prepared for</span>
          <img src="/img/knight-frank/knight-frank-logo.svg" alt="Knight Frank" class="kf-cobrand-logo" />
        </aside>
      </div>
    </section>

    <!-- ============================================================
         TRUST STRIP
    ============================================================ -->
    <section class="kf-trust">
      <div class="kf-trust-inner">
        <div class="kf-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 2 3 5v6c0 5 3.8 9.4 9 11 5.2-1.6 9-6 9-11V5l-9-3z"/><path d="m9 12 2 2 4-4"/></svg>
          <div>
            <div class="kf-trust-title">Fully Insured</div>
            <div class="kf-trust-text">{'£'}15k per van, with specialist cover available on request</div>
          </div>
        </div>
        <div class="kf-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="8" r="5"/><path d="m8.2 12.5-2 8L12 18l5.8 2.5-2-8"/></svg>
          <div>
            <div class="kf-trust-title">Accredited</div>
            <div class="kf-trust-text">Move Assured · AIM member</div>
          </div>
        </div>
        <div class="kf-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M8 10h8M8 14h6"/><path d="m15 17 2 2 4-4"/></svg>
          <div>
            <div class="kf-trust-title">Direct Line</div>
            <div class="kf-trust-text">Same name, same number, start to finish</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         INTRODUCTION
    ============================================================ -->
    <section class="kf-section kf-intro">
      <div class="kf-narrow">
        <div class="kf-eyebrow-center">A bespoke partnership</div>
        <h2 class="kf-h2 kf-center">
          Knight Frank introduced you to us. <em>That tells us</em> something already.
        </h2>
        <p class="kf-lead">
          From the first call to the last picture back on the wall, you'll
          deal with one named person from start to finish. The quote is
          fixed at survey, the property protected at both ends, and yours
          is the only move we'll book that day. Your time stays your own.
        </p>
      </div>
    </section>

    <!-- ============================================================
         THREE TIERS
    ============================================================ -->
    <section class="kf-section kf-tiers-section">
      <div class="kf-wide">
        <div class="kf-section-head">
          <div>
            <div class="kf-eyebrow">Three Levels of Service</div>
            <h2 class="kf-h2">The right level of care<br />for <em>every Bristol move.</em></h2>
          </div>
          <div class="kf-section-head-note">
            Every package includes a dedicated Move Manager, a fixed quote on survey,
            and full protection of the property at both ends.
          </div>
        </div>

        <div class="kf-tiers">

          <!-- Tier 1: Removal -->
          <article class="kf-tier">
            <div class="kf-tier-image">
              <img src="/img/knight-frank/tier-removal.webp" alt="Painless Removals crew loading a van in Bristol" loading="lazy" />
            </div>
            <div class="kf-tier-body">
              <div class="kf-tier-label">Level One</div>
              <h3 class="kf-tier-h3">Painless <em>Removal</em></h3>
              <p class="kf-tier-lead">You pack. We handle everything from the doorstep onward — properly, carefully, on time.</p>
              <ul class="kf-tier-list">
                <li>Dedicated Move Manager &amp; trusted in-house crew</li>
                <li>Loading, transport &amp; unloading by our own team</li>
                <li>Furniture disassembly &amp; reassembly included</li>
                <li>Sofa covers, mattress protectors, TV &amp; picture bags as standard</li>
                <li>{'£'}15,000 Goods-in-Transit cover per van</li>
              </ul>
              <div class="kf-tier-foot">
                <strong>Ideal for</strong>
                Straightforward chains and confident self-packers who still want a proper, insured, uniformed crew on the day.
              </div>
            </div>
          </article>

          <!-- Tier 2: Packing (featured) -->
          <article class="kf-tier kf-tier-featured">
            <div class="kf-tier-ribbon">Most Requested</div>
            <div class="kf-tier-image">
              <img src="/img/knight-frank/tier-packing.webp" alt="Painless Removals professional packing service" loading="lazy" />
            </div>
            <div class="kf-tier-body">
              <div class="kf-tier-label">Level Two</div>
              <h3 class="kf-tier-h3">Painless <em>Packing</em></h3>
              <p class="kf-tier-lead">We pack, we move, we unpack. You arrive at the other end to a home, not a houseful of boxes.</p>
              <ul class="kf-tier-list">
                <li>Everything in Painless Removal</li>
                <li>Full professional packing — fragile, wardrobe, kitchen, loft</li>
                <li>Specialist handling for artwork, mirrors &amp; glass</li>
                <li>Unpack &amp; placement at destination</li>
                <li>Packed items covered under transit insurance</li>
              </ul>
              <div class="kf-tier-foot">
                <strong>Ideal for</strong>
                Busy families, downsizers, and anyone whose time is worth more than a weekend of packing boxes.
              </div>
            </div>
          </article>

          <!-- Tier 3: VIP -->
          <article class="kf-tier">
            <div class="kf-tier-image">
              <img src="/img/knight-frank/tier-vip.webp" alt="Painless Removals VIP concierge service" loading="lazy" />
            </div>
            <div class="kf-tier-body">
              <div class="kf-tier-label">Level Three</div>
              <h3 class="kf-tier-h3">Painless <em>VIP</em></h3>
              <p class="kf-tier-lead">Our full white-glove service, with a concierge built in. The only thing you have to do is turn the key.</p>
              <ul class="kf-tier-list">
                <li>Everything in Painless Packing</li>
                <li>Concierge: address changes and supplier handover</li>
                <li>Utilities, broadband and deliveries coordinated for your arrival</li>
                <li>High-value specialist cover arranged when needed</li>
                <li>Weekend, early-morning &amp; evening moves included</li>
              </ul>
              <div class="kf-tier-foot">
                <strong>Ideal for</strong>
                Those who want the smoothest possible passage from one home to the next. We take care of the move and everything around it — the admin, the supplier handovers, the new-home set-up — so nothing falls on you.
              </div>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- ============================================================
         SPECIALIST BAND
    ============================================================ -->
    <section class="kf-specialist">
      <div class="kf-specialist-inner">
        <div>
          <div class="kf-band-label">For what matters most</div>
          <h3 class="kf-specialist-h3">Specialist handling for <em>valuables, antiques &amp; period homes.</em></h3>
        </div>
        <div>
          <p class="kf-specialist-p">
            We've packed grand pianos, antique clocks, vintage wine collections
            and family heirlooms passed down through generations. High-value
            specialist cover arranged on request — underwritten beyond
            our standard policy, for the items and addresses that need it.
          </p>
        </div>
        <div class="kf-specialist-items">
          <div>Fine art &amp; framed works</div>
          <div>Antique furniture</div>
          <div>Grand &amp; upright pianos</div>
          <div>Wine cellars</div>
          <div>Georgian &amp; listed homes</div>
          <div>Narrow access &amp; cranes</div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         WHY + HOW
    ============================================================ -->
    <section class="kf-bottom-grid">

      <div class="kf-why">
        <h2 class="kf-h2">What Bristol clients<br /><em>say</em> about us.</h2>
        <div class="kf-gold-hair"></div>

        <blockquote class="kf-quote">
          <p>"They did what it says on the tin — made the whole process very painless. Friendly, efficient, the whole experience was effortless."</p>
          <cite>Ellen J. · Clifton, BS8</cite>
        </blockquote>

        <blockquote class="kf-quote">
          <p>"Prompt and professional from the initial quote through to the end of the removal. We went for the full packing package — painless from start to finish."</p>
          <cite>James &amp; Victoria W. · Redland, BS6</cite>
        </blockquote>

        <blockquote class="kf-quote">
          <p>"Couldn't recommend them more. Very kind, very efficient. They go above and beyond."</p>
          <cite>Charles H. · Sneyd Park, BS9</cite>
        </blockquote>

        <div class="kf-reviews-badge">
          <div class="kf-stars">{'★★★★★'}</div>
          <div>
            <div class="kf-score">{siteConfig.company.rating.value} / 5</div>
            <div class="kf-score-meta">{siteConfig.company.rating.count} verified Google reviews</div>
          </div>
        </div>
      </div>

      <div class="kf-how">
        <div class="kf-how-head">
          <h2 class="kf-h2">How we make it <em>simple</em><br />for you.</h2>
          <div class="kf-gold-hair"></div>
        </div>

        <div class="kf-steps">
          <div class="kf-step">
            <div class="kf-step-num">1</div>
            <div class="kf-step-title">Introduction</div>
            <p>An introductory call. We listen first, then we ask the right questions.</p>
          </div>
          <div class="kf-step">
            <div class="kf-step-num">2</div>
            <div class="kf-step-title">Home Survey</div>
            <p>We visit the property. Fixed, bespoke quote in a day.</p>
          </div>
          <div class="kf-step">
            <div class="kf-step-num">3</div>
            <div class="kf-step-title">Move Day</div>
            <p>Our own crew — on time, in uniform, calm and methodical.</p>
          </div>
          <div class="kf-step">
            <div class="kf-step-num">4</div>
            <div class="kf-step-title">Settled In</div>
            <p>Everything placed and put away. You're home — not camped in your own house.</p>
          </div>
        </div>

        <div class="kf-jay">
          <div class="kf-jay-avatar">
            <img src="/img/knight-frank/jay-newton.webp" alt="Jay Newton, Director, Painless Removals" />
          </div>
          <div class="kf-jay-body">
            <div class="kf-jay-mark">"</div>
            <p>The move stays firmly in our hands, so you can think about everything else moving day involves, and trust us with the rest.</p>
            <cite>Jay Newton — Director, Painless Removals</cite>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         CALLBACK FORM
    ============================================================ -->
    <section class="kf-callback" id="callback">
      <div class="kf-narrow">
        <div class="kf-callback-card">
          <div class="kf-callback-head">
            <div class="kf-eyebrow">Request a callback</div>
            <h2 class="kf-h2">Knight Frank introduced you. <em>We'll take it from here.</em></h2>
            <p class="kf-callback-lead">
              Leave your details below and we'll be in touch as soon as
              possible to arrange a home survey at a time that suits you.
              There's no
              commitment at this stage — we'd just like to introduce ourselves
              properly. Mon–Fri, 9am–5pm; weekends on request.
            </p>
          </div>

          <!-- Success state (hidden by default) -->
          <div id="kf-form-success" class="kf-form-success" hidden>
            <div class="kf-success-mark">{'✓'}</div>
            <h3 class="kf-h3">Thank you — we have your details.</h3>
            <p>You'll hear from us shortly. If it's urgent, please call <a href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a>.</p>
          </div>

          <form id="kf-form" class="kf-form" novalidate data-phone={PHONE_DISPLAY}>
            <!-- Honeypot -->
            <div class="kf-honeypot" aria-hidden="true">
              <label for="kf-website">Leave this blank</label>
              <input type="text" id="kf-website" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <div class="kf-field">
              <label for="kf-name">Your full name <span class="kf-req">*</span></label>
              <input type="text" id="kf-name" name="clientName" required autocomplete="name" placeholder="e.g. James Whitfield" />
            </div>

            <div class="kf-field-row">
              <div class="kf-field">
                <label for="kf-phone">Phone <span class="kf-req">*</span></label>
                <input type="tel" id="kf-phone" name="clientPhone" required autocomplete="tel" placeholder="07… or 0117…" />
              </div>
              <div class="kf-field">
                <label for="kf-email">Email <span class="kf-req">*</span></label>
                <input type="email" id="kf-email" name="clientEmail" required autocomplete="email" placeholder="you@example.com" />
              </div>
            </div>

            <label class="kf-consent">
              <input type="checkbox" id="kf-consent" name="gdprConsent" required />
              <span>
                I'm happy for Painless Removals to contact me about my move.
                <span class="kf-req">*</span>
              </span>
            </label>

            <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="light" data-language="en"></div>

            <div id="kf-form-error" class="kf-form-error" hidden></div>

            <div class="kf-form-cta">
              <button type="submit" id="kf-submit" class="kf-btn kf-btn-orange kf-btn-wide">Request my callback</button>
              <p class="kf-form-or">
                Or speak to us now on <a href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a>
              </p>
            </div>
          </form>
        </div>
      </div>
    </section>

    <!-- ============================================================
         FINAL BANNER
    ============================================================ -->
    <section class="kf-banner">
      <div class="kf-banner-diamond" aria-hidden="true"></div>
      <h3 class="kf-banner-h3">Careful hands. Calm minds. <em>Better moves.</em></h3>
      <p class="kf-banner-p">
        We know how important your home and time are — and that a Knight Frank
        recommendation is never given lightly. That's why we treat every move as if
        it were our own.
      </p>
      <a href={`tel:${PHONE_TEL}`} class="kf-banner-cta">
        <span>Book a free survey</span>
        <span class="kf-banner-cta-num">{PHONE_DISPLAY}</span>
      </a>
    </section>

  </main>

  <!-- Cloudflare Turnstile -->
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <!-- Form submission -->
  <script is:inline>
    (function () {
      var form = document.getElementById('kf-form');
      if (!form) return;

      var PHONE = (form.dataset.phone || '0117 287 0082');
      var errorEl = document.getElementById('kf-form-error');
      var submitBtn = document.getElementById('kf-submit');
      var successEl = document.getElementById('kf-form-success');

      function showError(msg) {
        errorEl.textContent = msg;
        errorEl.hidden = false;
        if (window.showToast) window.showToast(msg, 'error');
      }

      function clearError() {
        errorEl.hidden = true;
        errorEl.textContent = '';
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        clearError();

        var clientName = form.querySelector('#kf-name').value.trim();
        var clientPhone = form.querySelector('#kf-phone').value.trim();
        var clientEmail = form.querySelector('#kf-email').value.trim();
        var gdprConsent = form.querySelector('#kf-consent').checked;
        var honeypot = form.querySelector('#kf-website').value;

        if (!clientName) { showError('Please enter your full name.'); return; }
        if (!clientPhone) { showError('Please enter a phone number we can reach you on.'); return; }
        if (!clientEmail) { showError('Please enter your email address.'); return; }
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(clientEmail)) { showError('That email address doesn\'t look right — please double-check it.'); return; }
        if (!gdprConsent) { showError('Please tick the consent box so we know you\'re happy for us to be in touch.'); return; }

        var turnstileToken = '';
        var tsInput = form.querySelector('[name="cf-turnstile-response"]');
        if (tsInput) turnstileToken = tsInput.value;
        if (!turnstileToken) { showError('Please complete the security check before submitting.'); return; }

        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending…';

        var referringAgent = 'Knight Frank Bristol';

        fetch('/api/affiliate/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            referringAgent: referringAgent,
            clientName: clientName,
            clientPhone: clientPhone,
            clientEmail: clientEmail,
            gdprConsent: true,
            honeypot: honeypot,
            turnstileToken: turnstileToken,
          }),
        })
          .then(function (res) {
            return res.json().catch(function () { throw new Error('Server returned ' + res.status); });
          })
          .then(function (data) {
            if (data && data.success) {
              // Analytics-only event (NOT a conversion). event_id satisfies tracking rule #2.
              var eventId = (window.crypto && window.crypto.randomUUID)
                ? window.crypto.randomUUID()
                : ('id-' + Date.now() + '-' + Math.random().toString(36).slice(2));
              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push({
                event: 'form_submission',
                event_id: eventId,
                form_name: 'knight_frank_callback',
                form_source: 'partners-knight-frank',
              });

              form.hidden = true;
              successEl.hidden = false;
              successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
            } else {
              showError((data && data.error) || ('Something went wrong. Please try again or call us on ' + PHONE + '.'));
              submitBtn.disabled = false;
              submitBtn.textContent = 'Request my callback';
              if (window.turnstile) window.turnstile.reset();
            }
          })
          .catch(function () {
            showError('Connection error — please check your internet and try again, or call us on ' + PHONE + '.');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Request my callback';
          });
      });
    })();
  </script>

</Layout>

<style>
  /* ==============================================================
     Knight Frank × Painless — scoped premium aesthetic
     Re-uses existing site fonts (Fraunces / DM Sans) and brand
     gold (--color-accent-500) but darkens the petrol blue locally.
  ============================================================== */
  .kf {
    --kf-petrol: #0E3C54;
    --kf-petrol-deep: #0A2F41;
    --kf-petrol-mid: #165978;
    --kf-orange: #F16B21;
    --kf-orange-dark: #D85818;
    --kf-gold: #D4A84B;
    --kf-gold-soft: #C8A05C;
    --kf-gold-light: #F5E6C8;
    --kf-cream: #FAF7F2;
    --kf-cream-deep: #F2ECE0;
    --kf-paper: #FFFFFF;
    --kf-ink: #1B2A38;
    --kf-muted: #5C6470;
    --kf-line: #E0D6C4;

    --kf-serif: 'Fraunces', Georgia, 'Times New Roman', serif;
    --kf-sans: 'DM Sans', system-ui, sans-serif;

    background: var(--kf-cream);
    color: var(--kf-ink);
    font-family: var(--kf-sans);
    line-height: 1.55;
  }

  /* ---- HERO ---- */
  .kf-hero {
    position: relative;
    overflow: hidden;
    color: var(--kf-cream);
    background:
      radial-gradient(120% 80% at 20% 20%, rgba(212, 168, 75, 0.18) 0%, rgba(212, 168, 75, 0) 55%),
      linear-gradient(145deg, var(--kf-petrol-deep) 0%, var(--kf-petrol-mid) 45%, var(--kf-petrol) 100%);
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .kf-hero::before {
    content: "1978";
    position: absolute;
    right: -30px;
    top: 30px;
    font-family: var(--kf-serif);
    font-weight: 500;
    font-size: clamp(180px, 24vw, 360px);
    line-height: 0.8;
    color: rgba(212, 168, 75, 0.07);
    letter-spacing: -0.04em;
    pointer-events: none;
  }
  .kf-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px);
    background-size: 4px 4px;
    pointer-events: none;
  }
  .kf-hero-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(40px, 6vh, 80px) 28px clamp(40px, 6vh, 90px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 48px;
    align-items: end;
  }
  .kf-hero-copy { max-width: 720px; }
  .kf-hero-cobrand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
    padding: 22px 28px;
    border-left: 2px solid var(--kf-gold);
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(2px);
    position: relative;
    z-index: 3;
  }
  .kf-eyebrow-tiny {
    color: var(--kf-gold);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .kf-cobrand-logo {
    height: 36px;
    width: auto;
    filter: brightness(0) invert(1) brightness(0.96);
  }
  .kf-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--kf-gold);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 22px;
  }
  .kf-eyebrow::before {
    content: "";
    width: 32px;
    height: 1px;
    background: var(--kf-gold);
  }
  .kf-h1 {
    margin: 0 0 18px;
    font-family: var(--kf-serif);
    font-size: clamp(40px, 6vw, 76px);
    line-height: 1.04;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--kf-cream);
  }
  .kf-h1 em {
    font-style: italic;
    color: var(--kf-gold);
    font-weight: 400;
  }
  .kf-h1 .kf-period {
    color: var(--kf-orange);
    font-style: normal;
  }
  .kf-hero-kicker {
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 12px;
    color: rgba(245, 230, 200, 0.85);
    margin-bottom: 22px;
  }
  .kf-hero-lead {
    margin: 0 0 32px;
    max-width: 560px;
    font-size: 17px;
    line-height: 1.65;
    color: rgba(250, 247, 242, 0.9);
  }
  .kf-hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 22px;
    align-items: center;
    margin-bottom: 40px;
  }
  .kf-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px 30px;
    font-family: var(--kf-sans);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  }
  .kf-btn-orange {
    background: var(--kf-orange);
    color: var(--kf-cream);
    box-shadow: 0 12px 28px rgba(241, 107, 33, 0.35);
  }
  .kf-btn-orange:hover {
    background: var(--kf-orange-dark);
    transform: translateY(-2px);
    box-shadow: 0 16px 36px rgba(241, 107, 33, 0.45);
  }
  .kf-btn-wide { width: 100%; }
  .kf-btn-text {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--kf-gold-light);
    font-size: 14px;
    text-decoration: none;
    letter-spacing: 0.04em;
  }
  .kf-btn-text:hover { color: var(--kf-gold); }
  .kf-btn-text svg { width: 18px; height: 18px; color: var(--kf-gold); }

  .kf-hero-stats {
    display: flex;
    gap: 28px;
    align-items: center;
    padding-top: 28px;
    border-top: 1px solid rgba(212, 168, 75, 0.24);
    max-width: 620px;
    flex-wrap: wrap;
  }
  .kf-stat { display: flex; flex-direction: column; gap: 2px; }
  .kf-stat-num {
    font-family: var(--kf-serif);
    font-size: 30px;
    font-weight: 500;
    color: var(--kf-gold);
    line-height: 1;
  }
  .kf-stat-label {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(245, 230, 200, 0.8);
  }
  .kf-stat-divider {
    width: 1px;
    height: 32px;
    background: rgba(212, 168, 75, 0.3);
  }

  /* ---- TRUST STRIP ---- */
  .kf-trust {
    background: var(--kf-petrol-deep);
    color: var(--kf-cream);
    border-top: 1px solid rgba(212, 168, 75, 0.2);
    border-bottom: 1px solid rgba(212, 168, 75, 0.2);
  }
  .kf-trust-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 22px 28px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    justify-items: start;
  }
  .kf-trust-item {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .kf-trust-item svg {
    width: 32px;
    height: 32px;
    flex: 0 0 32px;
    color: var(--kf-gold);
  }
  .kf-trust-title {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--kf-gold-light);
    margin-bottom: 2px;
  }
  .kf-trust-text {
    font-size: 13px;
    color: rgba(250, 247, 242, 0.85);
  }

  /* ---- SECTIONS ---- */
  .kf-section {
    padding: 90px 28px;
  }
  .kf-narrow {
    max-width: 760px;
    margin: 0 auto;
  }
  .kf-wide {
    max-width: 1280px;
    margin: 0 auto;
  }
  .kf-h2 {
    font-family: var(--kf-serif);
    font-size: clamp(28px, 3.4vw, 46px);
    line-height: 1.06;
    font-weight: 400;
    color: var(--kf-petrol);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }
  .kf-h2 em {
    font-style: italic;
    color: var(--kf-orange);
    font-weight: 400;
  }
  .kf-h3 {
    font-family: var(--kf-serif);
    font-size: 22px;
    font-weight: 500;
    color: var(--kf-petrol);
    margin: 0 0 8px;
  }
  .kf-center { text-align: center; }
  .kf-eyebrow-center {
    display: block;
    text-align: center;
    color: var(--kf-orange);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 14px;
  }
  .kf-lead {
    color: var(--kf-muted);
    font-size: 18px;
    line-height: 1.7;
    text-align: center;
    margin: 18px 0 0;
  }

  .kf-intro { background: var(--kf-paper); }

  /* ---- TIERS ---- */
  .kf-tiers-section {
    background: var(--kf-cream);
    border-top: 1px solid var(--kf-line);
    border-bottom: 1px solid var(--kf-line);
  }
  .kf-section-head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 36px;
    align-items: end;
    margin-bottom: 48px;
  }
  .kf-section-head-note {
    font-size: 14px;
    line-height: 1.5;
    color: var(--kf-muted);
    max-width: 320px;
    font-style: italic;
    text-align: right;
    padding-right: 22px;
    border-right: 1px solid var(--kf-gold);
  }
  .kf-tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .kf-tier {
    background: var(--kf-paper);
    border: 1px solid var(--kf-line);
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .kf-tier:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 60px rgba(14, 60, 84, 0.12);
  }
  .kf-tier-featured {
    border: 1.5px solid var(--kf-orange);
    background: linear-gradient(180deg, #FFFBF6 0%, #FFFFFF 100%);
    box-shadow: 0 22px 56px rgba(241, 107, 33, 0.16);
    transform: translateY(-8px);
  }
  .kf-tier-featured:hover { transform: translateY(-12px); }
  .kf-tier-image {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--kf-petrol);
  }
  .kf-tier-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.96);
    transition: transform 0.5s ease;
  }
  .kf-tier:hover .kf-tier-image img { transform: scale(1.04); }
  .kf-tier-image::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(14, 60, 84, 0) 50%, rgba(14, 60, 84, 0.25) 100%);
    pointer-events: none;
  }
  .kf-tier-ribbon {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 2;
    background: var(--kf-orange);
    color: var(--kf-cream);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 8px 14px;
    box-shadow: 0 4px 12px rgba(14, 60, 84, 0.3);
  }
  .kf-tier-body {
    padding: 30px 32px 34px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .kf-tier-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--kf-gold-soft);
    margin-bottom: 10px;
  }
  .kf-tier-featured .kf-tier-label { color: var(--kf-orange); }
  .kf-tier-h3 {
    font-family: var(--kf-serif);
    font-size: 28px;
    font-weight: 500;
    line-height: 1.1;
    color: var(--kf-petrol);
    margin: 0 0 10px;
    letter-spacing: -0.01em;
  }
  .kf-tier-h3 em {
    font-style: italic;
    color: var(--kf-orange);
  }
  .kf-tier-lead {
    font-size: 14px;
    line-height: 1.6;
    color: var(--kf-muted);
    margin: 0 0 18px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--kf-line);
  }
  .kf-tier-list {
    list-style: none;
    padding: 0;
    margin: 0 0 22px;
    flex: 1;
  }
  .kf-tier-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 9px 0;
    color: var(--kf-ink);
    font-size: 14px;
    line-height: 1.55;
  }
  .kf-tier-list li::before {
    content: "";
    flex: 0 0 14px;
    width: 14px;
    height: 1px;
    background: var(--kf-gold);
    margin-top: 0.7em;
  }
  .kf-tier-foot {
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px dashed var(--kf-line);
    font-size: 12.5px;
    color: var(--kf-muted);
    line-height: 1.5;
  }
  .kf-tier-foot strong {
    display: block;
    color: var(--kf-petrol);
    font-family: var(--kf-serif);
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 4px;
  }
  .kf-tier-featured .kf-tier-foot strong { color: var(--kf-orange); }

  /* ---- SPECIALIST BAND ---- */
  .kf-specialist {
    background: var(--kf-petrol-deep);
    color: var(--kf-cream);
    padding: 60px 28px;
    border-top: 3px solid var(--kf-gold);
    position: relative;
    overflow: hidden;
  }
  .kf-specialist::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(80% 50% at 80% 100%, rgba(212, 168, 75, 0.08), transparent);
    pointer-events: none;
  }
  .kf-specialist-inner {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .kf-band-label {
    color: var(--kf-gold);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 12px;
  }
  .kf-specialist-h3 {
    font-family: var(--kf-serif);
    font-size: 28px;
    line-height: 1.2;
    font-weight: 400;
    color: var(--kf-cream);
    margin: 0;
  }
  .kf-specialist-h3 em {
    color: var(--kf-gold);
    font-style: italic;
  }
  .kf-specialist-p {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(250, 247, 242, 0.86);
    margin: 0;
  }
  .kf-specialist-items {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px 22px;
  }
  .kf-specialist-items div {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 13px;
    letter-spacing: 0.04em;
    padding: 10px 0;
    border-bottom: 1px solid rgba(212, 168, 75, 0.18);
    color: rgba(250, 247, 242, 0.94);
  }
  .kf-specialist-items div::before {
    content: "";
    flex: 0 0 10px;
    width: 10px;
    height: 1px;
    background: var(--kf-gold);
    margin-top: 0.7em;
  }

  /* ---- WHY + HOW ---- */
  .kf-bottom-grid {
    display: grid;
    grid-template-columns: 1fr 1.25fr;
    background: var(--kf-paper);
    border-top: 1px solid var(--kf-line);
  }
  .kf-why {
    padding: 80px 56px;
    border-right: 1px solid var(--kf-line);
    display: flex;
    flex-direction: column;
  }
  .kf-how {
    padding: 80px 56px;
    background: var(--kf-cream);
    display: flex;
    flex-direction: column;
  }
  .kf-gold-hair {
    width: 56px;
    height: 2px;
    background: var(--kf-gold);
    margin: 18px 0 28px;
  }
  .kf-quote {
    border-left: 3px solid var(--kf-gold);
    padding: 4px 0 4px 20px;
    margin: 0 0 24px;
  }
  .kf-quote p {
    font-family: var(--kf-serif);
    font-style: italic;
    font-size: 17px;
    line-height: 1.55;
    color: var(--kf-petrol);
    margin: 0 0 10px;
  }
  .kf-quote cite {
    font-style: normal;
    font-family: var(--kf-sans);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--kf-orange);
    font-weight: 600;
  }
  .kf-reviews-badge {
    margin-top: auto;
    padding: 18px 22px;
    background: var(--kf-cream);
    border: 1px solid var(--kf-line);
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .kf-stars {
    color: var(--kf-gold);
    font-size: 18px;
    letter-spacing: 2px;
  }
  .kf-score {
    font-family: var(--kf-serif);
    font-size: 24px;
    font-weight: 500;
    color: var(--kf-petrol);
    line-height: 1;
  }
  .kf-score-meta {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--kf-muted);
    margin-top: 4px;
  }
  .kf-how-head { margin-bottom: 12px; }
  .kf-steps {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px 32px;
    margin: 24px 0 36px;
  }
  .kf-step-num {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--kf-paper);
    border: 1.5px solid var(--kf-gold);
    color: var(--kf-orange);
    display: grid;
    place-items: center;
    font-family: var(--kf-serif);
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 16px;
  }
  .kf-step-title {
    font-family: var(--kf-serif);
    font-size: 17px;
    font-weight: 600;
    color: var(--kf-petrol);
    margin-bottom: 6px;
  }
  .kf-step p {
    margin: 0;
    color: var(--kf-muted);
    font-size: 13.5px;
    line-height: 1.55;
  }
  .kf-jay {
    background: var(--kf-paper);
    border: 1px solid var(--kf-line);
    padding: 30px 32px;
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 24px;
    align-items: start;
    position: relative;
  }
  .kf-jay-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 2px solid var(--kf-gold);
    overflow: hidden;
    background: var(--kf-petrol);
  }
  .kf-jay-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .kf-jay-mark {
    position: absolute;
    top: 12px;
    right: 22px;
    font-family: var(--kf-serif);
    font-size: 80px;
    line-height: 1;
    color: var(--kf-gold);
    opacity: 0.22;
  }
  .kf-jay-body p {
    font-family: var(--kf-serif);
    font-style: italic;
    font-size: 16px;
    line-height: 1.55;
    color: var(--kf-petrol);
    margin: 0 0 12px;
  }
  .kf-jay-body cite {
    font-style: normal;
    font-family: var(--kf-sans);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--kf-orange);
    font-weight: 700;
  }

  /* ---- CALLBACK FORM ---- */
  .kf-callback {
    background: var(--kf-cream-deep);
    padding: 90px 28px;
    border-top: 1px solid var(--kf-line);
  }
  .kf-callback-card {
    background: var(--kf-paper);
    border: 1px solid var(--kf-line);
    box-shadow: 0 30px 80px rgba(14, 60, 84, 0.10);
    padding: 56px 56px 52px;
    position: relative;
  }
  .kf-callback-card::before {
    content: "";
    position: absolute;
    left: 0;
    top: 32px;
    bottom: 32px;
    width: 3px;
    background: linear-gradient(to bottom, transparent, var(--kf-gold) 18%, var(--kf-gold) 82%, transparent);
    opacity: 0.6;
  }
  .kf-callback-head { margin-bottom: 36px; }
  .kf-callback-head .kf-eyebrow { color: var(--kf-orange); margin-bottom: 16px; }
  .kf-callback-head .kf-eyebrow::before { background: var(--kf-orange); }
  .kf-callback-lead {
    color: var(--kf-muted);
    font-size: 16px;
    line-height: 1.65;
    margin: 14px 0 0;
  }

  .kf-form { display: flex; flex-direction: column; gap: 22px; }
  .kf-honeypot { position: absolute; left: -9999px; }
  .kf-field { display: flex; flex-direction: column; gap: 8px; }
  .kf-field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
  }
  .kf-field label {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--kf-petrol);
  }
  .kf-req { color: var(--kf-orange); }
  .kf-optional {
    font-weight: 400;
    color: var(--kf-muted);
    text-transform: none;
    letter-spacing: 0.02em;
    font-size: 11px;
  }
  .kf-field input,
  .kf-field textarea {
    font-family: var(--kf-sans);
    font-size: 16px;
    color: var(--kf-ink);
    background: var(--kf-cream);
    border: 1px solid var(--kf-line);
    border-radius: 0;
    padding: 14px 16px;
    transition: border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
  }
  .kf-field input:focus,
  .kf-field textarea:focus {
    outline: none;
    background: var(--kf-paper);
    border-color: var(--kf-petrol);
    box-shadow: 0 0 0 3px rgba(14, 60, 84, 0.12);
  }
  .kf-field textarea { resize: vertical; min-height: 90px; }
  .kf-consent {
    display: flex;
    gap: 12px;
    align-items: center;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--kf-muted);
  }
  .kf-consent input { flex: 0 0 auto; }
  .kf-form-error {
    background: #FDECEA;
    border: 1px solid #E8B6B0;
    color: #8A2B1E;
    padding: 12px 16px;
    font-size: 14px;
    line-height: 1.5;
  }
  .kf-form-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    margin-top: 6px;
  }
  .kf-form-or {
    margin: 0;
    font-size: 13px;
    color: var(--kf-muted);
  }
  .kf-form-or a {
    color: var(--kf-petrol);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid var(--kf-gold);
  }

  .kf-form-success {
    text-align: center;
    padding: 24px 8px;
  }
  .kf-success-mark {
    width: 64px;
    height: 64px;
    margin: 0 auto 18px;
    border-radius: 50%;
    background: var(--kf-petrol);
    color: var(--kf-gold);
    display: grid;
    place-items: center;
    font-size: 28px;
    font-weight: 700;
  }
  .kf-form-success p {
    color: var(--kf-muted);
