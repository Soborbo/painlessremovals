      box-shadow: 0 2px 6px rgb(198 93 59 / 0.35), 0 0 0 10px rgba(198, 93, 59, 0);
    }
  }
  /* Pulse ring expands and fades — mid keyframe stops at 0.18 alpha then fades */
  .ea-card-primary .ea-card-badge::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    box-shadow: 0 0 0 0 rgba(198, 93, 59, 0.55);
