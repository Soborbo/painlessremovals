    left: 50%;
    transform: translateX(-150%);
    width: 220px;
    height: 130px;
    pointer-events: none;
    z-index: 1;
  }
  /* Continuously flow the dashes toward the arrowhead — pulls the eye downward */
  .ea-curved-arrow path:first-child {
    animation: ea-arrow-flow 1.4s linear infinite;
  }
  @keyframes ea-arrow-flow {
    to { stroke-dashoffset: -20; }
  }
  /* Subtle bob on the arrowhead so it feels alive */
  .ea-curved-arrow path:nth-child(2) {
    transform-origin: 30px 110px;
    animation: ea-arrow-bob 2.2s ease-in-out infinite;
  }
  @keyframes ea-arrow-bob {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-1px, 2px); }
