---
/**
 * Partners: Estate Agents & Property Professionals
 *
 * B2B page targeting estate agents, earn referral fees,
 * branded materials, same-day callback. Agent-centric framing.
 * Redesigned to match service page patterns with high-conversion layout.
 */

import Layout from '@/layouts/Layout.astro';
import UspBar from '@/components/UspBar.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';
import FinalCTA from '@/components/FinalCTA.astro';
import OptimizedPicture from '@/components/OptimizedPicture.astro';
import { siteConfig } from '@/config/site.config';

// Page metadata
const pageTitle = 'For Estate Agents | Painless Removals, Chain Move Specialists Since 1978';
const pageDescription = 'A removal partner your clients will thank you for recommending. Branded materials, same-day callback on agent referrals, and a referral fee on every completed move. Since 1978.';

const reviewCount = siteConfig.company.rating.count;
const yearsSince1978 = new Date().getFullYear() - 1978;
const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;

// "One Introduction" steps \u2014 reuses the HowItWorksHome layout for visual consistency with the rest of the site
const introSteps = [
  {
    icon: '<path d="M16 11c1.66 0 3-1.34 3-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3z"/><path d="M8 11c1.66 0 3-1.34 3-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3z"/><path d="M2 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/>',
    title: 'You mention us',
    description: 'At a viewing, at exchange, whenever it feels natural. Hand over a moving guide, drop our name, or send the quote link. That is the only step that needs you.',
  },
  {
    icon: '<path d="M3 5a2 2 0 0 1 2-2h3.28a1 1 0 0 1 .948.684l1.498 4.493a1 1 0 0 1-.502 1.21l-2.257 1.13a11.042 11.042 0 0 0 5.516 5.516l1.13-2.257a1 1 0 0 1 1.21-.502l4.493 1.498a1 1 0 0 1 .684.949V19a2 2 0 0 1-2 2h-1C9.716 21 3 14.284 3 6V5z"/>',
    title: 'Same-day response',
    description: 'Your client hears from us the same working day. From there we book in a quick video survey or call before sending the personalised quote, no pressure, no aggressive follow-up.',
  },
  {
    icon: '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',
    title: 'Our Move Manager takes over',
    description: 'One named person on our team handles everything from quote through completion day. Your client calls us, not your office, when they have a question.',
  },
  {
    icon: '<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/><path d="m9 16 2 2 4-4"/>',
    title: 'You\u2019re kept in the loop',
    description: 'Monthly statement, full reporting on which referrals converted, NTS-compliant disclosure documents on file. Nothing else for you to chase.',
  },
];

// "What You Actually Get", 4 cards each backed by a real photographic mockup
type PartnerOffer = {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
};
const partnerOffers: PartnerOffer[] = [
  {
    title: 'Referral Fee',
    description: 'Paid monthly on every completed move. Full reporting shows which referrals converted. NTS-compliant disclosure documentation provided.',
    image: 'partners/estate-agent-referral-fee-dashboard',
    imageAlt: 'Estate agent referral dashboard showing completed moves and referral fees earned',
  },
  {
    title: 'Professional Packing Guide',
    description: 'We give your client our full professional packing guide, the same room-by-room playbook our crews use, branded for you to share at viewings or completion.',
    image: 'homepage/packing-video-guide',
    imageAlt: 'Painless Removals professional packing guide demonstrated by Jay Newton',
  },
  {
    title: 'Compliance Done for You',
    description: 'Pre-written NTS disclosure text and pro-forma documents so your referral arrangement is compliant from day one. We hand you the paperwork ready to use.',
    image: 'partners/estate-agent-nts-compliance-disclosure-pack',
    imageAlt: 'NTS-compliant disclosure pack and referral-arrangement documents for estate agents',
  },
  {
    title: 'Branded Referral Page',
    description: 'Your own affiliate page where you can submit client referrals directly. Tracked to your agency, instant notification to our team, auto-intro email to your client.',
    image: 'partners/estate-agent-branded-referral-page',
    imageAlt: 'Branded estate-agent referral page on a laptop, with a client callback request form',
  },
];

// FAQs
const faqs = [
  {
    question: 'How does the referral fee work?',
    answer: 'You introduce your client to us. If they book and the move completes, you earn a referral fee. We pay monthly with full reporting, you see which referrals converted and what you earned. We also provide NTS-compliant disclosure documentation so your paperwork is covered. <a href="#partner-form" class="text-secondary-500 underline decoration-secondary-300 underline-offset-2 hover:text-secondary-700">Get in touch to discuss the fee structure &rarr;</a>',
  },
  {
    question: 'What if my client needs to move at short notice after a fast exchange?',
    answer: 'We can usually accommodate moves within 5&ndash;7 working days, sometimes sooner. Your dedicated trade contact can check availability in real time, not via a contact form, via a direct line.',
  },
  {
    question: 'How fast do you respond to referrals?',
    answer: 'Same working day. That\'s our guarantee on agent referrals. Your client gets a personalised quote, not a generic estimate, before the day is out.',
  },
  {
    question: 'Do you handle packing as well?',
    answer: 'Yes. Full and partial packing services, including fragile-only packing. Packing is done the day before the move. Costs range from &pound;400&ndash;&pound;990 depending on property size. This is often the add-on that makes the biggest difference to your client\'s experience, and the one they\'ll mention when they thank you for the recommendation.',
  },
  {
    question: 'What about properties with difficult access?',
    answer: 'Narrow streets, no parking, upper floors without a lift, we deal with this daily across Bristol. We assess access during the survey and plan accordingly. No surprises on the day.',
  },
  {
    question: 'Can you handle moves outside Bristol?',
    answer: 'Yes. We\'re long-distance specialists, moves of 100+ miles are our sweet spot. Bristol to London, Bristol to Manchester, Southwest to anywhere. National coverage, Bristol base.',
  },
  {
    question: 'What\'s the Key Wait Waiver?',
    answer: 'A flat add-on your client includes in their quote. It removes all overtime charges if keys are delayed past 5pm. For chain moves, we recommend it as standard, it removes the last financial uncertainty from the day.',
  },
  {
    question: 'What\'s the soft booking system?',
    answer: 'Your client places a small deposit to reserve their preferred date and the deposit is applied to the final invoice. We&rsquo;ll move the date with the chain where we can. Standard cancellation and date-change terms still apply, an optional waiver added at booking covers fee-free changes if your client wants extra peace of mind.',
  },
  {
    question: 'What if something goes wrong on the move?',
    answer: 'Claims are handled within 7 days. &pound;15,000 per van Goods in Transit insurance. We deal with issues directly with your client, you won\'t be pulled into a complaint process.',
  },
  {
    question: 'Do I need to manage any of this?',
    answer: 'No. You make the introduction. We handle the quote, the survey, the move, the follow-up, and the review prompt. Your involvement ends after the introduction, unless you want updates, which we\'re happy to provide.',
  },
  {
    question: 'What branded materials do you provide?',
    answer: 'Physical Painless-branded moving kits (bubble wrap, tape, checklist, quote voucher) for you to hand to clients, our full professional packing guide in printed and digital form, quote cards for viewings, and a branded quote link tracked to your agency. We design, produce, and deliver everything to your office at no cost to you.',
  },
];

// Schema markup
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Removal Services for Estate Agents, Painless Removals Bristol",
  "description": pageDescription,
  "provider": {
    "@type": "MovingCompany",
    "@id": `${siteConfig.brand.domain}/#business`,
    "name": siteConfig.company.name,
    "url": siteConfig.brand.domain,
    "telephone": siteConfig.company.contact.phoneInternational,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Bristol",
      "addressRegion": "Bristol",
      "addressCountry": "GB",
    },
  },
  "areaServed": [
    { "@type": "City", "name": "Bristol" },
    { "@type": "AdministrativeArea", "name": "South West England" },
  ],
  "serviceType": "House Removals for Estate Agent Partners",
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer.replace(/&ndash;/g, '\u2013').replace(/&mdash;/g, '\u2014').replace(/&pound;/g, '\u00a3').replace(/&rarr;/g, '\u2192').replace(/<[^>]*>/g, ''),
    },
  })),
};

const pageSchema = [serviceSchema, faqSchema];
---

<Layout title={pageTitle} description={pageDescription} schema={pageSchema} ogImage="/img/partners/refer-a-client-1200w.avif">

  <!-- ============================================
       HERO, Split 50/50 (service page pattern)
  ============================================ -->
  <section class="relative lg:grid lg:grid-cols-2 lg:min-h-[calc(100dvh-var(--header-h,104px))]">

    <!-- Mobile: image at top -->
    <div class="lg:hidden w-full h-[50vh] min-h-[280px] relative overflow-hidden">
      <OptimizedPicture name="partners/refer-a-client" pattern="FULL" alt="Estate agent referring a client to Painless Removals" class="absolute inset-0 w-full h-full object-cover" />
    </div>

    <!-- Left: content -->
    <div class="gradient-hero px-6 py-8 lg:py-10 lg:px-12 xl:px-16 flex flex-col justify-center">
      <div class="max-w-xl mx-auto text-center">

        <!-- Eyebrow -->
        <p class="text-primary-600 text-sm font-semibold uppercase tracking-wide mb-2">
          For Estate Agents
        </p>

        <!-- H1 -->
        <h1 class="text-3xl lg:text-4xl xl:text-5xl mb-3 lg:mb-4 font-bold font-heading text-balance">
          Removals Your Clients Will <span class="text-secondary-500">Thank You For</span>
        </h1>

        <!-- Subtitle -->
        <p class="text-lg lg:text-xl text-warm-gray mb-5 lg:mb-6 leading-relaxed">
          Every move in the chain gets its own full day &mdash; so your clients get our full attention, start to finish.
        </p>

        <!-- Proof bar -->
        <div class="flex flex-col gap-2 text-sm text-warm-gray mb-6 max-w-max mx-auto">
          <div class="flex items-center gap-2">
            <span class="text-green-500 shrink-0">&#10003;</span>
            <span>Same-day quote response on agent referrals</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-green-500 shrink-0">&#10003;</span>
            <span>Branded materials &amp; compliance docs provided</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-green-500 shrink-0">&#10003;</span>
            <span>One introduction, we take it from there</span>
          </div>
        </div>

        <!-- CTA -->
        <div class="flex flex-col gap-2 mb-5 items-center">
          <a href="#partner-form" class="btn-cta-orange">
            Start a Conversation
          </a>
          <a href={`tel:${siteConfig.company.contact.phone.replace(/\s/g, '')}`} class="flex items-center gap-2 text-primary-600 font-semibold no-underline hover:text-secondary-500 transition-colors text-lg mt-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {siteConfig.company.contact.phone}
          </a>
        </div>

      </div>
    </div>

    <!-- Right: image (desktop) -->
    <div class="hidden lg:block relative overflow-hidden">
      <OptimizedPicture name="partners/refer-a-client" pattern="FULL" alt="Estate agent referring a client to Painless Removals" class="absolute inset-0 w-full h-full object-cover" />
    </div>
  </section>

  <!-- USP Bar -->
  <UspBar hideBadge={true} />

  <!-- ============================================
       JAY INTRO — kf-intro layout: portrait left, eyebrow + serif h2 + two paragraphs right
  ============================================ -->
  <section class="kf ea-jay-intro">
    <div class="ea-jay-intro-grid">
      <figure class="ea-jay-portrait">
        <OptimizedPicture
          name="about/team/Jay"
          pattern="HALF"
          alt="Jay Newton, Director, Painless Removals"
          loading="lazy"
          class="ea-jay-portrait-img"
        />
        <figcaption>
          <strong>Jay Newton</strong>
          <span>Director &middot; Painless Removals</span>
        </figcaption>
      </figure>

      <div class="ea-jay-copy">
        <div class="ea-jay-eyebrow">Bristol &middot; Since 1978</div>
        <h2 class="ea-jay-h2">
          A reliable removals partner <em>for every agent referral.</em>
        </h2>
        <p class="ea-jay-p">
          &ldquo;When an agent puts their name next to ours, I take it personally. Your
          trust is an honour, and we do everything in our power to be worthy of it. Your
          client has our <em>full attention, start to finish &mdash; no shortcuts,
          ever.</em>&rdquo;
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECTION 1: ONE INTRODUCTION
       — step 1 sits alone under the heading
       — a curved dashed arrow leads the eye down
       — steps 2-4 form the row below
  ============================================ -->
  <section id="hiw-estate-agents" class="ea-intro section bg-primary-50" aria-labelledby="ea-intro-heading">
    <div class="ea-intro-inner">

      <h2 id="ea-intro-heading" class="ea-intro-heading">
        One Introduction. <span class="ea-intro-accent">That&rsquo;s It.</span>
      </h2>
      <p class="ea-intro-subtitle">
        This is the entire process from your side. Everything after step one is on us.
      </p>

      {/* Step 1 — feature card directly under heading */}
      <div class="ea-step-feature">
        <article class="ea-card ea-card-primary">
          <div class="ea-card-icon-wrap">
            <svg class="ea-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={introSteps[0].icon} />
            </svg>
            <span class="ea-card-badge">1</span>
          </div>
          <h3 class="ea-card-title">{introSteps[0].title}</h3>
          <p class="ea-card-desc">{introSteps[0].description}</p>
        </article>

        {/* Curved dashed arrow leading the eye down to the next row */}
        <svg class="ea-curved-arrow" viewBox="0 0 220 130" fill="none" aria-hidden="true">
          <path
            d="M 110 4 C 110 60, 60 70, 30 110"
            stroke="#C65D3B"
            stroke-width="2"
            stroke-linecap="round"
            stroke-dasharray="2 8"
            fill="none"
          />
          <path
            d="M 42 105 L 30 110 L 32 97"
            stroke="#C65D3B"
            stroke-width="2.4"
            stroke-linecap="round"
            stroke-linejoin="round"
            fill="none"
          />
        </svg>
      </div>

      {/* Steps 2, 3, 4 — horizontal row */}
      <div class="ea-steps-row">
        {introSteps.slice(1).map((step, i) => (
          <article class="ea-card">
            <div class="ea-card-icon-wrap">
              <svg class="ea-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={step.icon} />
              </svg>
              <span class="ea-card-badge">{i + 2}</span>
            </div>
            <h3 class="ea-card-title">{step.title}</h3>
            <p class="ea-card-desc">{step.description}</p>
          </article>
        ))}
      </div>

      <div class="ea-intro-cta">
        <a href="#partner-form" class="ea-intro-cta-link">
          <span>Start a Conversation</span>
        </a>
      </div>

    </div>
  </section>

  <!-- ============================================
       SECTION 3: WHAT YOU ACTUALLY GET,4 cards with iconography (placeholder visual until free-stock imagery is processed through the build pipeline)
  ============================================ -->
  <section class="section bg-white">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="text-2xl lg:text-3xl mb-4">What You Actually <span class="text-secondary-500">Get</span></h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
        {partnerOffers.map((offer) => (
          <div class="group relative bg-cream rounded-xl border border-gray-100 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 overflow-hidden flex flex-col">
            <div class="relative aspect-[4/3] overflow-hidden bg-gray-100">
              <OptimizedPicture
                name={offer.image}
                pattern="QUARTER"
                alt={offer.imageAlt}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
            </div>
            <div class="p-6 flex-1">
              <h3 class="font-bold text-primary-600 mb-2">{offer.title}</h3>
              <p class="text-warm-gray text-sm leading-relaxed" set:html={offer.description} />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       SECTION 4: WHY YOUR RECOMMENDATION IS SAFE
  ============================================ -->
  <section class="section bg-cream">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="text-2xl lg:text-3xl mb-4">Why You Can Put Your Name <span class="text-secondary-500">Next to Ours</span></h2>
        <p class="text-warm-gray text-lg max-w-2xl mx-auto">
          You don&rsquo;t recommend tradespeople lightly. Here&rsquo;s why we&rsquo;re a safe bet.
        </p>
      </div>

      <div class="max-w-6xl mx-auto grid lg:grid-cols-[5fr_7fr] gap-10 lg:gap-14 items-start">
        <div class="rounded-xl overflow-hidden shadow-md lg:sticky lg:top-24">
          <OptimizedPicture
            name="about/Painless-Removals-van-Bristol"
            pattern="SMALL"
            alt="Painless Removals branded van on a Bristol street"
            loading="lazy"
            class="w-full h-auto block"
          />
        </div>

        <div class="space-y-4">
          <div class="flex items-start gap-3 text-warm-gray">
            <span class="text-green-500 mt-1 shrink-0">&#10003;</span>
            <span><strong class="text-primary-600">{yearsSince1978} years. Since 1978.</strong> We&rsquo;ve handled chain moves since before most removal companies existed. This isn&rsquo;t a side hustle, it&rsquo;s all we do.</span>
          </div>
          <div class="flex items-start gap-3 text-warm-gray">
            <span class="text-green-500 mt-1 shrink-0">&#10003;</span>
            <span><strong class="text-primary-600">{reviewCount} verified reviews. {siteConfig.company.rating.value}&#9733; average.</strong> Read them. The most common thing clients mention is the team, respectful, careful, on time.</span>
          </div>
          <div class="flex items-start gap-3 text-warm-gray">
            <span class="text-green-500 mt-1 shrink-0">&#10003;</span>
            <span><strong class="text-primary-600">Exclusive completion-day allocation.</strong> Your client is our only job that day. No overlapping moves. No late arrivals. Full attention from start to finish.</span>
          </div>
          <div class="flex items-start gap-3 text-warm-gray">
            <span class="text-green-500 mt-1 shrink-0">&#10003;</span>
            <span><strong class="text-primary-600">&pound;15,000 insurance per van.</strong> Goods in Transit cover on every vehicle. Items over &pound;2,000 declared before the move. Transparent claims process, resolved within 7 days.</span>
          </div>
          <div class="flex items-start gap-3 text-warm-gray">
            <span class="text-green-500 mt-1 shrink-0">&#10003;</span>
            <span><strong class="text-primary-600">Every quote is based on a proper assessment.</strong> We send the right number of people with the right number of vans.</span>
          </div>
          <div class="flex items-start gap-3 text-warm-gray">
            <span class="text-green-500 mt-1 shrink-0">&#10003;</span>
            <span><strong class="text-primary-600">We protect the property.</strong> Mattress covers, sofa protectors, TV bags, and picture protection, all included as standard.</span>
          </div>
          <div class="flex items-start gap-3 text-warm-gray">
            <span class="text-green-500 mt-1 shrink-0">&#10003;</span>
            <span><strong class="text-primary-600">Key Wait Waiver available.</strong> A flat add-on that removes all overtime charges if keys are delayed. For chain moves, we recommend it as standard, it removes the last financial uncertainty.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       REVIEW STRIP, Real chain-move testimonial (verified Trustpilot review)
  ============================================ -->
  <section class="bg-white py-10 lg:py-14">
    <div class="container-wide max-w-3xl mx-auto text-center">
      <div class="text-orange-400 text-2xl mb-4">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
      <blockquote class="text-xl lg:text-2xl text-gray-700 italic leading-relaxed mb-4">
        &ldquo;Great moving company, who applied a lot of common sense and were communicative and helpful throughout. <mark>Dealt well with the last minute ups and downs involving our chain</mark>, very late exchange, and were reassuring to us during what could have been a stressful time.&rdquo;
      </blockquote>
      <div class="flex items-center justify-center gap-3">
        <span class="text-gray-500 text-sm font-medium">Joanna Wong</span>
        <span class="text-gray-300">&middot;</span>
        <img src="/images/trustpilot-logo.svg" alt="Trustpilot" class="h-4 w-auto" width="94" height="20" />
      </div>
    </div>
  </section>

  <!-- ============================================
       FAQ
  ============================================ -->
  <FAQAccordion faqs={faqs} heading="Questions Agents Ask Us" bgClass="bg-cream" />

  <!-- ============================================
       PARTNER REGISTRATION FORM (embedded inline so agents don't bounce to /partners/)
  ============================================ -->
  <section class="py-12 md:py-16 bg-primary-600 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute -top-20 -left-20 w-64 h-64 border border-white rounded-full"></div>
      <div class="absolute -bottom-16 -right-16 w-48 h-48 border border-white rounded-full"></div>
    </div>

    <div class="max-w-2xl mx-auto px-5 relative z-10">
      <div class="text-center mb-8">
        <h2 class="text-white text-2xl md:text-3xl mb-2">Let&rsquo;s Talk</h2>
        <p class="text-primary-200">
          Tell us about your agency and we&rsquo;ll arrange an introductory call. No hard sell &mdash; just a conversation about how we can help your clients.
        </p>
      </div>

      <div id="partner-form" class="bg-white rounded-2xl shadow-2xl p-6 sm:p-8 md:p-10" style="scroll-margin-top: 5rem;">

        <!-- Success message (hidden by default) -->
        <div id="form-success" class="hidden text-center py-8">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg width="32" height="32" class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-primary-600 mb-2">Registration Received</h3>
          <p class="text-warm-gray leading-relaxed">
            Thank you for your interest in partnering with us. We&rsquo;ll respond within one working day to arrange an introductory call.
          </p>
        </div>

        <form id="partner-form-el" class="space-y-5" novalidate data-phone={siteConfig.company.contact.phone}>
          <!-- Honeypot -->
          <div style="position: absolute; left: -9999px;" aria-hidden="true">
            <label for="website">Leave this blank</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <!-- Name -->
          <div>
            <label for="name" class="block text-sm font-semibold text-primary-600 mb-1.5">Your Name <span class="text-secondary-500">*</span></label>
            <input type="text" id="name" name="name" required autocomplete="name"
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" />
          </div>

          <!-- Company Name -->
          <div>
            <label for="companyName" class="block text-sm font-semibold text-primary-600 mb-1.5">Company Name <span class="text-secondary-500">*</span></label>
            <input type="text" id="companyName" name="companyName" required autocomplete="organization"
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" />
          </div>

          <!-- Role -->
          <div>
            <label for="role" class="block text-sm font-semibold text-primary-600 mb-1.5">Your Role</label>
            <input type="text" id="role" name="role" placeholder="e.g. Branch Manager, Senior Partner" autocomplete="organization-title"
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" />
          </div>

          <!-- Business Type and Estimated Referrals row -->
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="businessType" class="block text-sm font-semibold text-primary-600 mb-1.5">Business Type <span class="text-secondary-500">*</span></label>
              <select id="businessType" name="businessType" required
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors">
                <option value="estate-agent" selected>Estate Agent</option>
                <option value="solicitor">Solicitor / Conveyancer</option>
                <option value="care-home">Care Home / Senior Living</option>
                <option value="relocation-agent">Corporate Relocation</option>
                <option value="home-staging">Home Staging / Interior Design</option>
                <option value="property-developer">Property Developer</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label for="estimatedReferrals" class="block text-sm font-semibold text-primary-600 mb-1.5">Estimated Referrals/Month</label>
              <select id="estimatedReferrals" name="estimatedReferrals"
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors">
                <option value="">Select...</option>
                <option value="1-2">1&ndash;2</option>
                <option value="3-5">3&ndash;5</option>
                <option value="6-10">6&ndash;10</option>
                <option value="10+">10+</option>
              </select>
            </div>
          </div>

          <!-- Email and Phone row -->
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="email" class="block text-sm font-semibold text-primary-600 mb-1.5">Email Address <span class="text-secondary-500">*</span></label>
              <input type="email" id="email" name="email" required autocomplete="email"
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-semibold text-primary-600 mb-1.5">Phone Number <span class="text-secondary-500">*</span></label>
              <input type="tel" id="phone" name="phone" required autocomplete="tel"
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" />
            </div>
          </div>

          <!-- What Matters Most -->
          <div>
            <label for="whatMatters" class="block text-sm font-semibold text-primary-600 mb-1.5">What Matters Most to You in a Removal Partner?</label>
            <textarea id="whatMatters" name="whatMatters" rows="3"
              placeholder="Reliability, communication, handling of fragile items..."
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors resize-y"></textarea>
          </div>

          <!-- Preferred Contact Method -->
          <fieldset>
            <legend class="block text-sm font-semibold text-primary-600 mb-2">Preferred Contact Method</legend>
            <div class="flex gap-6">
              <label class="flex items-center gap-2 text-sm text-warm-gray cursor-pointer">
                <input type="radio" name="preferredContact" value="phone" class="text-primary-600 focus:ring-primary-500" />
                Phone
              </label>
              <label class="flex items-center gap-2 text-sm text-warm-gray cursor-pointer">
                <input type="radio" name="preferredContact" value="email" class="text-primary-600 focus:ring-primary-500" />
                Email
              </label>
              <label class="flex items-center gap-2 text-sm text-warm-gray cursor-pointer">
                <input type="radio" name="preferredContact" value="either" checked class="text-primary-600 focus:ring-primary-500" />
                Either
              </label>
            </div>
          </fieldset>

          <!-- Cloudflare Turnstile -->
          <div>
            <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="light" data-language="en"></div>
          </div>

          <!-- Error message area -->
          <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm"></div>

          <!-- Submit -->
          <div>
            <button type="submit" id="submit-btn"
              class="btn-cta-orange cursor-pointer w-full sm:w-auto">
              Register as a Partner
            </button>
            <p class="text-warm-gray text-sm mt-3">
              We&rsquo;ll respond within one working day. No hard sell &mdash; just a conversation about how we can help your clients.
            </p>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- ============================================
       FINAL CTA
  ============================================ -->
  <FinalCTA
    heading="One Introduction. We Handle the Rest."
    description="Recommend us with confidence. Branded materials, compliance documents, a same-day response, and a referral fee on every completed move."
    bullets={['Same-day response', 'Branded materials at no cost', 'NTS compliance handled', 'Referral fee on every move']}
    primaryText="Start a Conversation"
    primaryHref="#partner-form"
    bottomNote="Call and ask about our agent partnership, we'll have you set up the same week."
  />

  <!-- Cloudflare Turnstile script -->
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <!-- Partner form submission -->
  <script is:inline>
    (function() {
      var form = document.getElementById('partner-form-el');
      var PHONE = form && form.dataset.phone || '0117 287 0082';
      var errorDiv = document.getElementById('form-error');
      var submitBtn = document.getElementById('submit-btn');

      if (form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault();

          errorDiv.classList.add('hidden');
          errorDiv.textContent = '';

          var name = form.querySelector('#name').value.trim();
          var companyName = form.querySelector('#companyName').value.trim();
          var role = form.querySelector('#role').value.trim();
          var businessType = form.querySelector('#businessType').value;
          var estimatedReferrals = form.querySelector('#estimatedReferrals').value;
          var email = form.querySelector('#email').value.trim();
          var phone = form.querySelector('#phone').value.trim();
          var whatMatters = form.querySelector('#whatMatters').value.trim();
          var preferredContact = form.querySelector('input[name="preferredContact"]:checked');
          preferredContact = preferredContact ? preferredContact.value : 'either';
          var honeypot = form.querySelector('#website').value;

          if (!name || !companyName || !email || !phone || !businessType) {
            errorDiv.textContent = 'Please fill in all required fields (name, company, business type, email, and phone).';
            errorDiv.classList.remove('hidden');
            return;
          }

          var turnstileResponse = '';
          var turnstileInput = form.querySelector('[name="cf-turnstile-response"]');
          if (turnstileInput) {
            turnstileResponse = turnstileInput.value;
          }

          if (!turnstileResponse) {
            errorDiv.textContent = 'The security check is still loading. Please wait a moment and try again, or call us on ' + PHONE + '.';
            errorDiv.classList.remove('hidden');
            return;
          }

          submitBtn.disabled = true;
          submitBtn.textContent = 'SUBMITTING...';

          fetch('/api/partner-register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: name,
              companyName: companyName,
              role: role,
              businessType: businessType,
              estimatedReferrals: estimatedReferrals,
              email: email,
              phone: phone,
              whatMatters: whatMatters,
              preferredContact: preferredContact,
              honeypot: honeypot,
              turnstileToken: turnstileResponse,
            }),
          })
          .then(function(res) { return res.json(); })
          .then(function(data) {
            if (data.success) {
              // Analytics-only event (NOT a conversion).
              var eventId = (window.crypto && window.crypto.randomUUID)
                ? window.crypto.randomUUID()
                : ('id-' + Date.now() + '-' + Math.random().toString(36).slice(2));
              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push({
                event: 'form_submission',
                event_id: eventId,
                form_name: 'partner_register',
                form_source: 'partners-estate-agents-page',
              });
              window.location.href = '/partners/thank-you/';
            } else {
              errorDiv.textContent = data.error || 'Something went wrong. Please try again or call us directly.';
              errorDiv.classList.remove('hidden');
              submitBtn.disabled = false;
              submitBtn.textContent = 'REGISTER AS A PARTNER';
              if (window.turnstile) { window.turnstile.reset(); }
            }
          })
          .catch(function() {
            errorDiv.textContent = 'Connection error. Please try again or call us on ' + PHONE + '.';
            errorDiv.classList.remove('hidden');
            submitBtn.disabled = false;
            submitBtn.textContent = 'REGISTER AS A PARTNER';
          });
        });
      }
    })();
  </script>

</Layout>

<style>
  /* ── "One Introduction" — bespoke layout: step 1 alone under heading,
        curved dashed arrow, then steps 2-4 in a row ── */
  .ea-intro {
    padding: 4rem 0 5rem;
  }
  .ea-intro-inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .ea-intro-heading {
    text-align: center;
    margin: 0 0 0.6rem;
    font-size: clamp(1.75rem, 3.4vw, 2.4rem);
  }
  .ea-intro-accent {
    color: #C65D3B;
  }
  .ea-intro-subtitle {
    text-align: center;
    max-width: 38rem;
    margin: 0 auto 2.5rem;
    color: #6B6B6B;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  /* Step 1 feature row — centered card + curved arrow off to the bottom-left */
  .ea-step-feature {
    position: relative;
