            <span class="font-medium">Google Business</span>
            <small class="text-warm-gray text-xs">Reviews & directions</small>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECTION 17: CTA
  ============================================ -->
  <section class="py-16 md:py-20 bg-primary-600 text-white text-center">
    <div class="container-wide">
      <h2 class="text-white mb-4">Ready to Get Started?</h2>
      <p class="text-primary-100 text-lg mb-8 max-w-xl mx-auto">
        Get an instant estimate for your move. No pressure, no obligation–just a clear idea of what it might cost.
      </p>

      <a href="/instantquote/" class="btn btn-primary text-lg px-10 py-4">
        Get Your Instant Quote
      </a>
    </div>
  </section>

</Layout>

<style>
  /* ═══════════════════════════════════════════
     TIMELINE — Horizontal scroll with connecting line
  ═══════════════════════════════════════════ */
  .tl-wrapper {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--color-primary-300, #7c9cbf) transparent;
    padding: 0 1.5rem 1rem;
    cursor: grab;
  }
  .tl-wrapper:active { cursor: grabbing; }
  .tl-wrapper::-webkit-scrollbar { height: 4px; }
  .tl-wrapper::-webkit-scrollbar-track { background: transparent; }
  .tl-wrapper::-webkit-scrollbar-thumb {
    background: var(--color-primary-300, #7c9cbf);
    border-radius: 999px;
  }

  .tl-track {
    display: flex;
    gap: 0;
    position: relative;
    padding: 3rem 0 1rem;
    min-width: max-content;
  }

  /* Connecting horizontal line */
  .tl-line {
    position: absolute;
    top: calc(3rem + 6px);
    left: 2rem;
    right: 2rem;
    height: 2px;
    background: linear-gradient(90deg, var(--color-primary-200, #bdd0e7), var(--color-secondary-400, #f59e0b), var(--color-primary-200, #bdd0e7));
  }

  .tl-card {
    flex-shrink: 0;
    width: 260px;
    padding: 0 1rem;
    position: relative;
    animation: tl-fade-in 0.5s ease-out both;
    animation-delay: calc(var(--idx) * 0.08s);
  }
  @media (min-width: 768px) {
    .tl-card { width: 300px; }
  }

  @keyframes tl-fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Dot on the line */
  .tl-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-primary-600, #1e3a5f);
    border: 3px solid var(--color-cream, #faf7f2);
    position: relative;
    z-index: 1;
    margin-bottom: 1rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .tl-card:hover .tl-dot {
    transform: scale(1.4);
    box-shadow: 0 0 0 4px var(--color-primary-200, #bdd0e7);
  }

  .tl-year {
    display: block;
    font-family: var(--font-heading, serif);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-secondary-500, #f59e0b);
    line-height: 1;
    margin-bottom: 0.375rem;
  }

  .tl-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary-600, #1e3a5f);
    margin-bottom: 0.5rem;
  }

  .tl-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-warm-gray, #78716c);
  }

  /* Snap on touch */
  @media (hover: none) {
    .tl-wrapper { scroll-snap-type: x mandatory; scroll-padding: 1.5rem; }
    .tl-card { scroll-snap-align: start; }
  }

  /* ═══════════════════════════════════════════
     SCROLL ANIMATIONS (sa = scroll-animate)
  ═══════════════════════════════════════════ */
  .sa {
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: opacity, transform;
  }
  .sa--fade {
    transform: scale(1.04);
  }
  .sa--right {
    transform: translateX(60px);
  }
  .sa.is-visible {
    opacity: 1;
    transform: translateX(0) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .sa {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

</style>

<script>
  // Enable drag-to-scroll on timeline
  const tl = document.querySelector<HTMLElement>('.tl-wrapper');
  if (tl) {
    let isDown = false;
    let startX: number;
    let scrollLeft: number;

    tl.addEventListener('mousedown', (e) => {
      isDown = true;
      startX = e.pageX - tl.offsetLeft;
      scrollLeft = tl.scrollLeft;
    });
    tl.addEventListener('mouseleave', () => { isDown = false; });
    tl.addEventListener('mouseup', () => { isDown = false; });
    tl.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - tl.offsetLeft;
      const walk = (x - startX) * 1.5;
      tl.scrollLeft = scrollLeft - walk;
    });
  }

  // Scroll-triggered animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('[data-sa]').forEach((el) => observer.observe(el));
</script>
