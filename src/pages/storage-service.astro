<!-- Storage Slider Calculator Script -->
<script>
  const storageTiers = [
    { sqft: 25,  name: 'Small Wardrobe', price: 41,  regular: 82,  recommendation: 'Just a few boxes?', thinkOf: 'a small wardrobe or garden shed' },
    { sqft: 50,  name: 'Garden Shed',    price: 59,  regular: 118, recommendation: 'Including a couch?', thinkOf: 'a single garage or garden shed' },
    { sqft: 85,  name: 'Small Bedroom',  price: 82,  regular: 164, recommendation: 'Studio apartment',   thinkOf: 'a small bedroom – fits a studio flat' },
    { sqft: 100, name: 'Standard Bedroom', price: 92, regular: 184, recommendation: '1-bedroom apartment', thinkOf: 'a standard bedroom – fits a 1-bed apartment' },
    { sqft: 150, name: 'Large Bedroom',  price: 124, regular: 248, recommendation: '2-bedroom apartment', thinkOf: 'a large bedroom – fits a 2-bed apartment' },
    { sqft: 200, name: '1 Car Garage',   price: 157, regular: 314, recommendation: '3-bedroom house',    thinkOf: 'a single car garage – fits a 3-bed house' },
  ];

  const slider = document.getElementById('storage-slider') as HTMLInputElement;
  const roomName = document.getElementById('calc-room-name');
  const thinkOf = document.getElementById('calc-think-of');
  const recText = document.getElementById('calc-rec-text');
  const priceEl = document.getElementById('calc-price');
  const regularEl = document.getElementById('calc-regular');
  const regularAfter = document.getElementById('calc-regular-after');
  const sqftLabel = document.getElementById('svg-sqft-label');
  const roomIcon = document.getElementById('calc-room-icon');
  const ticks = document.querySelectorAll('.slider-tick');

  function updateCalculator(index: number) {
    const tier = storageTiers[index];
    if (!tier) return;

    // Update text displays
    if (roomName) roomName.textContent = tier.name;
    if (thinkOf) thinkOf.textContent = tier.thinkOf;
    if (recText) recText.textContent = tier.recommendation;
    if (priceEl) priceEl.textContent = `£${tier.price}`;
    if (regularEl) regularEl.textContent = `£${tier.regular}`;
    if (regularAfter) regularAfter.textContent = `£${tier.regular}`;
    if (sqftLabel) sqftLabel.textContent = tier.sqft.toString();

    // Scale the room icon: smallest is 80px, largest is 220px
    // Container has fixed min-height so page doesn't jump
    const minSize = 80;
    const maxSize = 220;
    const progress = index / (storageTiers.length - 1);
    const size = Math.round(minSize + progress * (maxSize - minSize));
    if (roomIcon) {
      roomIcon.style.width = `${size}px`;
      roomIcon.style.height = `${size}px`;
    }

    // Update slider progress fill via CSS custom property
    const percent = (index / 5) * 100;
    slider.style.setProperty('--slider-progress', `${percent}%`);

    // Highlight active tick
    ticks.forEach((tick, i) => {
      const dot = tick.querySelector('span:first-child');
      const label = tick.querySelector('span:last-child');
      if (i === index) {
        dot?.classList.add('bg-primary-500', 'scale-150');
        dot?.classList.remove('bg-gray-300');
        label?.classList.add('text-primary-600', 'font-bold');
        label?.classList.remove('text-warm-gray');
      } else {
        dot?.classList.remove('bg-primary-500', 'scale-150');
        dot?.classList.add('bg-gray-300');
        label?.classList.remove('text-primary-600', 'font-bold');
        label?.classList.add('text-warm-gray');
      }
    });
  }

  // Slider input handler
  slider.addEventListener('input', () => {
    updateCalculator(parseInt(slider.value));
  });

  // Tick click handlers
  ticks.forEach(tick => {
    tick.addEventListener('click', () => {
      const index = parseInt(tick.getAttribute('data-index') || '0');
      slider.value = index.toString();
      updateCalculator(index);
    });
  });

  // Initialize on load (default: Standard Bedroom, index 3)
  updateCalculator(3);
</script>


