  <!-- Global smooth <details> animation -->
  <script>
    function initDetailsAnimation() {
      document.querySelectorAll('details').forEach((det) => {
        if (det.hasAttribute('data-anim-init')) return;
        det.setAttribute('data-anim-init', '');

        // Skip if already wrapped (e.g. by FAQAccordion component or FAQ page)
        if (det.querySelector('.faq-answer-wrap') || det.querySelector('.faq-page-answer')) return;

        const summary = det.querySelector('summary');
        if (!summary) return;

        // Collect all sibling nodes after <summary>
        const children: Node[] = [];
        let node = summary.nextSibling;
        while (node) {
          children.push(node);
          node = node.nextSibling;
        }
        if (children.length === 0) return;

        // Create wrapper divs for the grid animation
        const wrap = document.createElement('div');
        wrap.className = 'details-anim-wrap';
        const inner = document.createElement('div');
        inner.className = 'details-anim-inner';

        children.forEach((child) => inner.appendChild(child));
        wrap.appendChild(inner);
        det.appendChild(wrap);

        // Intercept toggle to animate close
        let isClosing = false;
        summary.addEventListener('click', (e) => {
          if (isClosing) return;
          if (det.open) {
            // Animate close: keep open attr until transition ends
            e.preventDefault();
            isClosing = true;
            wrap.style.gridTemplateRows = '0fr';
            const unlock = () => {
              det.removeAttribute('open');
              isClosing = false;
              wrap.style.gridTemplateRows = '';
            };
            wrap.addEventListener('transitionend', unlock, { once: true });
            setTimeout(() => { if (isClosing) unlock(); }, 400);
          }
        });
      });
    }

    // Run on initial load and after Astro view transitions
    initDetailsAnimation();
    document.addEventListener('astro:after-swap', initDetailsAnimation);
  </script>

  <!-- Toast notification container -->
  <div id="toast-container" aria-live="polite" aria-atomic="false" style="position:fixed;top:1.25rem;right:1.25rem;z-index:9999;display:flex;flex-direction:column;gap:0.5rem;width:22rem;max-width:calc(100vw - 2.5rem);pointer-events:none;"></div>

  <script is:inline>
    // Global toast notification system
    window.showToast = function(message, type, duration) {
      type = type || 'error';
      duration = duration || 6000;
      var container = document.getElementById('toast-container');
      if (!container) return;

      var styles = {
        error:   { bg: '#fef2f2', border: '#fca5a5', text: '#991b1b', iconBg: '#fee2e2', icon: '&#10005;' },
        success: { bg: '#f0fdf4', border: '#86efac', text: '#166534', iconBg: '#dcfce7', icon: '&#10003;' },
        warning: { bg: '#fffbeb', border: '#fcd34d', text: '#92400e', iconBg: '#fef3c7', icon: '&#33;' },
        info:    { bg: '#eff6ff', border: '#93c5fd', text: '#1e40af', iconBg: '#dbeafe', icon: '&#105;' },
      };
      var s = styles[type] || styles.error;

      var toast = document.createElement('div');
      toast.setAttribute('role', 'alert');
      toast.style.cssText = [
        'pointer-events:auto',
        'display:flex',
        'align-items:flex-start',
        'gap:0.625rem',
        'padding:0.875rem 1rem',
        'border-radius:0.5rem',
        'border:1px solid ' + s.border,
        'background:' + s.bg,
        'color:' + s.text,
        'box-shadow:0 4px 16px rgba(0,0,0,0.12)',
        'font-size:0.875rem',
        'line-height:1.5',
        'opacity:0',
        'transform:translateX(110%)',
        'transition:opacity 0.25s ease, transform 0.25s ease',
      ].join(';');

      var icon = document.createElement('span');
      icon.innerHTML = s.icon;
      icon.style.cssText = [
        'flex-shrink:0',
        'width:1.25rem',
        'height:1.25rem',
        'border-radius:50%',
        'display:flex',
        'align-items:center',
        'justify-content:center',
        'font-size:0.6875rem',
        'font-weight:700',
        'background:' + s.iconBg,
        'color:' + s.text,
        'margin-top:0.125rem',
      ].join(';');

      var msg = document.createElement('span');
      msg.style.flex = '1';
      msg.textContent = message;

      var close = document.createElement('button');
      close.innerHTML = '&times;';
      close.setAttribute('aria-label', 'Dismiss');
      close.style.cssText = [
        'flex-shrink:0',
        'background:none',
        'border:none',
        'cursor:pointer',
        'color:inherit',
        'opacity:0.5',
        'font-size:1.125rem',
        'line-height:1',
        'padding:0',
        'margin-top:-0.125rem',
      ].join(';');

      toast.appendChild(icon);
      toast.appendChild(msg);
      toast.appendChild(close);
      container.appendChild(toast);

      function remove() {
        toast.style.opacity = '0';
        toast.style.transform = 'translateX(110%)';
        setTimeout(function() {
          if (toast.parentNode) toast.parentNode.removeChild(toast);
        }, 280);
      }

      close.addEventListener('click', remove);

      var timer = setTimeout(remove, duration);
      toast.addEventListener('mouseenter', function() { clearTimeout(timer); });
      toast.addEventListener('mouseleave', function() { timer = setTimeout(remove, 2500); });

      // Trigger entrance animation
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          toast.style.opacity = '1';
          toast.style.transform = 'translateX(0)';
        });
      });
    };
  </script>

