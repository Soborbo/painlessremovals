---
/**
 * ClientLogos — shared "regular clients" logo grid
 *
 * 2×2 on mobile, 4-across on desktop. All logos same height.
 */
import OptimizedPicture from '@/components/OptimizedPicture.astro';

const clients = [
  { name: 'Bristol Old Vic', imageName: 'home-removals/clients/bristol-old-vic' },
  { name: 'LiveWest', imageName: 'home-removals/clients/livewest' },
  { name: 'Church of England', imageName: 'home-removals/clients/church-of-england' },
  { name: 'Second Step', imageName: 'home-removals/clients/second-step' },
];

interface Props {
  heading?: string;
  class?: string;
}
const {
  heading = 'Some of Our Regular Clients Include',
  class: className = '',
} = Astro.props;
---

<section class:list={['py-8 lg:py-10 bg-cream overflow-hidden', className]}>
  <div class="container-wide">
    <p class="client-logos__heading text-center text-sm text-warm-gray mb-6 uppercase tracking-widest">{heading}</p>
    <div class="client-logos__track">
      {/* Render twice for seamless infinite scroll */}
      {[0, 1].map((set) => (
        <div class="client-logos__set" aria-hidden={set === 1 ? 'true' : undefined}>
          {clients.map((client, i) => (
            <div class="client-logos__item group" style={`--i:${i}`}>
              <div class="client-logos__card">
                <OptimizedPicture
                  name={client.imageName}
                  pattern="SIXTH"
                  alt={`${client.name} – regular client of Painless Removals`}
                  sizes="180px"
                  class="w-auto h-[77px] lg:h-[89px] object-contain transition-all duration-500 ease-out group-hover:scale-110"
                />
              </div>
              <span class="client-logos__label">{client.name}</span>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── heading animated underline ── */
  .client-logos__heading {
    position: relative;
    display: inline-block;
    width: 100%;
  }
  .client-logos__heading::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    width: 48px;
    height: 2px;
    background: var(--color-primary, #b91c1c);
    border-radius: 999px;
    animation: heading-line 3s ease-in-out infinite;
  }
  @keyframes heading-line {
    0%, 100% { width: 48px; opacity: 0.6; }
    50% { width: 80px; opacity: 1; }
  }

  /* ── scrolling track (mobile: auto-scroll, desktop: static grid) ── */
  .client-logos__track {
    display: flex;
    gap: 2rem;
    animation: scroll-logos 20s linear infinite;
  }
  .client-logos__track:hover {
    animation-play-state: paused;
  }
  .client-logos__set {
    display: flex;
    gap: 2rem;
    flex-shrink: 0;
  }

  @keyframes scroll-logos {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 1rem)); }
  }

  @media (prefers-reduced-motion: reduce) {
    .client-logos__track { animation: none; }
    .client-logos__item { animation: none; }
  }

  /* desktop: no scroll, centered grid */
  @media (min-width: 1024px) {
    .client-logos__track {
      animation: none;
      justify-content: center;
      gap: 3rem;
    }
    .client-logos__set:last-child {
      display: none;
    }
  }

  /* ── individual logo card ── */
  .client-logos__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
    min-width: 160px;
    padding: 0.75rem 2rem;
    cursor: default;
    animation: fade-up 0.6s ease-out both;
    animation-delay: calc(var(--i) * 0.1s);
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .client-logos__card {
    position: relative;
    padding: 1rem 1.5rem;
    border-radius: 12px;
    background: white;
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.06);
    transition: box-shadow 0.4s ease, transform 0.4s ease;
  }
  .group:hover .client-logos__card {
    box-shadow: 0 8px 24px rgb(0 0 0 / 0.1);
    transform: translateY(-4px);
  }

  /* subtle shine sweep on hover */
  .client-logos__card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 12px;
    background: linear-gradient(105deg, transparent 40%, rgb(255 255 255 / 0.6) 50%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }
  .group:hover .client-logos__card::before {
    opacity: 1;
    animation: shine-sweep 0.7s ease-out;
  }
  @keyframes shine-sweep {
    from { transform: translateX(-100%); }
    to   { transform: translateX(100%); }
  }

  /* ── client name label ── */
  .client-logos__label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgb(120 113 108 / 0.7);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .group:hover .client-logos__label {
    opacity: 1;
    transform: translateY(0);
  }
</style>
