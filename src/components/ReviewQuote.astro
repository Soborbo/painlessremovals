---
/**
 * ReviewQuote — styled review with stars, highlighted text, attribution
 *
 * Uses the .review-quote CSS class which auto-generates 5 stars via ::before.
 */

export interface Props {
  /** Review text (supports HTML, e.g. <mark> tags for highlights) */
  text: string;
  /** Reviewer name */
  name: string;
  /** Review source */
  source?: string;
}

const {
  text,
  name,
  source = 'Verified Trustpilot Review',
} = Astro.props;
---

<div class="review-quote">
  <p class="text-lg md:text-xl italic text-gray-700 leading-relaxed mb-4">
    <Fragment set:html={text} />
  </p>
  <p class="font-semibold text-primary-600">{name}</p>
  <p class="text-sm text-warm-gray">{source}</p>
</div>
