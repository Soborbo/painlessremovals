---
/**
 * USP Bar – shared across homepage and all service pages.
 * Renders 4 icon USPs on a dark primary-600 strip with a
 * Google Reviews badge.
 */
import { siteConfig } from '@/config/site.config';
import OptimizedPicture from '@/components/OptimizedPicture.astro';

interface Props {
  hideBadge?: boolean;
}

const { hideBadge = false } = Astro.props;
const rating = siteConfig.company.rating.value;
---

<div class="w-full relative z-20">
  <!-- Google Reviews Badge - sits above the USP strip -->
  {!hideBadge && (
    <div class="hidden lg:flex absolute bottom-full mb-4 left-[calc(50%+1.5rem)] z-10 bg-white/95 backdrop-blur-sm rounded-lg shadow-lg px-4 py-2 items-center gap-2 w-[160px]">
      <img
        src="/images/google-g-logo.svg"
        alt="Google"
        class="w-8 h-8"
        width="32"
        height="32"
      />
      <div class="flex-1">
        <div class="flex items-center justify-between">
          <span class="text-xl font-bold text-gray-800 tabular-nums js-rating-countup" data-target={rating}>{rating}</span>
          <span class="text-yellow-400 text-xs" role="img" aria-label={`${rating} out of 5 stars`}>&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        </div>
        <p class="text-[10px] text-gray-600">Google reviews</p>
      </div>
    </div>
  )}
  <!-- USP strip -->
  <div class="bg-primary-600 py-3">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-4 lg:gap-y-0">

      <!-- Since 1978 -->
      <div class="flex items-center justify-center h-[80px] lg:h-[90px] transition-all duration-300 cursor-default group">
        <OptimizedPicture
          name="usp/usp-since1978"
          pattern="ICON"
          alt="Established since 1978"
          class="max-h-[100px] w-auto transition-transform duration-300 group-hover:scale-110"
        />
      </div>

      <!-- Instant Quote -->
      <div class="flex items-center justify-center h-[80px] lg:h-[90px] transition-all duration-300 cursor-default group">
        <OptimizedPicture
          name="usp/usp-instant-quote"
          pattern="ICON"
          alt="Instant online quote"
          class="max-h-[85px] w-auto transition-transform duration-300 group-hover:scale-110"
        />
      </div>

      <!-- Insurance -->
      <div class="flex items-center justify-center h-[80px] lg:h-[90px] transition-all duration-300 cursor-default group">
        <OptimizedPicture
          name="usp/usp-insurance-removals"
          pattern="ICON"
          alt="Fully insured removals"
          class="max-h-[80px] w-auto transition-transform duration-300 group-hover:scale-110"
        />
      </div>

      <!-- Based in Bristol -->
      <div class="text-center text-white px-3 transition-all duration-300 cursor-default group flex flex-col items-center justify-center h-[80px] lg:h-[90px]">
        <div class="flex items-center justify-center">
          <OptimizedPicture
            name="usp/bristol-bridge-bg"
            pattern="ICON"
            alt=""
            class="max-h-[43px] lg:max-h-[53px] w-auto transition-transform duration-300 group-hover:scale-110"
          />
        </div>
        <p class="text-xs lg:text-sm font-semibold leading-tight transition-transform duration-300 group-hover:scale-110 mt-1">Based in Bristol</p>
      </div>

    </div>
  </div>
</div>

{/* SEO-safe count-up: the real rating is server-rendered into the span so
    crawlers and no-JS users always see it. This inline script runs during
    parse (before the badge paints), resets to the start value with no flash,
    then counts up. Reduced-motion users keep the static value. */}
<script is:inline>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    document.querySelectorAll('.js-rating-countup:not([data-counted])').forEach(function (el) {
      el.setAttribute('data-counted', '');
      var target = parseFloat(el.getAttribute('data-target')) || 4.9;
      el.textContent = '0.0';
      var duration = 1200, startTime = null;
      function tick(now) {
        if (!startTime) startTime = now;
        var t = Math.min((now - startTime) / duration, 1);
        var eased = 1 - Math.pow(1 - t, 3);
        el.textContent = (eased * target).toFixed(1);
        if (t < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    });
  })();
</script>
