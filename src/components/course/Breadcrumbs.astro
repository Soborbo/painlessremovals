---
/**
 * Breadcrumbs — Navigation trail + BreadcrumbList JSON-LD schema
 *
 * Works on both light and dark backgrounds.
 */

import { siteConfig } from '@/config/site.config';

export interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

// Build schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": items.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.label,
    ...(item.href ? { "item": new URL(item.href, siteConfig.brand.domain).toString() } : {}),
  })),
};
---

<nav class="course-breadcrumbs" aria-label="Breadcrumb">
  {items.map((item, index) => (
    <>
      {index > 0 && <span class="separator" aria-hidden="true">&rsaquo;</span>}
      {item.href ? (
        <a href={item.href}>{item.label}</a>
      ) : (
        <span aria-current="page">{item.label}</span>
      )}
    </>
  ))}
</nav>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
