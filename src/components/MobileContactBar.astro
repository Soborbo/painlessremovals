---
/**
 * MobileContactBar — elegant sticky bottom bar with Call Now + Online Quote
 *
 * Appears after 6-second delay with slide-up animation. Mobile/tablet only.
 * Hidden on pages defined by `excludePaths` in the inline script.
 */

import { siteConfig } from '@/config/site.config';

const phone = siteConfig.company.contact.phone.replace(/\s/g, '');
---

<div
  id="mobile-contact-bar"
  class="fixed bottom-0 inset-x-0 z-50 translate-y-full lg:hidden pointer-events-none"
  inert
>
  <div class="bg-white shadow-[0_-2px_20px_rgba(0,0,0,.1)] pointer-events-auto">
    <div class="grid grid-cols-2 gap-px bg-white px-3 py-2.5">
      <!-- Call Now -->
      <a
        href={`tel:${phone}`}
        class="group flex items-center justify-center gap-2.5 py-3.5 bg-secondary-500 text-white font-semibold text-[15px] tracking-wide no-underline transition-all duration-200 hover:bg-secondary-600 active:scale-[.97] rounded-l-md"
      >
        <svg class="w-[18px] h-[18px] shrink-0 transition-transform duration-200 group-hover:rotate-12" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        Call Now
      </a>

      <!-- Online Quote -->
      <a
        href="/instantquote/"
        class="group flex items-center justify-center gap-2.5 py-3.5 bg-primary-600 text-white font-semibold text-[15px] tracking-wide no-underline transition-all duration-200 hover:bg-primary-700 active:scale-[.97] rounded-r-md"
      >
        <svg class="w-[18px] h-[18px] shrink-0 transition-transform duration-200 group-hover:-translate-y-0.5" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        Online Quote
      </a>
    </div>
  </div>
</div>

<style>
  #mobile-contact-bar {
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    opacity: 0;
  }
  #mobile-contact-bar.is-visible {
    transform: translateY(0);
    opacity: 1;
  }
</style>

<script is:inline>
  (function () {
    var bar = document.getElementById('mobile-contact-bar');
    if (!bar) return;

    var excluded = ['/contact', '/contact/', '/contact/thank-you', '/contact/thank-you/', '/vehicle-check', '/vehicle-check/', '/partner-register', '/partner-register/', '/terms-conditions', '/terms-conditions/'];
    var path = window.location.pathname;
    if (excluded.indexOf(path) !== -1) {
      bar.remove();
      return;
    }

    setTimeout(function () {
      bar.classList.add('is-visible');
      bar.removeAttribute('inert');
    }, 6000);
  })();
</script>
