---
/**
 * ProblemSolution — Portrait/image + heading + text content + CTA
 *
 * Two-column layout: image on the left, text on the right.
 * Used on service pages to introduce the problem and solution.
 *
 * Defaults to Jay Newton's homepage portrait if no image props are provided.
 */

import OptimizedPicture from '@/components/OptimizedPicture.astro';

export interface Props {
  /** Section heading */
  heading: string;
  /** CTA button text */
  ctaText?: string;
  /** CTA button href */
  ctaHref?: string;
  /** Background class for the section */
  bgClass?: string;
  /** Image name for OptimizedPicture (default: homepage Jay portrait) */
  imageName?: string;
  /** Image alt text */
  imageAlt?: string;
  /** Image pattern for OptimizedPicture */
  imagePattern?: 'FULL' | 'HALF' | 'QUARTER' | 'SIXTH';
  /** Additional CSS classes for the image element */
  imageClass?: string;
  /** Caption name shown below image */
  captionName?: string;
  /** Caption subtitle shown below name */
  captionSubtitle?: string;
  /** Link href for the caption name */
  captionHref?: string;
}

const {
  heading,
  ctaText,
  ctaHref,
  bgClass = 'bg-white',
  imageName = 'homepage/Jay-Newton-Painless-Removals',
  imageAlt = 'Jay Newton, Director of Painless Removals',
  imagePattern = 'QUARTER',
  imageClass = 'w-48 lg:w-72 aspect-[3/4] object-cover object-top rounded-xl shadow-md',
  captionName = 'Jay Newton',
  captionSubtitle = 'Director, Painless Removals',
  captionHref = '/about/jay-newton',
} = Astro.props;
---

<section class={`py-8 md:py-10 ${bgClass}`}>
  <div class="container-wide">
    <div class="grid lg:grid-cols-[auto_1fr] gap-10 lg:gap-16 items-center">
      <!-- Image -->
      <div class="flex flex-col items-center text-center mx-auto lg:mx-0 order-last lg:order-first">
        <OptimizedPicture
          name={imageName}
          pattern={imagePattern}
          alt={imageAlt}
          sizes="(min-width: 1024px) 280px, 200px"
          class={imageClass}
        />
        {captionName && captionHref ? (
          <a href={captionHref} class="mt-3 text-primary-700 font-semibold hover:text-secondary-500 transition-colors no-underline">
            {captionName}
          </a>
        ) : captionName ? (
          <span class="mt-3 text-primary-700 font-semibold">{captionName}</span>
        ) : null}
        {captionSubtitle && (
          <span class="text-warm-gray text-sm">{captionSubtitle}</span>
        )}
      </div>

      <!-- Text -->
      <div>
        <h2 class="mb-6">{heading}</h2>
        <slot />
        {ctaText && ctaHref && (
          <a href={ctaHref} class="inline-block btn-cta-orange mt-8">
            {ctaText}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
