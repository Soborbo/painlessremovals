---
/**
 * PackingGuideCinema — cinematic dark section showcasing the free packing guide
 *
 * Reusable component: used on homepage and packing service page.
 * Displays course overview, meta info, preview cards, and CTAs.
 */

import OptimizedPicture from '@/components/OptimizedPicture.astro';
---

<section class="guides-cinema" aria-labelledby="guides-heading">
  <!-- Hero split -->
  <div class="guides-cinema-hero">
    <div class="guides-cinema-content">
      <p class="guides-cinema-eyebrow">Free Video Course</p>
      <h2 id="guides-heading" class="guides-cinema-title">The Complete Packing Guide</h2>
      <p class="guides-cinema-subtitle">
        Free, room-by-room video lessons from Bristol's trusted removals team. Everything you need to pack your home safely, efficiently, and without the stress. No sign-ups, no sales pitches.
      </p>

      <div class="guides-cinema-meta">
        <span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          11 lessons
        </span>
        <span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          42 min
        </span>
        <span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          100% free
        </span>
      </div>

      <div class="guides-cinema-ctas">
        <a href="/packing-guide/" class="guides-cinema-cta-primary">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Watch the Packing Guide
        </a>
        <a href="/moving-advice/" class="guides-cinema-cta-secondary">Read Moving Advice &rarr;</a>
      </div>

      <!-- Credit line -->
      <div class="guides-cinema-credit">
        <span class="guides-cinema-credit-label">with</span>
        <span class="guides-cinema-credit-name">Jay Newton</span>
        <span class="guides-cinema-credit-role">Director, Painless Removals &middot; 2,000+ moves</span>
      </div>
    </div>

    <!-- Image -->
    <div class="guides-cinema-image">
      <OptimizedPicture
        name="homepage/packing-video-guide"
        pattern="HALF"
        alt="Jay Newton demonstrating professional packing techniques in a kitchen"
        class="guides-cinema-img"
      />
    </div>
  </div>

  <!-- Preview cards -->
  <div class="guides-cinema-cards">
    <a href="/packing-guide/planning-and-preparation/" class="guides-preview-card">
      <div class="guides-preview-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      </div>
      <div class="guides-preview-body">
        <span class="guides-preview-number">Lesson 1</span>
        <span class="guides-preview-title">Planning & Timeline</span>
      </div>
      <span class="guides-preview-arrow">&rarr;</span>
    </a>
    <a href="/packing-guide/materials-and-equipment/" class="guides-preview-card">
      <div class="guides-preview-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
      </div>
      <div class="guides-preview-body">
        <span class="guides-preview-number">Lesson 2</span>
        <span class="guides-preview-title">Materials & Supplies</span>
      </div>
      <span class="guides-preview-arrow">&rarr;</span>
    </a>
    <a href="/packing-guide/how-to-pack-kitchen/" class="guides-preview-card">
      <div class="guides-preview-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 010 8h-1"/><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
      </div>
      <div class="guides-preview-body">
        <span class="guides-preview-number">Lesson 3</span>
        <span class="guides-preview-title">Packing Your Kitchen</span>
      </div>
      <span class="guides-preview-arrow">&rarr;</span>
    </a>
    <a href="/packing-guide/" class="guides-preview-card guides-preview-card--all">
      <div class="guides-preview-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      </div>
      <div class="guides-preview-body">
        <span class="guides-preview-number">All 11 Lessons</span>
        <span class="guides-preview-title">View Full Course</span>
      </div>
      <span class="guides-preview-arrow">&rarr;</span>
    </a>
  </div>
</section>
