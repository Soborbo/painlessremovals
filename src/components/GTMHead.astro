---
/**
 * Google Tag Manager — <head> snippet.
 *
 * The order here matters:
 *   1. Consent Mode default (everything denied) — MUST run before GTM
 *      so any tag that fires before the CMP responds has a defined
 *      consent context.
 *   2. GTM bootstrap. The CookieYes CMP itself is loaded by a tag
 *      INSIDE the GTM container (firing on the built-in "Consent
 *      Initialization - All Pages" trigger), so GTM and the CMP
 *      load order is managed in one place.
 */
import { env } from 'cloudflare:workers';
const gtmId = env.GTM_ID || import.meta.env.GTM_ID || '';
---

{/* 1. Consent Mode v2 default — first script in <head> */}
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){ window.dataLayer.push(arguments); }
  window.gtag = window.gtag || gtag;
  gtag('consent', 'default', {
    ad_storage: 'denied',
    analytics_storage: 'denied',
    ad_user_data: 'denied',
    ad_personalization: 'denied',
    functionality_storage: 'denied',
    personalization_storage: 'denied',
    security_storage: 'granted',
    wait_for_update: 500,
  });
</script>

{/* 2. GTM bootstrap — the GTM container itself loads CookieYes via the
       "CookieYes CMP" tag on the Consent Initialization trigger */}
{gtmId && (
  <script set:html={`
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','${gtmId}');
  `} />
)}
