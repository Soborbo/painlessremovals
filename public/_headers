# ── Static assets — long-lived immutable caching ─────────────
# Files under public/ otherwise fall through to Cloudflare's default
# `Cache-Control: max-age=0, must-revalidate`, which forces a revalidation
# round-trip for every image/font on every request and cripples LCP from a
# cold/distant CF edge (PageSpeed saw 8s). These are effectively versioned
# (fonts never change; images carry width suffixes) — replace by renaming.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/img/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.ico
  Cache-Control: public, max-age=604800

/favicon.svg
  Cache-Control: public, max-age=604800

# ── Sitemap files — cacheable, no restrictive security headers ─
/sitemap-index.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600
  X-Robots-Tag: noindex

/sitemap-0.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600
  X-Robots-Tag: noindex

/video-sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600
  X-Robots-Tag: noindex

/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=14400

# ── Default security headers for all other pages ─────────────
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  # HSTS: site is HTTPS-only behind Cloudflare. 2 years + preload-ready.
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  # ── Content-Security-Policy (defence-in-depth vs XSS) ──────────
  # NOT enforced yet: this is a conversion-critical site and an over-tight
  # CSP silently breaks GTM/GA4/Meta Pixel/CookieYes/Turnstile (the exact
  # systems with revenue impact). Promote the Report-Only line below to
  # `Content-Security-Policy` only after watching reports across every
  # template. Known origins to allowlist are baked into it already.
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://*.google-analytics.com https://connect.facebook.net https://challenges.cloudflare.com https://cdn-cookieyes.com; connect-src 'self' https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com https://connect.facebook.net https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; frame-ancestors 'self'
