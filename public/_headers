# ── Static assets — long-lived immutable caching ─────────────
# Files under public/ otherwise fall through to Cloudflare's default
# `Cache-Control: max-age=0, must-revalidate`, which forces a revalidation
# round-trip for every image/font on every request and cripples LCP from a
# cold/distant CF edge (PageSpeed saw 8s). These are effectively versioned
# (fonts never change; images carry width suffixes) — replace by renaming.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/img/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.ico
  Cache-Control: public, max-age=604800

/favicon.svg
  Cache-Control: public, max-age=604800

# ── Sitemap files — cacheable, no restrictive security headers ─
/sitemap-index.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600
  X-Robots-Tag: noindex

/sitemap-0.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600
  X-Robots-Tag: noindex

/video-sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600
  X-Robots-Tag: noindex

/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=14400

# ── Default security headers for all other pages ─────────────
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
